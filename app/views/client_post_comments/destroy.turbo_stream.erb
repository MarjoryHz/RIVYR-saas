<%= turbo_stream.replace "comments_#{@client_post.id}" do %>
  <div id="comments_<%= @client_post.id %>" class="space-y-3">
    <%= render "client_post_comments/comments_list", client_post: @client_post %>
  </div>
<% end %>

<%= turbo_stream.replace "company_contribution_comment_count_#{@client_post.id}" do %>
  <button type="button"
    id="company_contribution_comment_count_<%= @client_post.id %>"
    onclick="document.getElementById('comments_modal_<%= @client_post.id %>')?.classList.remove('hidden');document.body.classList.add('overflow-hidden')"
    class="inline-flex items-center gap-2.5 transition hover:text-white">
    <i class="fa-regular fa-comment"></i>
    <span><%= @client_post.client_post_comments.count %></span>
  </button>
<% end %>

<%= turbo_stream.replace "company_contribution_modal_comment_count_#{@client_post.id}" do %>
  <button type="button"
    id="company_contribution_modal_comment_count_<%= @client_post.id %>"
    onclick="document.getElementById('comments_<%= @client_post.id %>')?.scrollIntoView({ behavior: 'smooth', block: 'start' })"
    class="inline-flex items-center gap-2.5 text-[#6b3f4f] transition hover:text-[#ed0e64]">
    <i class="fa-regular fa-comment"></i>
    <span><%= @client_post.client_post_comments.count %></span>
  </button>
<% end %>

<%= turbo_stream.replace "comments_badge_#{@client_post.id}" do %>
  <span id="comments_badge_<%= @client_post.id %>" class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-[#a33d68]">
    <%= @client_post.client_post_comments.count %> message<%= @client_post.client_post_comments.count > 1 ? "s" : "" %>
  </span>
<% end %>
