<%= form_with url: client_post_client_post_comments_path(client_post), scope: :client_post_comment, id: "comment_form_#{client_post.id}", data: { turbo: true } do |f| %>
  <div class="rounded-[1.6rem] border border-[#ead2dc] bg-[linear-gradient(180deg,#ffffff_0%,#fffafb_100%)] p-3 shadow-[0_12px_24px_rgba(94,31,50,0.06)]">
    <div class="mb-3 flex items-center gap-2.5">
      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-2xl border border-[#ead2dc] bg-gradient-to-br from-[#fdeef3] to-[#f5c8d8] text-xs font-bold text-[#ed0e64]">
        <%= current_user.first_name&.first&.upcase %>
      </div>
      <div class="min-w-0">
        <p class="text-xs font-semibold text-[#4c1f2a]"><%= current_user.first_name %> <%= current_user.last_name %></p>
      </div>
    </div>

    <% if comment.errors.any? %>
      <div class="mb-3 rounded-2xl border border-[#f7c7d8] bg-[#fff1f6] px-3 py-2 text-xs text-[#a33d68]">
        <%= comment.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="rounded-[1.35rem] border border-[#dfc0ce] bg-white/90 px-4 py-3 transition focus-within:border-[#ed0e64] focus-within:bg-white focus-within:shadow-[0_0_0_3px_rgba(237,14,100,0.08)]">
      <%= f.text_area :body,
          value: comment.body,
          placeholder: "Partager un point de vue, un retour ou une question...",
          class: "min-h-[96px] w-full resize-none bg-transparent text-sm leading-6 text-[#4c1f2a] placeholder-[#c9a0b0] outline-none",
          autocomplete: "off",
          rows: 4,
          maxlength: 500 %>
    </div>

    <div class="mt-3 flex items-center justify-between gap-3">
      <p class="text-[11px] text-[#9a7080]">500 caracteres maximum.</p>
      <%= f.submit "Publier",
          class: "inline-flex cursor-pointer items-center justify-center rounded-full bg-[#ed0e64] px-4 py-2 text-sm font-semibold text-white transition hover:bg-[#cf0c57]" %>
    </div>
  </div>
<% end %>
