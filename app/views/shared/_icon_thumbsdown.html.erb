<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" fill="none" class="<%= local_assigns[:css_class] || 'size-5' %>">
  <!-- Fist body -->
  <rect x="10" y="6" width="72" height="44" rx="12" fill="#fdeef3" stroke="#4c1f2a" stroke-width="5" paint-order="stroke"/>
  <!-- Thumb pointing down -->
  <path d="M20 50 L20 82 Q20 92 32 92 Q44 92 44 82 L44 50Z" fill="#fdeef3" stroke="#4c1f2a" stroke-width="5" stroke-linejoin="round" paint-order="stroke"/>
  <!-- Finger lines on fist -->
  <line x1="36" y1="14" x2="36" y2="42" stroke="#4c1f2a" stroke-width="3.5" stroke-linecap="round"/>
  <line x1="56" y1="14" x2="56" y2="42" stroke="#4c1f2a" stroke-width="3.5" stroke-linecap="round"/>
  <!-- Wrist detail -->
  <rect x="10" y="6" width="72" height="6" rx="3" fill="#4c1f2a"/>
</svg>
