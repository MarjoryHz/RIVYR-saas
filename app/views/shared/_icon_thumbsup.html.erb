  <rect x="10" y="50" width="72" height="44" rx="12" fill="#fdeef3" stroke="#4c1f2a" stroke-width="5" paint-order="stroke"/>
  <!-- Thumb -->
  <path d="M20 50 L20 18 Q20 8 32 8 Q44 8 44 18 L44 50Z" fill="#fdeef3" stroke="#4c1f2a" stroke-width="5" stroke-linejoin="round" paint-order="stroke"/>
  <!-- Finger lines on fist -->
  <line x1="36" y1="58" x2="36" y2="86" stroke="#4c1f2a" stroke-width="3.5" stroke-linecap="round"/>
  <line x1="56" y1="58" x2="56" y2="86" stroke="#4c1f2a" stroke-width="3.5" stroke-linecap="round"/>
  <!-- Wrist detail -->
  <rect x="10" y="88" width="72" height="6" rx="3" fill="#4c1f2a"/>
</svg>
