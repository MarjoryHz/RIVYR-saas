<nav class="fixed inset-x-0 top-0 z-100 px-4 pt-4 md:px-6 md:pt-6">
  <% search_modal_id = "freelance_quick_search_modal" %>
  <% show_back_button = !(controller_name == "missions" && action_name == "index") && !(controller_name == "missions" && action_name == "dashboard") && !(controller_name == "candidates" && action_name == "index") %>
  <% back_url = if controller_name == "candidates" && action_name == "show"
      request.path.start_with?("/dashboard") ? dashboard_candidates_path : candidates_path
    else
      request.referer.presence || dashboard_path
    end %>
  <div class="flex items-center justify-between">
    <div></div>

    <div class="flex shrink-0 items-center gap-2">
      <% if show_back_button %>
        <a href="#" onclick="history.back(); return false;" class="inline-flex h-10 items-center gap-2 rounded-full border border-base-200 bg-base-100/80 px-4 text-sm font-medium text-base-content/75 shadow-sm transition hover:bg-base-100 hover:text-base-content">
          <i class="fa-solid fa-arrow-left text-[#ed0e64]"></i>
          Retour
        </a>
      <% end %>
      <button type="button" class="h-10 w-10 items-center justify-center rounded-full border border-base-200 bg-base-100/80 text-primary shadow-sm transition hover:bg-base-100 sm:inline-flex" onclick="document.getElementById('<%= search_modal_id %>').showModal()">
        <i class="fa-solid fa-magnifying-glass text-base text-[#ed0e64]"></i>
      </button>
      <%= link_to dashboard_pending_missions_path, class: "relative inline-flex h-10 w-10 items-center justify-center rounded-full border border-base-200 bg-base-100/80 text-primary shadow-sm transition hover:bg-base-100 sm:inline-flex" do %>
        <i class="fa-regular fa-bell text-base text-[#ed0e64]"></i>
        <% if freelance_attention_count.positive? %>
          <span class="absolute -right-1 -top-1 inline-flex min-h-[1.45rem] min-w-[1.45rem] items-center justify-center rounded-full bg-[#ed0e64] px-1.5 text-[11px] font-bold text-white shadow-[0_10px_18px_rgba(237,14,100,0.25)]">
            <%= freelance_attention_count %>
          </span>
        <% end %>
      <% end %>
      <button type="button" class="h-10 w-10 items-center justify-center rounded-full border border-base-200 bg-base-100/80 text-primary shadow-sm sm:inline-flex">
        <i class="fa-solid fa-robot text-base text-[#ed0e64]"></i>
      </button>
    </div>
  </div>
</nav>

<dialog id="<%= search_modal_id %>" class="modal">
  <div class="modal-box max-w-xl rounded-[1.75rem] border border-[#f2d5df] bg-base-100 shadow-2xl">
    <div class="space-y-5">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h3 class="text-2xl font-semibold text-base-content">Recherche rapide</h3>
          <p class="mt-1 text-sm text-base-content/65">Trouve rapidement une section du site.</p>
        </div>
        <form method="dialog">
          <button class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-base-200 bg-base-100/80 text-base-content/60 transition hover:bg-base-100 hover:text-base-content">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </form>
      </div>

      <label class="flex items-center gap-3 rounded-full border border-[#f2d5df] bg-[#fff5f8] px-5 py-3 text-[#b36a82] shadow-sm">
        <i class="fa-solid fa-magnifying-glass text-sm text-[#ed0e64]"></i>
        <input
          type="text"
          placeholder="Rechercher une page, une rubrique, une action..."
          class="w-full bg-transparent text-sm text-base-content outline-none placeholder:text-[#c79aad]"
          autofocus
          oninput="const query = this.value.toLowerCase(); const items = this.closest('dialog').querySelectorAll('[data-search-item]'); items.forEach((item) => { item.classList.toggle('hidden', !item.dataset.searchItem.includes(query)); });">
      </label>

      <div class="grid gap-3 sm:grid-cols-2">
        <%= link_to dashboard_path, class: "flex items-center gap-3 rounded-2xl border border-[#f2d5df] bg-[#fff7f9] px-4 py-3 text-base-content transition hover:bg-white", data: { search_item: "dashboard accueil tableau de bord recrutement freelance" } do %>
          <i class="fa-solid fa-table-columns text-[#ed0e64]"></i>
          <div>
            <p class="font-semibold">Dashboard</p>
            <p class="text-sm text-base-content/60">Cockpit et suivi global</p>
          </div>
        <% end %>

        <%= link_to dashboard_my_missions_path, class: "flex items-center gap-3 rounded-2xl border border-[#f2d5df] bg-[#fff7f9] px-4 py-3 text-base-content transition hover:bg-white", data: { search_item: "mes missions en cours urgent freelance" } do %>
          <i class="fa-solid fa-list-check text-[#ed0e64]"></i>
          <div>
            <p class="font-semibold">Mes missions</p>
            <p class="text-sm text-base-content/60">Missions en cours et priorités</p>
          </div>
        <% end %>

        <%= link_to dashboard_pending_missions_path, class: "flex items-center gap-3 rounded-2xl border border-[#f2d5df] bg-[#fff7f9] px-4 py-3 text-base-content transition hover:bg-white", data: { search_item: "attente validation pending missions" } do %>
          <i class="fa-regular fa-clock text-[#ed0e64]"></i>
          <div>
            <p class="font-semibold">En attente</p>
            <p class="text-sm text-base-content/60">Validations et missions en attente</p>
          </div>
        <% end %>

        <%= link_to dashboard_freelance_finance_path, class: "flex items-center gap-3 rounded-2xl border border-[#f2d5df] bg-[#fff7f9] px-4 py-3 text-base-content transition hover:bg-white", data: { search_item: "finance signature placement paiement" } do %>
          <i class="fa-solid fa-wallet text-[#ed0e64]"></i>
          <div>
            <p class="font-semibold">Finance</p>
            <p class="text-sm text-base-content/60">Signatures, placements et paiements</p>
          </div>
        <% end %>

        <%= link_to dashboard_freelancer_profiles_path, class: "flex items-center gap-3 rounded-2xl border border-[#f2d5df] bg-[#fff7f9] px-4 py-3 text-base-content transition hover:bg-white", data: { search_item: "cvtheque cv profils candidats freelance" } do %>
          <i class="fa-solid fa-folder-open text-[#ed0e64]"></i>
          <div>
            <p class="font-semibold">CVthèque</p>
            <p class="text-sm text-base-content/60">Profils et documents</p>
          </div>
        <% end %>

        <%= link_to placements_path(tab: "validated"), class: "flex items-center gap-3 rounded-2xl border border-[#f2d5df] bg-[#fff7f9] px-4 py-3 text-base-content transition hover:bg-white", data: { search_item: "placements valides finance archive" } do %>
          <i class="fa-solid fa-circle-check text-[#ed0e64]"></i>
          <div>
            <p class="font-semibold">Placements validés</p>
            <p class="text-sm text-base-content/60">Dossiers validés par Rivyr</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
