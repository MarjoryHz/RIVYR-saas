<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 110" fill="none" class="<%= local_assigns[:css_class] || 'size-5' %>">
  <!-- Fist body -->
  <rect x="10" y="52" width="60" height="48" rx="14" fill="#fdeef3" stroke="#4c1f2a" stroke-width="5" paint-order="stroke"/>
  <!-- Index finger -->
  <rect x="22" y="10" width="16" height="52" rx="8" fill="#fdeef3" stroke="#4c1f2a" stroke-width="5" paint-order="stroke"/>
  <!-- Middle finger -->
  <rect x="42" y="10" width="16" height="52" rx="8" fill="#fdeef3" stroke="#4c1f2a" stroke-width="5" paint-order="stroke"/>
  <!-- Finger separation lines -->
  <line x1="38" y1="52" x2="38" y2="62" stroke="#4c1f2a" stroke-width="4" stroke-linecap="round"/>
</svg>
