<% active_controller = controller_name %>
<% active_action = action_name %>
<aside class="freelance-sidebar" data-freelance-sidebar>
  <div class="freelance-sidebar__shell">
    <div class="freelance-sidebar__header z-50">
      <%= link_to safe_join([
        content_tag(:span, inline_svg_tag("icon_pers.svg", class: "freelance-sidebar__brand-mark-icon"), class: "freelance-sidebar__brand-mark"),
        content_tag(:span, inline_svg_tag("icon_rivyr.svg", class: "freelance-sidebar__brand-wordmark-icon"), class: "freelance-sidebar__brand-wordmark")
      ]), dashboard_path, class: "freelance-sidebar__brand", aria: { label: "Rivyr" } %>
    </div>

    <div class="freelance-sidebar__content">
      <button type="button" class="freelance-sidebar__collapse freelance-sidebar__collapse--content" aria-label="Réduire la sidebar freelance" aria-expanded="true" data-freelance-sidebar-toggle>
        <span class="freelance-sidebar__collapse-open"><i class="fa-solid fa-angle-left"></i></span>
        <span class="freelance-sidebar__collapse-closed"><i class="fa-solid fa-bars"></i></span>
      </button>

      <ul class="freelance-sidebar__menu">
        <li class="freelance-sidebar__menu-item">
          <%= link_to dashboard_path, class: ["freelance-sidebar__item", ("freelance-sidebar__item--active" if active_controller == "missions" && active_action == "dashboard")] do %>
            <i class="fa-solid fa-table-columns"></i>
            <span>Dashboard</span>
          <% end %>
        </li>
        <li class="freelance-sidebar__menu-item">
          <%= link_to dashboard_missions_path, class: ["freelance-sidebar__item", ("freelance-sidebar__item--active" if active_controller == "missions" && active_action == "index")] do %>
            <i class="fa-solid fa-briefcase"></i>
            <span>Missions</span>
            <% if freelance_attention_count.positive? %>
              <span class="freelance-sidebar__item-badge"><%= freelance_attention_count %></span>
            <% end %>
          <% end %>
        </li>
        <li class="freelance-sidebar__menu-item">
          <%= link_to dashboard_freelance_finance_path, class: ["freelance-sidebar__item", ("freelance-sidebar__item--active" if active_controller.in?(%w[freelance_finances invoices placements]))] do %>
            <i class="fa-solid fa-wallet"></i>
            <span>Finance</span>
          <% end %>
        </li>
        <li class="freelance-sidebar__menu-item">
          <%= link_to dashboard_candidates_path, class: ["freelance-sidebar__item", ("freelance-sidebar__item--active" if active_controller == "candidates")] do %>
            <i class="fa-solid fa-folder-open"></i>
            <span>CVthèque</span>
          <% end %>
        </li>
        <li class="freelance-sidebar__menu-item">
          <%= link_to todo_list_path, class: ["freelance-sidebar__item", ("freelance-sidebar__item--active" if active_controller == "todo_lists")] do %>
            <i class="fa-solid fa-list-check"></i>
            <span>To-do list</span>
          <% end %>
        </li>
        <li class="freelance-sidebar__menu-item">
          <%= link_to dashboard_training_path, class: ["freelance-sidebar__item", ("freelance-sidebar__item--active" if active_controller == "pages" && active_action == "training")] do %>
            <i class="fa-solid fa-graduation-cap"></i>
            <span>Formation</span>
          <% end %>
        </li>
        <li class="freelance-sidebar__menu-item">
          <%= link_to dashboard_feed_path, class: ["freelance-sidebar__item", ("freelance-sidebar__item--active" if active_controller == "pages" && active_action == "feed")] do %>
            <i class="fa-solid fa-newspaper"></i>
            <span>Feed</span>
          <% end %>
        </li>
        <li class="freelance-sidebar__menu-item">
          <%= link_to dashboard_community_path, class: ["freelance-sidebar__item", ("freelance-sidebar__item--active" if active_controller == "pages" && active_action == "community")] do %>
            <i class="fa-solid fa-users"></i>
            <span>Communauté</span>
          <% end %>
        </li>
      </ul>
    </div>

    <% if user_signed_in? %>
      <details class="freelance-sidebar__profile-menu">
        <summary class="freelance-sidebar__footer">
          <div class="freelance-sidebar__avatar-wrap">
            <div class="freelance-sidebar__avatar">
              <%= image_tag avatar_asset_src(current_user), alt: current_user.display_name, class: "h-full w-full rounded-full object-cover" %>
            </div>
            <span class="freelance-sidebar__avatar-status"></span>
          </div>
          <div class="freelance-sidebar__identity">
            <strong><%= current_user.display_name.presence || current_user.email %></strong>
            <span><%= current_user.role.to_s.humanize.presence || "Utilisateur" %></span>
          </div>
          <span class="freelance-sidebar__footer-chevron">
            <i class="fa-solid fa-chevron-up"></i>
          </span>
        </summary>

        <div class="freelance-sidebar__profile-dropdown">
          <div class="freelance-sidebar__profile-header">
            <div class="freelance-sidebar__avatar-wrap">
              <div class="freelance-sidebar__avatar freelance-sidebar__avatar--panel">
                <%= image_tag avatar_asset_src(current_user), alt: current_user.display_name.presence || current_user.email, class: "h-full w-full rounded-full object-cover" %>
              </div>
              <span class="freelance-sidebar__avatar-status"></span>
            </div>
            <div class="freelance-sidebar__identity freelance-sidebar__identity--panel">
              <strong><%= current_user.display_name.presence || current_user.email %></strong>
              <span><%= current_user.role.to_s.humanize.presence || "Utilisateur" %></span>
            </div>
          </div>

          <div class="freelance-sidebar__profile-links">
            <%= link_to(current_user.freelancer_profile.present? ? freelancer_profile_path(current_user.freelancer_profile) : edit_user_registration_path, class: "freelance-sidebar__profile-link") do %>
              <i class="fa-regular fa-user"></i>
              <span>Mon compte</span>
            <% end %>
            <%= link_to(current_user.freelancer_profile.present? ? edit_freelancer_profile_path(current_user.freelancer_profile) : edit_user_registration_path, class: "freelance-sidebar__profile-link") do %>
              <i class="fa-solid fa-gear"></i>
              <span>Parametres du profil</span>
            <% end %>
          </div>

          <div class="freelance-sidebar__profile-actions">
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "freelance-sidebar__profile-link freelance-sidebar__profile-link--logout" do %>
              <i class="fa-solid fa-arrow-right-from-bracket"></i>
              <span>Se deconnecter</span>
            <% end %>
          </div>
        </div>
      </details>
    <% end %>
  </div>
</aside>
