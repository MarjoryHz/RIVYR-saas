<article class="flex gap-3">
  <%= render "pages/community_avatar",
      wrapper_classes: "h-14 w-14 shrink-0",
      avatar_path: message[:avatar],
      alt_text: message[:author],
      status_dot: (message[:tone] == "rivyr" ? "bg-[#ed0e64]" : "bg-[#12d45e]") %>
  <div class="min-w-0 flex-1 rounded-3xl border <%= message[:tone] == 'rivyr' ? 'border-[#f2c9d8] bg-[#fff1f6]' : 'border-[#efdbe4] bg-white/80' %> p-4">
    <div class="flex flex-wrap items-center gap-2">
      <p class="font-semibold text-[#4c1f2a]"><%= message[:author] %></p>
      <span class="text-xs text-[#8a6170]"><%= message[:role] %></span>
      <span class="text-xs text-[#b38494]">•</span>
      <span class="text-xs text-[#8a6170]"><%= message[:time] %></span>
      <% if message[:author_id].to_i == current_user.id %>
        <span class="rounded-full bg-[#fff1f6] px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide text-[#a33d68]">Vous</span>
      <% end %>
    </div>
    <p class="mt-2 text-[15px] leading-7 text-[#5f3647]"><%= message[:body] %></p>

    <% if message[:replies].present? %>
      <div class="mt-3 space-y-2 rounded-2xl border border-[#f1dce5] bg-white/65 p-3">
        <% message[:replies].each do |reply| %>
          <div class="flex items-start gap-3">
            <%= render "pages/community_avatar",
                wrapper_classes: "h-9 w-9 shrink-0",
                avatar_path: reply[:avatar],
                alt_text: reply[:author],
                status_dot: nil %>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-[#4c1f2a]"><%= reply[:author] %> <span class="font-normal text-xs text-[#8a6170]">· <%= reply[:time] %></span></p>
              <p class="text-sm leading-6 text-[#5f3647]"><%= reply[:body] %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
      <div class="flex flex-wrap gap-2">
        <%= link_to "Répondre", dashboard_community_path(channel: current_channel, reply_to: message[:id]), class: "rounded-full border border-[#dfbcc9] bg-white px-3 py-1.5 text-xs font-semibold text-[#8b4452] transition hover:bg-[#fdeef3]" %>
        <%= link_to "Ajouter une réaction", dashboard_community_path(channel: current_channel, react_to: message[:id]), class: "rounded-full border border-[#dfbcc9] bg-white px-3 py-1.5 text-xs font-semibold text-[#8b4452] transition hover:bg-[#fdeef3]" %>
        <% if message[:author_id].to_i == current_user.id %>
          <%= button_to "Supprimer", dashboard_community_message_path(message[:id]), method: :delete, params: { channel: current_channel }, class: "rounded-full border border-[#f2c9d8] bg-white px-3 py-1.5 text-xs font-semibold text-[#c0466c] transition hover:bg-[#fff1f6]", form_class: "inline-block" %>
        <% end %>
      </div>
      <div class="flex flex-wrap justify-end gap-2">
        <% message[:reactions].each do |reaction| %>
          <span class="rounded-full border border-[#dfbcc9] bg-white px-3 py-1.5 text-xs font-semibold text-[#8b4452]"><%= reaction[:emoji] %> <%= reaction[:count] %></span>
        <% end %>
      </div>
    </div>
  </div>
</article>
