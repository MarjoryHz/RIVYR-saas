
<section class="hero min-h-96 bg-gradient-to-r from-primary to-secondary">
  <div class="hero-content text-center text-neutral-content">
    <div class="max-w-md">
      <h1 class="mb-5 text-5xl font-bold">Trouvez les meilleurs talents</h1>
      <p class="mb-5 text-lg">Plateforme de recrutement intelligente pour transformer votre hiring</p>
      <div class="flex gap-4 justify-center">
        <%= link_to "Commencer gratuitement", new_user_registration_path, class: "btn btn-primary" %>
        <% if policy(Client).index? %>
          <%= link_to "Voir les clients", clients_path, class: "btn btn-outline btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</section>
