<% content_for :title, "Rivyr | Plateforme de recrutement freelance" %>

<section class="relative overflow-hidden px-4 py-5 md:px-6 md:py-6">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(255,255,255,0.85),_transparent_42%),radial-gradient(circle_at_bottom_left,_rgba(253,164,175,0.26),_transparent_36%),radial-gradient(circle_at_right,_rgba(251,146,60,0.18),_transparent_34%)]"></div>

  <div class="relative mx-auto max-w-7xl space-y-6">
    <header class="rounded-[2rem] border border-white/60 bg-white/70 px-5 py-4 shadow-[0_18px_50px_rgba(120,51,75,0.10)] backdrop-blur md:px-8">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="flex items-center gap-3">
          <%= inline_svg_tag("icon_pers.svg", class: "h-11 w-auto text-primary") %>
          <%= inline_svg_tag("icon_rivyr.svg", class: "h-8 w-auto text-[#5f2a39]") %>
        </div>

        <nav class="flex flex-wrap items-center gap-2 text-sm font-medium text-base-content/70 md:text-base">
          <%= link_to "Accueil", root_path, class: "rounded-full px-4 py-2 text-base-content transition hover:bg-white/80 hover:text-base-content" %>
          <span class="hidden text-base-content/20 md:inline">/</span>
          <%= link_to "Fonctionnalités", "#fonctionnalites", class: "rounded-full px-4 py-2 transition hover:bg-white/80 hover:text-base-content" %>
          <%= link_to "Tarifs", "#tarifs", class: "rounded-full px-4 py-2 transition hover:bg-white/80 hover:text-base-content" %>
          <%= link_to "Contact", contact_path, class: "rounded-full px-4 py-2 transition hover:bg-white/80 hover:text-base-content" %>
        </nav>

        <div class="flex items-center gap-3 self-start lg:self-auto">
          <%= link_to "Se connecter", new_user_session_path, class: "inline-flex items-center justify-center rounded-full bg-[#f58d7d] px-6 py-3 text-base font-semibold text-white shadow-[0_10px_24px_rgba(245,141,125,0.35)] transition hover:-translate-y-0.5 hover:bg-[#ed7d6c]" %>
          <div class="flex h-11 items-center gap-2 rounded-full border border-white/60 bg-white/80 px-3 text-sm font-medium text-base-content/70 shadow-sm">
            <span class="text-lg">FR</span>
            <i class="fa-solid fa-angle-down text-xs text-base-content/40"></i>
          </div>
        </div>
      </div>
    </header>

    <div class="grid gap-6 lg:grid-cols-[minmax(0,1.35fr)_minmax(260px,0.65fr)] lg:items-stretch">
      <section class="relative overflow-hidden p-6 md:p-10">
        <div class="relative max-w-4xl space-y-8">
          <div class="space-y-5">
            <div class="space-y-4">
              <h1 class="max-w-4xl text-4xl font-semibold leading-[1.08] tracking-tight text-[#5a2c39] md:text-[4rem] xl:text-[3.8rem]">
                La plateforme clé en main pour freelances et entreprises qui recrutent mieux
              </h1>
              <p class="max-w-2xl text-lg leading-8 text-[#7d5a66] md:text-xl">
                Centralisez vos missions, fluidifiez les échanges et gagnez du temps à chaque étape du recrutement.
              </p>
            </div>
          </div>

          <div class="flex flex-col gap-4 md:flex-row">
            <label class="flex h-16 flex-1 items-center rounded-full border border-white/70 bg-white/86 px-6 text-base text-[#9a7b84] shadow-inner">
              <input type="email" placeholder="Entrez votre email" class="w-full bg-transparent outline-none placeholder:text-[#b79ca4]">
            </label>
            <%= link_to "Essayer gratuitement", new_user_registration_path, class: "inline-flex h-16 items-center justify-center rounded-full bg-[#f59b84] px-8 text-lg font-semibold text-white shadow-[0_14px_30px_rgba(245,155,132,0.38)] transition hover:-translate-y-0.5 hover:bg-[#ef8b73]" %>
          </div>
        </div>
      </section>

      <aside class="min-h-[420px] rounded-[2.25rem] lg:min-h-full"></aside>
    </div>

    <section id="fonctionnalites" class="grid gap-6 lg:grid-cols-3">
      <article class="rounded-[2rem] border border-white/60 bg-white/70 p-6 shadow-[0_18px_50px_rgba(120,51,75,0.10)] backdrop-blur">
        <div class="flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#fff1ed] text-[#f28f78]">
            <i class="fa-solid fa-briefcase text-lg"></i>
          </div>
          <h2 class="text-3xl font-semibold text-[#5a2c39]">Freelances</h2>
        </div>
        <p class="mt-4 text-base leading-7 text-[#7d5a66]">
          Développez votre activité avec un environnement conçu pour suivre vos missions et vos relations clients.
        </p>
        <ul class="mt-6 space-y-3 text-base text-[#6f4a57]">
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Tableau de bord clair pour piloter vos missions en cours.</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Messagerie et suivi d’avancement centralisés.</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Bibliothèque de missions pour repérer rapidement les bonnes opportunités.</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Visibilité sur la facturation et les prochaines étapes.</span></li>
        </ul>
      </article>

      <article class="rounded-[2rem] border border-white/60 bg-white/70 p-6 shadow-[0_18px_50px_rgba(120,51,75,0.10)] backdrop-blur">
        <div class="flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#fff1ed] text-[#f28f78]">
            <i class="fa-solid fa-building text-lg"></i>
          </div>
          <h2 class="text-3xl font-semibold text-[#5a2c39]">Entreprises</h2>
        </div>
        <p class="mt-4 text-base leading-7 text-[#7d5a66]">
          Regroupez vos besoins de recrutement dans une interface unique, pensée pour travailler avec plusieurs recruteurs.
        </p>
        <ul class="mt-6 space-y-3 text-base text-[#6f4a57]">
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Publication et suivi des missions depuis un point d’entrée unique.</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Collaboration fluide avec vos recruteurs externes ou internes.</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Centralisation des candidatures, échanges et étapes de validation.</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Vision consolidée sur l’avancement de vos recrutements.</span></li>
        </ul>
      </article>

      <article class="rounded-[2rem] border border-white/60 bg-white/70 p-6 shadow-[0_18px_50px_rgba(120,51,75,0.10)] backdrop-blur">
        <div class="flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#fff1ed] text-[#f28f78]">
            <i class="fa-solid fa-user-check text-lg"></i>
          </div>
          <h2 class="text-3xl font-semibold text-[#5a2c39]">Candidats</h2>
        </div>
        <p class="mt-4 text-base leading-7 text-[#7d5a66]">
          Offrez une expérience plus lisible aux talents, avec des opportunités mieux qualifiées et un suivi plus transparent.
        </p>
        <ul class="mt-6 space-y-3 text-base text-[#6f4a57]">
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Profils et candidatures mieux structurés pour gagner en clarté.</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Accès à des missions adaptées aux besoins des recruteurs.</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Communication simplifiée entre recruteurs, entreprises et talents.</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#f59b84]"></span><span>Parcours plus fluide, du premier échange jusqu’au placement.</span></li>
        </ul>
      </article>
    </section>

    <section id="contact" class="rounded-[2rem] border border-white/60 bg-white/72 p-6 shadow-[0_18px_50px_rgba(120,51,75,0.10)] backdrop-blur md:p-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl space-y-3">
          <p class="text-sm uppercase tracking-[0.22em] text-[#b18a96]">Contact</p>
          <h2 class="text-3xl font-semibold text-[#5a2c39] md:text-4xl">Prêt à découvrir Rivyr ?</h2>
          <p class="text-base leading-7 text-[#7d5a66]">
            Décris ton besoin, ton contexte de recrutement ou ton projet produit et nous te répondrons rapidement.
          </p>
        </div>

        <%= link_to "Accéder au formulaire de contact", contact_path, class: "inline-flex items-center justify-center rounded-full bg-[#f59b84] px-6 py-3 text-base font-semibold text-white shadow-[0_14px_30px_rgba(245,155,132,0.38)] transition hover:-translate-y-0.5 hover:bg-[#ef8b73]" %>
      </div>
    </section>
  </div>
</section>
