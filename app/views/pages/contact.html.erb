<% content_for :title, "Rivyr | Contact" %>

<section class="relative overflow-hidden px-4 py-5 md:px-6 md:py-6">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(255,255,255,0.85),_transparent_42%),radial-gradient(circle_at_bottom_left,_rgba(253,164,175,0.22),_transparent_36%),radial-gradient(circle_at_right,_rgba(251,146,60,0.16),_transparent_34%)]"></div>

  <div class="relative mx-auto max-w-7xl space-y-6">
    <header class="rounded-[2rem] border border-white/60 bg-white/70 px-5 py-4 shadow-[0_18px_50px_rgba(120,51,75,0.10)] backdrop-blur md:px-8">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="flex items-center gap-3">
          <%= link_to safe_join([
            inline_svg_tag("icon_pers.svg", class: "h-11 w-auto text-primary"),
            inline_svg_tag("icon_rivyr.svg", class: "h-8 w-auto text-[#5f2a39]")
          ]), root_path, class: "flex items-center gap-3" %>
        </div>

        <nav class="flex flex-wrap items-center gap-2 text-sm font-medium text-base-content/70 md:text-base">
          <%= link_to "Accueil", root_path, class: "rounded-full px-4 py-2 transition hover:bg-white/80 hover:text-base-content" %>
          <span class="hidden text-base-content/20 md:inline">/</span>
          <%= link_to "Fonctionnalités", "#{root_path}#fonctionnalites", class: "rounded-full px-4 py-2 transition hover:bg-white/80 hover:text-base-content" %>
          <%= link_to "Tarifs", "#{root_path}#tarifs", class: "rounded-full px-4 py-2 transition hover:bg-white/80 hover:text-base-content" %>
          <%= link_to "Contact", contact_path, class: "rounded-full px-4 py-2 transition hover:bg-white/80 hover:text-base-content" %>
        </nav>

        <div class="flex items-center gap-3 self-start lg:self-auto">
          <%= link_to "Se connecter", new_user_session_path, class: "inline-flex items-center justify-center rounded-full bg-[#f58d7d] px-6 py-3 text-base font-semibold text-white shadow-[0_10px_24px_rgba(245,141,125,0.35)] transition hover:-translate-y-0.5 hover:bg-[#ed7d6c]" %>
          <div class="flex h-11 items-center gap-2 rounded-full border border-white/60 bg-white/80 px-3 text-sm font-medium text-base-content/70 shadow-sm">
            <span class="text-lg">FR</span>
            <i class="fa-solid fa-angle-down text-xs text-base-content/40"></i>
          </div>
        </div>
      </div>
    </header>

    <div class="grid gap-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
      <section class="rounded-[2rem] border border-white/60 bg-white/72 p-6 shadow-[0_18px_50px_rgba(120,51,75,0.10)] backdrop-blur md:p-8">
        <p class="text-sm uppercase tracking-[0.22em] text-[#b18a96]">Contact</p>
        <h1 class="mt-3 text-4xl font-semibold leading-tight tracking-tight text-[#5a2c39] md:text-5xl">
          Parlons de ton besoin de recrutement
        </h1>
        <p class="mt-4 max-w-xl text-base leading-7 text-[#7d5a66] md:text-lg">
          Que tu veuilles structurer tes missions, collaborer avec des recruteurs ou faire évoluer la plateforme, ce formulaire est le bon point d’entrée.
        </p>

        <div class="mt-8 space-y-4">
          <div class="rounded-[1.5rem] border border-[#f7dde1] bg-[#fff7f6] px-5 py-4">
            <p class="font-semibold text-[#5a2c39]">Réponse rapide</p>
            <p class="mt-1 text-sm leading-6 text-[#7d5a66]">Décris ton contexte, nous revenons vers toi avec le bon interlocuteur.</p>
          </div>
          <div class="rounded-[1.5rem] border border-[#f7dde1] bg-[#fff7f6] px-5 py-4">
            <p class="font-semibold text-[#5a2c39]">Formulaire simple</p>
            <p class="mt-1 text-sm leading-6 text-[#7d5a66]">L’essentiel uniquement pour cadrer ton besoin et engager la suite.</p>
          </div>
          <div class="rounded-[1.5rem] border border-[#f7dde1] bg-[#fff7f6] px-5 py-4">
            <p class="font-semibold text-[#5a2c39]">Même univers visuel</p>
            <p class="mt-1 text-sm leading-6 text-[#7d5a66]">Le formulaire reprend la même direction artistique que ta landing page.</p>
          </div>
        </div>
      </section>

      <section class="rounded-[2rem] border border-white/60 bg-white/76 p-6 shadow-[0_18px_50px_rgba(120,51,75,0.10)] backdrop-blur md:p-8">
        <% if @contact_form.errors.any? %>
          <div class="mb-6 rounded-[1.4rem] border border-rose-200 bg-rose-50/85 px-5 py-4 text-sm text-[#8b4c5d]">
            <p class="font-semibold">Le formulaire contient des erreurs.</p>
            <ul class="mt-2 space-y-1">
              <% @contact_form.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: @contact_form, url: contact_path, method: :post, class: "space-y-5" do |f| %>
          <div class="grid gap-5 md:grid-cols-2">
            <div>
              <%= f.label :full_name, "Nom complet", class: "mb-2 block text-sm font-medium text-[#6f4a57]" %>
              <%= f.text_field :full_name, class: "w-full rounded-[1.2rem] border border-white/70 bg-white/90 px-4 py-3 text-base text-[#5a2c39] outline-none transition placeholder:text-[#c1a6ae] focus:border-[#f2ab98]", placeholder: "Marie Dupont" %>
            </div>
            <div>
              <%= f.label :email, "Email", class: "mb-2 block text-sm font-medium text-[#6f4a57]" %>
              <%= f.email_field :email, class: "w-full rounded-[1.2rem] border border-white/70 bg-white/90 px-4 py-3 text-base text-[#5a2c39] outline-none transition placeholder:text-[#c1a6ae] focus:border-[#f2ab98]", placeholder: "marie@entreprise.com" %>
            </div>
          </div>

          <div class="grid gap-5 md:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)]">
            <div>
              <%= f.label :company, "Entreprise", class: "mb-2 block text-sm font-medium text-[#6f4a57]" %>
              <%= f.text_field :company, class: "w-full rounded-[1.2rem] border border-white/70 bg-white/90 px-4 py-3 text-base text-[#5a2c39] outline-none transition placeholder:text-[#c1a6ae] focus:border-[#f2ab98]", placeholder: "Rivyr" %>
            </div>
            <div>
              <%= f.label :subject, "Sujet", class: "mb-2 block text-sm font-medium text-[#6f4a57]" %>
              <%= f.text_field :subject, class: "w-full rounded-[1.2rem] border border-white/70 bg-white/90 px-4 py-3 text-base text-[#5a2c39] outline-none transition placeholder:text-[#c1a6ae] focus:border-[#f2ab98]", placeholder: "Mise en place de la plateforme" %>
            </div>
          </div>

          <div>
            <%= f.label :message, "Message", class: "mb-2 block text-sm font-medium text-[#6f4a57]" %>
            <%= f.text_area :message, rows: 7, class: "w-full rounded-[1.4rem] border border-white/70 bg-white/90 px-4 py-4 text-base text-[#5a2c39] outline-none transition placeholder:text-[#c1a6ae] focus:border-[#f2ab98]", placeholder: "Décris ton besoin, ton contexte de recrutement ou les fonctionnalités que tu aimerais mettre en place." %>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-sm leading-6 text-[#8a6a75]">
              Le message est validé côté serveur puis enregistré dans les logs pour cette première version.
            </p>
            <%= f.submit "Envoyer la demande", class: "inline-flex items-center justify-center rounded-full bg-[#f59b84] px-6 py-3 text-base font-semibold text-white shadow-[0_14px_30px_rgba(245,155,132,0.38)] transition hover:-translate-y-0.5 hover:bg-[#ef8b73]" %>
          </div>
        <% end %>
      </section>
    </div>
  </div>
</section>
