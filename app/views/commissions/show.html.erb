<div class="max-w-5xl mx-auto p-6 space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Commission #<%= @commission.id %></h1>
    <div class="flex gap-2">
      <%= link_to "Modifier", edit_commission_path(@commission), class: "btn btn-primary" %>
      <%= link_to "Supprimer", commission_path(@commission), data: { turbo_method: :delete, turbo_confirm: "Confirmer la suppression ?" }, class: "btn btn-error" %>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-4">
    <p><strong>Placement:</strong> <%= link_to "##{@commission.placement_id}", placement_path(@commission.placement), class: "link link-primary" %></p>
    <p><strong>Mission:</strong> <%= @commission.placement.mission.reference %></p>
    <p><strong>Regle:</strong> <%= @commission.commission_rule %></p>
    <p><strong>Statut:</strong> <%= @commission.status %></p>
    <p><strong>Brut (cents):</strong> <%= @commission.gross_amount_cents %></p>
    <p><strong>Part Rivyr (cents):</strong> <%= @commission.rivyr_share_cents %></p>
    <p><strong>Part freelancer (cents):</strong> <%= @commission.freelancer_share_cents %></p>
    <p><strong>Paiement client requis:</strong> <%= @commission.client_payment_required ? "Oui" : "Non" %></p>
    <p><strong>Eligible facturation:</strong> <%= @commission.eligible_for_invoicing_at.presence || "-" %></p>
  </div>

  <div class="flex gap-2">
    <%= link_to "Nouveau payment", new_payment_path(commission_id: @commission.id), class: "btn" %>
  </div>

  <%= link_to "Retour a la liste", commissions_path, class: "btn" %>
</div>
