<div class="max-w-6xl mx-auto p-6 space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Commissions</h1>
    <%= link_to "Nouvelle commission", new_commission_path, class: "btn btn-primary" %>
  </div>
  <%= render "shared/index_filters", path: commissions_path, q: @q, status: @status, status_options: Commission.statuses.keys, status_param: :status %>

  <div class="overflow-x-auto bg-base-100 rounded-lg">
    <% if @commissions.any? %>
      <table class="table w-full">
        <thead>
          <tr>
            <th>Placement</th>
            <th>Regle</th>
            <th>Statut</th>
            <th>Brut</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @commissions.each do |commission| %>
            <tr>
              <td>#<%= commission.placement_id %></td>
              <td><%= commission.commission_rule %></td>
              <td><%= commission.status %></td>
              <td><%= commission.gross_amount_cents %></td>
              <td class="text-right">
                <%= link_to "Voir", commission_path(commission), class: "btn btn-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-8 text-center space-y-3">
        <p class="text-lg font-medium">Aucune commission pour le moment</p>
        <%= link_to "Creer la premiere commission", new_commission_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
  <%= render "shared/pagination", page: @page, total_pages: @total_pages, extra_params: { q: @q, status: @status }, path: ->(params) { commissions_path(params) } %>
</div>
