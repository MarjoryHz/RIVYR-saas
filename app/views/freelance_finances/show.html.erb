            <% else %>
              <div class="px-4 py-10 text-center md:px-5">
                <p class="text-sm font-medium text-[#7b4b5a]">Aucun placement visible pour le moment.</p>
              </div>
            <% end %>
          </section>

          <section class="<%= soft_card_class %> mt-4 p-4 md:p-5">
            <div class="flex items-center justify-between gap-3">
              <div>
                <h3 class="text-lg font-semibold text-[#4c1f2a]">Archives</h3>
              </div>
              <span class="inline-flex items-center rounded-full border border-[#f0bfd0] bg-white px-3 py-1 text-xs font-semibold text-[#8b4452]"><%= @active_finance_tab[:archived_rows].to_a.count %></span>
            </div>
            <% if @active_finance_tab[:archived_rows].to_a.any? %>
              <div class="mt-4 overflow-x-auto">
                <table class="min-w-full table-fixed divide-y divide-[#f3e2e8] text-sm">
                  <thead class="bg-[#fff7fa] text-left text-[11px] font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">
                    <tr>
                      <th class="w-[72px] px-4 py-3 md:px-5"></th>
                      <th class="w-[160px] px-4 py-3 md:px-5">Statut</th>
                      <th class="w-[260px] px-4 py-3 md:px-5">Client</th>
                      <th class="w-[260px] px-4 py-3 md:px-5">Mission</th>
                      <th class="w-[220px] px-4 py-3 md:px-5">Candidat</th>
                      <th class="w-[160px] px-4 py-3 md:px-5">Montant</th>
                      <th class="w-[320px] px-4 py-3 md:px-5">Note Rivyr</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-[#f6e8ed] bg-white">
                    <% @active_finance_tab[:archived_rows].to_a.each do |row| %>
                      <% badge_class = tone_classes.fetch(row[:workflow_tone], tone_classes[:slate]) %>
                      <tr class="transition hover:bg-[#fff8fb]">
                        <td class="align-middle px-4 py-4 md:px-5">
                          <div class="flex items-center gap-4">
                            <%= link_to placement_path(row[:placement]), target: "_blank", rel: "noopener", class: "inline-flex h-8 w-8 items-center justify-center rounded-xl border border-[#dfbcc9] bg-[#fff5f8] text-xs text-[#8b4452] transition hover:bg-[#fdeef3]", title: "Ouvrir le placement dans un nouvel onglet" do %>
                              <i class="fa-solid fa-user-check"></i>
                            <% end %>
                          </div>
                        </td>
                        <td class="align-middle px-4 py-4 md:px-5">
                          <span class="inline-flex items-center whitespace-nowrap rounded-full border px-3 py-1 text-xs font-semibold <%= badge_class %>"><%= row[:workflow_label] %></span>
                        </td>
                        <td class="align-middle px-4 py-4 md:px-5 font-semibold text-[#4c1f2a]"><span class="block truncate whitespace-nowrap"><%= row[:client_name] %></span></td>
                        <td class="align-middle px-4 py-4 md:px-5 font-semibold text-[#4c1f2a]"><span class="block truncate whitespace-nowrap"><%= row[:mission_title] %></span></td>
                        <td class="align-middle px-4 py-4 md:px-5 text-[#6f4a58]"><span class="block truncate whitespace-nowrap"><%= row[:candidate_name] %></span></td>
                        <td class="align-middle whitespace-nowrap px-4 py-4 md:px-5 text-[#4c1f2a]"><%= number_to_currency(row[:amount_cents].to_i / 100.0, unit: "€", precision: 0) %></td>
                        <td class="align-middle px-4 py-4 md:px-5 text-[#6f4a58]"><span class="block truncate whitespace-nowrap"><%= row[:note] %></span></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <div class="mt-4 rounded-[1.2rem] border border-[#edd8df] bg-white px-4 py-8 text-center text-sm text-[#7b4b5a]">
                Aucune archive placement pour le moment.
              </div>
            <% end %>
          </section>
          <% else %>
          <% rows = @active_finance_tab[:rows].to_a %>
          <section class="<%= soft_card_class %> relative">
            <div class="border-b border-[#f0dce3] px-4 py-4 md:px-5">
              <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                  <h2 class="text-2xl font-semibold text-[#4c1f2a]">Historique des paiements</h2>
                </div>
                <%= form_with url: dashboard_freelance_finance_path, method: :get, local: true, class: "flex items-center gap-2" do %>
                  <%= hidden_field_tag :tab, @tab %>
                  <%= hidden_field_tag :wallet_tab, @wallet_tab %>
                  <%= hidden_field_tag :payment_changes_only, (@payment_changes_only ? "1" : nil) %>
                  <label for="payment_status" class="text-xs font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">Status</label>
                  <%= select_tag :payment_status, options_for_select([["Tous", ""]] + @active_finance_tab[:status_options].to_a, @payment_status), id: "payment_status", class: "select select-bordered rounded-full border-[#f0cfd9] bg-white text-sm text-[#5f3647]", onchange: "this.form.submit()" %>
                <% end %>
              </div>
              <% if @payment_changes_only %>
                <div class="mt-3 flex items-center justify-between gap-3 rounded-2xl border border-[#f1cfda] bg-[#fff4f8] px-3 py-2 text-sm text-[#8b4452]">
                  <span><%= rows.count %> ligne<%= "s" if rows.count != 1 %> avec changement récent affichée<%= "s" if rows.count != 1 %>.</span>
                  <%= link_to "Voir toutes les lignes", dashboard_freelance_finance_path(tab: @tab, wallet_tab: @wallet_tab, payment_status: @payment_status.presence), class: "inline-flex items-center rounded-full border border-[#dfbcc9] bg-white px-3 py-1.5 text-xs font-semibold text-[#8b4452] transition hover:bg-[#fdeef3]" %>
                </div>
              <% end %>
            </div>
            <% if rows.any? %>
              <div class="overflow-x-auto">
                <table class="min-w-full table-fixed divide-y divide-[#f3e2e8] text-sm">
                  <thead class="bg-[#fff7fa] text-left text-[11px] font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">
                    <tr>
                      <th class="w-[72px] px-4 py-3 md:px-5"></th>
                      <th class="w-[180px] px-4 py-3 md:px-5">Status</th>
                      <th class="w-[280px] px-4 py-3 md:px-5">Client</th>
                      <th class="w-[280px] px-4 py-3 md:px-5">Mission</th>
                      <th class="w-[180px] px-4 py-3 md:px-5">Référence</th>
                      <th class="w-[160px] px-4 py-3 md:px-5">Montant</th>
                      <th class="w-[160px] px-4 py-3 md:px-5">Date</th>
                      <th class="w-[320px] px-4 py-3 md:px-5">Note</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-[#f6e8ed] bg-white">
                    <% rows.each do |row| %>
                      <% badge_class = tone_classes.fetch(row[:status_tone], tone_classes[:slate]) %>
                      <tr class="transition hover:bg-[#fff8fb]">
                        <td class="align-middle px-4 py-4 md:px-5">
                          <div class="flex items-center gap-4" data-controller="signature-change-indicator" data-signature-change-indicator-row-id-value="<%= row[:id] %>" data-signature-change-indicator-changed-recently-value="<%= row[:changed_recently] %>">
                            <span class="relative inline-flex" <% if row[:changed_recently] %>data-action="mouseenter->signature-change-indicator#reveal mouseleave->signature-change-indicator#hide"<% end %>>
                              <span data-signature-change-indicator-target="indicator" class="inline-flex h-3 w-3 shrink-0 rounded-full border border-[#dec4cd] bg-white"></span>
                              <% if row[:changed_recently] %>
                                <span data-signature-change-indicator-target="tooltip" class="pointer-events-none absolute left-0 top-full z-30 hidden min-w-[240px] max-w-[320px] rounded-xl border border-[#f4d5bf] bg-white px-3 py-2 text-sm text-[#5f3647] shadow-[0_20px_45px_rgba(116,43,70,0.16)] mt-2">
                                  <%= row[:change_hint] %>
                                </span>
                              <% end %>
                            </span>
                            <%= link_to placement_path(row[:placement]), class: "inline-flex h-8 w-8 items-center justify-center rounded-xl border border-[#dfbcc9] bg-[#fff5f8] text-xs text-[#8b4452] transition hover:bg-[#fdeef3]", title: "Ouvrir le placement", data: { action: "click->signature-change-indicator#markSeen" } do %>
                              <i class="fa-solid fa-wallet"></i>
                            <% end %>
                          </div>
                        </td>
                        <td class="align-middle px-4 py-4 md:px-5">
                          <span class="inline-flex items-center whitespace-nowrap rounded-full border px-3 py-1 text-xs font-semibold <%= badge_class %>"><%= row[:status_short_label] %></span>
                        </td>
                        <td class="align-middle px-4 py-4 md:px-5">
                          <div class="flex items-center gap-3 whitespace-nowrap">
                            <% if row[:client_logo].present? %>
                              <span class="h-11 w-11 shrink-0 overflow-hidden rounded-2xl border border-[#f0dce3] bg-white">
                                <%= image_tag client_logo_src(row[:client_logo]), alt: row[:client_name], class: "h-full w-full object-cover" %>
                              </span>
                            <% else %>
                              <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl border border-[#f0dce3] bg-[#fff1f6] text-sm font-semibold text-[#a33d68]"><%= row[:client_name].to_s.first(1) %></span>
                            <% end %>
                            <span class="block truncate font-semibold text-[#4c1f2a]"><%= row[:client_name] %></span>
                          </div>
                        </td>
                        <td class="align-middle px-4 py-4 md:px-5 font-semibold text-[#4c1f2a]"><span class="block truncate whitespace-nowrap"><%= row[:mission_title] %></span></td>
                        <td class="align-middle whitespace-nowrap px-4 py-4 md:px-5 text-[#6f4a58]"><%= row[:invoice_number] %></td>
                        <td class="align-middle whitespace-nowrap px-4 py-4 md:px-5 text-[#4c1f2a]"><%= number_to_currency(row[:amount_cents].to_i / 100.0, unit: "€", precision: 0) %></td>
                        <td class="align-middle whitespace-nowrap px-4 py-4 md:px-5 text-[#6f4a58]"><%= l(row[:occurred_at].to_date, format: :default) rescue row[:occurred_at].strftime("%d/%m/%Y") %></td>
                        <td class="align-middle px-4 py-4 md:px-5 text-[#6f4a58]"><span class="block truncate whitespace-nowrap"><%= row[:note] %></span></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <div class="px-4 py-10 text-center md:px-5">
                <p class="text-sm font-medium text-[#7b4b5a]">Aucun paiement visible pour le moment.</p>
              </div>
            <% end %>
          </section>
        <% end %>
      </div>
    </section>
  </section>
</div>

<% if @wallet_payout_invoice.present? %>
  <% wallet_default_amount_cents = 200_000 %>
  <dialog id="wallet-payout-modal" class="modal">
    <div class="modal-box max-w-lg rounded-[1.75rem] border border-[#f2d5df] bg-base-100 shadow-2xl">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h3 class="text-2xl font-semibold text-base-content">Declencher un paiement</h3>
          <p class="mt-1 text-sm text-base-content/65">Choisis le montant et le compte bancaire de reception.</p>
        </div>
        <form method="dialog">
          <button class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-base-200 bg-base-100/80 text-base-content/60 transition hover:bg-base-100 hover:text-base-content">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </form>
      </div>

      <%= form_with url: create_payout_request_freelance_finance_path, method: :post, local: true, class: "mt-6 space-y-4" do %>
        <%= hidden_field_tag :invoice_id, @wallet_payout_invoice.id %>
        <%= hidden_field_tag :billing_number, @wallet_payout_invoice.number %>
        <div>
          <label for="wallet_amount_eur" class="mb-1 block text-sm font-medium text-base-content/70">Montant souhaite (€)</label>
          <%= number_field_tag :amount_eur, (wallet_default_amount_cents / 100.0), min: 1, step: 1, class: "input input-bordered w-full", id: "wallet_amount_eur" %>
          <p class="mt-1 text-xs text-[#8b4452]">Disponible mobilisable sur cette demande: <%= number_to_currency(@wallet_requestable_amount_cents / 100.0, unit: "€", precision: 0) %></p>
        </div>
        <div>
          <label for="wallet_bank_account_label" class="mb-1 block text-sm font-medium text-base-content/70">Compte bancaire</label>
          <% if @wallet_bank_account_options.any? %>
            <%= select_tag :bank_account_label, options_for_select(@wallet_bank_account_options), id: "wallet_bank_account_label", class: "select select-bordered w-full" %>
          <% else %>
            <div class="rounded-2xl border border-[#f1cfda] bg-[#fff4f8] px-4 py-3 text-sm text-[#8b4452]">
              Aucun compte bancaire renseigne. Ajoute-en un dans ton profil avant de demander un paiement.
            </div>
          <% end %>
        </div>
        <div class="flex justify-end gap-2">
          <button type="button" class="btn btn-ghost" onclick="document.getElementById('wallet-payout-modal').close()">Annuler</button>
          <%= submit_tag "Envoyer la demande", disabled: @wallet_bank_account_options.empty?, class: "btn border-[#ed0e64] bg-[#ed0e64] text-white hover:border-[#cf0c57] hover:bg-[#cf0c57] disabled:border-[#e5dbe0] disabled:bg-[#f3edf0] disabled:text-[#9f8a92]" %>
        </div>
      <% end %>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>
<% end %>

<% if flash[:payout_request_success].present? %>
  <% payout_success = flash[:payout_request_success].to_h.symbolize_keys %>
  <dialog id="wallet-payout-success-modal" class="modal" open>
    <div class="modal-box max-w-md rounded-[1.75rem] border border-[#f2d5df] bg-base-100 text-center shadow-2xl">
      <form method="dialog" class="flex justify-end">
        <button class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-base-200 bg-base-100/80 text-base-content/60 transition hover:bg-base-100 hover:text-base-content">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </form>

      <div class="mx-auto mt-2 inline-flex h-16 w-16 items-center justify-center rounded-full bg-[#fff1f6] text-[#ed0e64] shadow-[0_12px_24px_rgba(237,14,100,0.16)]">
        <i class="fa-solid fa-check text-2xl"></i>
      </div>

      <h3 class="mt-4 text-2xl font-semibold text-[#4c1f2a]">Demande prise en compte</h3>
      <p class="mt-2 text-sm text-[#7b4b5a]">
        <%= number_to_currency(payout_success[:amount_cents].to_i / 100.0, unit: "€", precision: 0) %> vont etre traites sur <%= payout_success[:bank_account_label] %>.
      </p>
      <p class="mt-2 text-sm text-[#7b4b5a]">
        Le montant a deja ete deduit du portefeuille disponible.
      </p>

      <form method="dialog" class="mt-6">
        <button class="btn border-[#ed0e64] bg-[#ed0e64] text-white hover:border-[#cf0c57] hover:bg-[#cf0c57]">Fermer</button>
      </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>
<% end %>

<% if flash[:payout_request_insufficient].present? %>
  <% payout_insufficient = flash[:payout_request_insufficient].to_h.symbolize_keys %>
  <dialog id="wallet-payout-insufficient-modal" class="modal" open>
    <div class="modal-box max-w-md rounded-[1.75rem] border border-[#f2d5df] bg-base-100 text-center shadow-2xl">
      <form method="dialog" class="flex justify-end">
        <button class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-base-200 bg-base-100/80 text-base-content/60 transition hover:bg-base-100 hover:text-base-content">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </form>

      <div class="mx-auto mt-2 inline-flex h-16 w-16 items-center justify-center rounded-full bg-[#fff1f6] text-[#ed0e64] shadow-[0_12px_24px_rgba(237,14,100,0.16)]">
        <i class="fa-solid fa-triangle-exclamation text-2xl"></i>
      </div>

      <h3 class="mt-4 text-2xl font-semibold text-[#4c1f2a]">Fonds insuffisants</h3>
      <p class="mt-2 text-sm text-[#7b4b5a]">
        Montant demandé: <%= number_to_currency(payout_insufficient[:requested_amount_cents].to_i / 100.0, unit: "€", precision: 0) %>
      </p>
      <p class="mt-2 text-sm text-[#7b4b5a]">
        Montant disponible: <%= number_to_currency(payout_insufficient[:available_amount_cents].to_i / 100.0, unit: "€", precision: 0) %>
      </p>

      <form method="dialog" class="mt-6">
        <button class="btn border-[#ed0e64] bg-[#ed0e64] text-white hover:border-[#cf0c57] hover:bg-[#cf0c57]">Fermer</button>
      </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>
<% end %>
