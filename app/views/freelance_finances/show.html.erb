<%
  surface_card_class = "rounded-[1.6rem] border border-[#f0d8e0] bg-white/92 shadow-[0_22px_50px_rgba(130,39,77,0.08)] backdrop-blur"
  soft_card_class = "rounded-[1.35rem] border border-[#f3dfe5] bg-[#fff9fb]"
  trend_tone_classes = {
    up: "text-[#14b84a]",
    down: "text-[#f04a3a]",
    flat: "text-[#8b4452]"
  }
  metric_tone_classes = {
    green: "text-[#2f6b3c]",
    amber: "text-[#c96b28]",
    rose: "text-[#a33d68]",
    slate: "text-[#7a5a67]"
  }
  wallet_tabs = [
    { key: "available", label: "Principal", amount_cents: @available_wallet_cents, description: "Montant disponible dans ton wallet." },
    { key: "waiting", label: "En attente", amount_cents: @waiting_client_payments_cents, description: "Montants encore en attente côté règlement client." },
    { key: "potential", label: "Potentiel", amount_cents: @potential_wallet_cents, description: "Commissions estimées sur les missions ouvertes et en cours." }
  ]
  active_wallet_tab = wallet_tabs.find { |tab| tab[:key] == @wallet_tab } || wallet_tabs.first

  tone_classes = {
    green: "border-[#d7e9dc] bg-[#edf8f0] text-[#2f6b3c]",
    rose: "border-[#f1cfda] bg-[#fff1f6] text-[#a33d68]",
    amber: "border-[#f2dec2] bg-[#fff4e6] text-[#a46a22]",
    slate: "border-[#e5dbe0] bg-[#faf5f7] text-[#7a5a67]"
  }
%>

<div class="mx-auto max-w-7xl p-4 md:p-6">
  <section class="space-y-6">
    <header class="space-y-4">
      <div class="grid gap-4 xl:grid-cols-[minmax(0,2fr)_minmax(320px,1fr)]">
        <article class="<%= surface_card_class %> overflow-hidden p-6 md:p-7">
          <div class="relative">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[#a15c70]">Finance Rivyr</p>
            <h1 class="mt-2 text-3xl font-semibold tracking-tight text-[#4c1f2a] md:text-4xl">Signatures, placements et paiements</h1>
            <% finance_info_items = [
              { value: @finance_overview[:sent_this_month_count], label: "contrats envoyés ce mois", icon: "fa-file-signature" },
              { value: @finance_overview[:signed_this_month_count], label: "contrats signés", icon: "fa-badge-check" },
              { value: @finance_overview[:urgent_actions_count], label: "actions urgentes", icon: "fa-bell" }
            ] %>
            <div class="mt-5 flex flex-wrap gap-x-6 gap-y-3">
              <% finance_info_items.each do |item| %>
                <div class="flex items-center gap-2 text-sm text-[#7b4b5a]">
                  <span class="text-lg font-semibold text-[#ed0e64]"><%= item[:value] %></span>
                  <span class="inline-flex h-7 w-7 items-center justify-center text-[#ed0e64]">
                    <i class="fa-solid <%= item[:icon] %>"></i>
                  </span>
                  <span><%= item[:label] %></span>
                </div>
              <% end %>
            </div>
          </div>
        </article>

        <article class="<%= surface_card_class %> border-[#f1d7df] bg-[linear-gradient(135deg,rgba(255,247,250,0.96),rgba(255,240,244,0.98))] p-4 md:p-5">
          <div class="flex min-h-[128px] flex-col justify-between">
            <div class="flex justify-end">
              <div class="text-right">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Portefeuille</p>
                <p class="mt-1 text-3xl font-semibold tracking-tight text-[#4c1f2a] md:text-4xl xl:text-5xl"><%= number_to_currency(active_wallet_tab[:amount_cents] / 100.0, unit: "€", precision: 0) %></p>
              </div>
            </div>

            <div class="mt-1 flex items-center justify-end gap-5 text-right">
              <% wallet_tabs.reject { |tab| tab[:key] == @wallet_tab }.each do |tab| %>
                <div class="text-right">
                  <p class="text-xs font-medium text-[#9a5a68]"><%= tab[:label] %></p>
                  <p class="mt-0.5 text-base font-medium leading-none text-[#4c1f2a]"><%= number_to_currency(tab[:amount_cents] / 100.0, unit: "€", precision: 0) %></p>
                </div>
              <% end %>
            </div>

            <div class="mt-4 flex items-center justify-end gap-2">
              <%= link_to dashboard_freelance_finance_path(tab: "payments", wallet_tab: @wallet_tab), class: "inline-flex h-9 w-9 items-center justify-center rounded-full border border-[#dfbcc9] bg-white text-[#8b4452] transition hover:bg-[#fdeef3]", title: "Voir l'historique des paiements" do %>
                <i class="fa-solid fa-clock-rotate-left"></i>
              <% end %>
              <% if @wallet_payout_invoice.present? %>
                <button type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-[#ed0e64] bg-[#ed0e64] text-white transition hover:bg-[#cf0c57]" title="Declencher un paiement" onclick="document.getElementById('wallet-payout-modal').showModal()">
                  <i class="fa-solid fa-money-bill-transfer"></i>
                </button>
              <% end %>
            </div>
          </div>
        </article>
      </div>

      <section class="<%= surface_card_class %> p-4">
        <% overview = @finance_overview %>
        <div class="grid gap-3 xl:grid-cols-5">
          <article class="rounded-[1.35rem] border border-[#f1d7df] bg-[linear-gradient(135deg,rgba(255,247,250,0.98),rgba(255,240,244,0.98))] p-3 xl:col-span-3">
            <div class="flex flex-col gap-2 xl:flex-row xl:items-center xl:justify-between">
              <div class="max-w-2xl">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">CA du mois vs objectif</p>
                  <span class="inline-flex items-center rounded-full border border-[#f0dce3] bg-white px-2.5 py-1 text-xs font-semibold text-[#7b4b5a]"><%= overview[:freelance_legal_status_label] == "Non renseigne" ? "15 000 €" : overview[:freelance_legal_status_label] %></span>
                </div>
                <div class="mt-1 flex flex-wrap items-end gap-3">
                  <p class="text-2xl font-semibold tracking-tight text-[#4c1f2a]">10 000 €</p>
                  <p class="pb-0.5 text-sm text-[#7b4b5a]"><%= overview[:monthly_target_eur].positive? ? "sur #{number_with_delimiter(overview[:monthly_target_eur], delimiter: ' ')} € en #{overview[:current_month_label]}" : overview[:current_month_label] %></p>
                </div>
                <div class="mt-2 h-2 overflow-hidden rounded-full bg-[#f6dde6]">
                  <div class="h-full rounded-full bg-[linear-gradient(90deg,#ed0e64,#f4a58a)]" style="width: 80%"></div>
                </div>
              </div>
              <div class="xl:w-1/3 xl:min-w-[220px]">
                <div class="rounded-[1.1rem] border border-[#f1d7df] bg-white/85 px-4 py-3">
                  <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">CA annuel réalisé</p>
                    <p class="mt-1 text-2xl font-semibold tracking-tight text-[#4c1f2a]">78 000€</p>
                  </div>
                  <div class="mt-3 border-t border-[#f3dfe5] pt-3">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">CA prévisionnel</p>
                    <p class="mt-1 text-2xl font-semibold tracking-tight text-[#4c1f2a]">24 000€</p>
                  </div>
                </div>
              </div>
            </div>
          </article>

          <article class="rounded-[1.35rem] border border-[#f1d7df] bg-[#fff9fb] p-3">
            <div class="grid h-full gap-2">
              <div class="px-1 py-1">
                <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">Ce mois-ci</p>
                <p class="mt-1 text-xl font-semibold text-[#4c1f2a]"><%= overview[:sent_this_month_count] %> / <%= overview[:signed_this_month_count] %></p>
                <p class="mt-0.5 text-sm text-[#7b4b5a]">contrats envoyés / signés</p>
              </div>
              <div class="border-t border-[#f3dfe5] px-1 pt-2">
                <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">Promesses de paiement</p>
                <p class="mt-1 text-xl font-semibold text-[#4c1f2a]"><%= number_to_currency(overview[:promised_payments_cents] / 100.0, unit: "€", precision: 0) %></p>
                <p class="mt-0.5 text-sm text-[#7b4b5a]">potentiel signé sur le mois</p>
              </div>
            </div>
          </article>

          <article class="rounded-[1.35rem] border border-[#f1d7df] bg-[#fff9fb] p-3">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Actions urgentes</p>
                <p class="mt-1 text-xl font-semibold text-[#4c1f2a]"><%= overview[:urgent_actions_count] %></p>
              </div>
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-2xl border border-[#f3b6ca] bg-[#fff1f6] text-[#ed0e64]">
                <i class="fa-solid fa-bell"></i>
              </span>
            </div>
            <div class="mt-2 space-y-1.5">
              <% if overview[:urgent_actions].any? %>
                <% overview[:urgent_actions].each do |action| %>
                  <div class="border-t border-[#f3dfe5] px-1 pt-2 text-xs text-[#7b4b5a]"><%= action[:text] %></div>
                <% end %>
              <% else %>
                <div class="border-t border-[#d7e9dc] px-1 pt-2 text-xs font-medium text-[#2f6b3c]">Aucune action bloquante.</div>
              <% end %>
            </div>
          </article>
        </div>
      </section>

      <section class="<%= surface_card_class %> p-4">
        <div class="grid gap-3 lg:grid-cols-3">
          <% @finance_tabs.each do |tab| %>
            <%= link_to dashboard_freelance_finance_path(tab: tab[:key], wallet_tab: @wallet_tab), class: "flex items-center justify-between gap-4 rounded-[1.35rem] border px-4 py-4 transition #{tab[:key] == @tab ? 'border-[#ed0e64] bg-[#fff1f6] shadow-sm' : 'border-[#f1d7df] bg-[#fff9fb] hover:border-[#e6aabb] hover:bg-white'}" do %>
              <span class="flex min-w-0 items-center gap-3">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-white/80 bg-white text-[#ed0e64] shadow-sm">
                  <i class="fa-solid <%= tab[:icon] %>"></i>
                </span>
                <span class="min-w-0">
                  <span class="block truncate text-sm font-semibold text-[#4c1f2a]"><%= tab[:label] %></span>
                  <span class="block text-xs text-[#8b4452]"><%= tab[:task_count] %> à traiter</span>
                </span>
              </span>
              <% if tab[:task_count].positive? %>
                <span class="inline-flex items-center rounded-full border border-[#f0bfd0] bg-[#fff1f6] px-2.5 py-1 text-xs font-semibold text-[#a33d68]"><%= tab[:task_count] %> action<%= "s" if tab[:task_count] != 1 %></span>
              <% else %>
                <span class="inline-flex items-center rounded-full border border-[#d7e9dc] bg-[#edf8f0] px-2.5 py-1 text-xs font-semibold text-[#2f6b3c]">À jour</span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </section>
    </header>

    <section class="<%= surface_card_class %> p-5 md:p-6">
      <% if @active_finance_tab[:key] == "signatures" %>
        <div>
          <% signature_metrics = @active_finance_tab[:metrics] || {} %>
          <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <div class="<%= soft_card_class %> px-4 py-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Taux de conversion</p>
              <% conversion_trend = signature_metrics[:conversion_trend] || {} %>
              <div class="mt-2 flex items-center gap-2">
                <p class="text-3xl font-semibold <%= metric_tone_classes.fetch(signature_metrics[:conversion_tone], metric_tone_classes[:slate]) %>"><%= signature_metrics[:conversion_rate] %>%</p>
                <span class="inline-flex items-center <%= trend_tone_classes.fetch(conversion_trend[:direction], trend_tone_classes[:flat]) %>">
                  <% if conversion_trend[:direction] == :up %>
                    <i class="fa-solid fa-arrow-trend-up text-lg"></i>
                  <% elsif conversion_trend[:direction] == :down %>
                    <i class="fa-solid fa-arrow-trend-down text-lg"></i>
                  <% else %>
                    <i class="fa-solid fa-minus text-sm"></i>
                  <% end %>
                </span>
              </div>
              <p class="mt-1 text-sm text-[#7b4b5a]">Annuel</p>
            </div>
            <div class="<%= soft_card_class %> px-4 py-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Contrats envoyés</p>
              <% sent_trend = signature_metrics[:yearly_sent_trend] || {} %>
              <% monthly_series = signature_metrics[:monthly_sent_series].to_a %>
              <% max_month_count = [monthly_series.map { |point| point[:count] }.max.to_i, 1].max %>
              <div class="mt-3 grid grid-cols-[minmax(72px,1fr)_minmax(0,2fr)] items-end gap-3">
                <div>
                  <div class="flex items-center gap-2">
                    <p class="text-3xl font-semibold <%= metric_tone_classes.fetch(signature_metrics[:yearly_sent_tone], metric_tone_classes[:slate]) %>"><%= signature_metrics[:yearly_sent_count] %></p>
                    <span class="inline-flex items-center <%= trend_tone_classes.fetch(sent_trend[:direction], trend_tone_classes[:flat]) %>">
                      <% if sent_trend[:direction] == :up %>
                        <i class="fa-solid fa-arrow-trend-up text-lg"></i>
                      <% elsif sent_trend[:direction] == :down %>
                        <i class="fa-solid fa-arrow-trend-down text-lg"></i>
                      <% else %>
                        <i class="fa-solid fa-minus text-sm"></i>
                      <% end %>
                    </span>
                  </div>
                  <p class="mt-1 text-sm text-[#7b4b5a]">Annuel</p>
                </div>
                <div class="pt-1">
                  <div class="flex items-end gap-1.5">
                    <% monthly_series.each do |point| %>
                      <% bar_height = [((point[:count].to_f / max_month_count) * 38).round, 8].max %>
                      <div class="flex min-w-0 flex-1 flex-col items-center gap-1.5">
                        <span class="w-full rounded-t-md bg-[#eadffc]" style="height: <%= "#{bar_height}px" %>"></span>
                        <span class="text-[10px] font-semibold uppercase tracking-[0.08em] text-[#9a8ca4]"><%= point[:label] %></span>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
            <div class="<%= soft_card_class %> px-4 py-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Délai moyen</p>
              <% delay_trend = signature_metrics[:average_signature_delay_trend] || {} %>
              <div class="mt-2 flex items-center gap-2">
                <p class="text-3xl font-semibold <%= metric_tone_classes.fetch(signature_metrics[:average_signature_delay_tone], metric_tone_classes[:slate]) %>"><%= signature_metrics[:average_signature_delay] %></p>
                <span class="inline-flex items-center <%= trend_tone_classes.fetch(delay_trend[:direction], trend_tone_classes[:flat]) %>">
                  <% if delay_trend[:direction] == :up %>
                    <i class="fa-solid fa-arrow-trend-up text-lg"></i>
                  <% elsif delay_trend[:direction] == :down %>
                    <i class="fa-solid fa-arrow-trend-down text-lg"></i>
                  <% else %>
                    <i class="fa-solid fa-minus text-sm"></i>
                  <% end %>
                </span>
              </div>
              <p class="mt-1 text-sm text-[#7b4b5a]">Jusqu'à signature</p>
            </div>
            <% if @active_finance_tab[:task_count].positive? %>
              <%= link_to dashboard_freelance_finance_path(tab: @tab, wallet_tab: @wallet_tab, signature_status: @signature_status.presence, signature_changes_only: "1"), class: "group block rounded-[1.35rem] border border-[#f3b6ca] bg-[linear-gradient(135deg,rgba(255,241,246,1),rgba(255,250,252,1))] px-4 py-4 shadow-[0_18px_32px_rgba(163,61,104,0.08)] transition hover:-translate-y-0.5 hover:border-[#ed0e64] hover:shadow-[0_22px_36px_rgba(163,61,104,0.16)]" do %>
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#a15c70]">À traiter</p>
                    <p class="mt-2 text-3xl font-semibold <%= metric_tone_classes.fetch(signature_metrics[:task_tone], metric_tone_classes[:slate]) %>"><%= @active_finance_tab[:task_count] %></p>
                  </div>
                  <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-white/80 bg-white text-[#ed0e64] shadow-sm transition group-hover:bg-[#ed0e64] group-hover:text-white">
                    <i class="fa-solid fa-arrow-right"></i>
                  </span>
                </div>
                <p class="mt-4 text-sm font-medium text-[#8b4452]">Filtrer les lignes actives</p>
              <% end %>
            <% else %>
              <div class="<%= soft_card_class %> px-4 py-4">
                <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">À traiter</p>
                <p class="mt-2 text-3xl font-semibold text-[#4c1f2a]"><%= @active_finance_tab[:task_count] %></p>
                <p class="mt-1 text-sm text-[#7b4b5a]">Tâches immédiatement activables.</p>
              </div>
            <% end %>
          </div>
        </div>
      <% elsif @active_finance_tab[:key] == "placements" %>
        <% placement_metrics = @active_finance_tab[:metrics] || {} %>
        <% validated_count = placement_metrics[:validated_count].to_i %>
        <% validated_count_class =
          if validated_count.zero?
            "text-[#2f6b3c]"
          elsif validated_count <= 3
            "text-[#c96b28]"
          else
            "text-[#b42318]"
          end %>
        <div>
          <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <div class="<%= soft_card_class %> px-4 py-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Placements à valider</p>
              <p class="mt-2 text-3xl font-semibold <%= validated_count_class %>"><%= validated_count %></p>
              <p class="mt-1 text-sm text-[#7b4b5a]">Validé par Rivyr.</p>
            </div>
            <div class="<%= soft_card_class %> px-4 py-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Placements à traiter</p>
              <p class="mt-2 text-3xl font-semibold text-[#c96b28]"><%= placement_metrics[:in_progress_count] %></p>
              <p class="mt-1 text-sm text-[#7b4b5a]">Placements encore en validation.</p>
            </div>
            <div class="<%= soft_card_class %> px-4 py-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Montant placement en attente</p>
              <p class="mt-2 text-3xl font-semibold text-[#4c1f2a]"><%= number_to_currency(placement_metrics[:total_amount_cents].to_i / 100.0, unit: "€", precision: 0) %></p>
            </div>
            <% if @active_finance_tab[:task_count].positive? %>
              <%= link_to dashboard_freelance_finance_path(tab: @tab, wallet_tab: @wallet_tab, placements_changes_only: "1"), class: "group block rounded-[1.35rem] border border-[#f3b6ca] bg-[linear-gradient(135deg,rgba(255,241,246,1),rgba(255,250,252,1))] px-4 py-4 shadow-[0_18px_32px_rgba(163,61,104,0.08)] transition hover:-translate-y-0.5 hover:border-[#ed0e64] hover:shadow-[0_22px_36px_rgba(163,61,104,0.16)]" do %>
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#a15c70]">À traiter</p>
                    <p class="mt-2 text-3xl font-semibold text-[#4c1f2a]"><%= @active_finance_tab[:task_count] %></p>
                  </div>
                  <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-white/80 bg-white text-[#ed0e64] shadow-sm transition group-hover:bg-[#ed0e64] group-hover:text-white">
                    <i class="fa-solid fa-arrow-right"></i>
                  </span>
                </div>
                <p class="mt-4 text-sm font-medium text-[#8b4452]">Filtrer les lignes actives</p>
              <% end %>
            <% else %>
              <div class="<%= soft_card_class %> px-4 py-4">
                <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">À traiter</p>
                <p class="mt-2 text-3xl font-semibold text-[#4c1f2a]"><%= @active_finance_tab[:task_count] %></p>
                <p class="mt-1 text-sm text-[#7b4b5a]">Tâches immédiatement activables.</p>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <% payment_metrics = @active_finance_tab[:metrics] || {} %>
        <div>
          <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <div class="<%= soft_card_class %> px-4 py-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">En attente de paiement</p>
              <p class="mt-2 text-3xl font-semibold text-[#c96b28]"><%= payment_metrics[:pending_count].to_i %></p>
              <p class="mt-1 text-sm text-[#7b4b5a]">Virements Rivyr en préparation.</p>
            </div>
            <div class="<%= soft_card_class %> px-4 py-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Paiements effectués</p>
              <p class="mt-2 text-3xl font-semibold text-[#2f6b3c]"><%= payment_metrics[:paid_count].to_i %></p>
              <p class="mt-1 text-sm text-[#7b4b5a]">Virements déjà reçus par le freelance.</p>
            </div>
            <div class="<%= soft_card_class %> px-4 py-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Montant total versé</p>
              <p class="mt-2 text-3xl font-semibold text-[#4c1f2a]"><%= number_to_currency(payment_metrics[:paid_total_cents].to_i / 100.0, unit: "€", precision: 0) %></p>
              <p class="mt-1 text-sm text-[#7b4b5a]">Historique des paiements Rivyr.</p>
            </div>
            <% if @active_finance_tab[:task_count].positive? %>
