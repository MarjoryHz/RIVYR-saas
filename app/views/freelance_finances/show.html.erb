<% surface_card_class = "rounded-[1.45rem] border border-base-100/70 bg-base-100/88 shadow-lg" %>

<div class="mx-auto max-w-7xl p-4 md:p-6">
  <section class="space-y-6">
    <header class="space-y-5">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[#a15c70]">Finance Rivyr</p>
        <h1 class="text-3xl font-semibold tracking-tight text-base-content md:text-4xl">Finance</h1>
        <p class="text-base text-base-content/60">Signature, placement et paiement dans un seul cockpit.</p>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        <article class="<%= surface_card_class %> p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Signatures</p>
          <p class="mt-3 text-3xl font-semibold text-base-content"><%= @placements.count { |placement| placement.mission.contract_signed? } %></p>
          <p class="mt-2 text-sm text-base-content/60">Missions avec contrat signé</p>
        </article>
        <article class="<%= surface_card_class %> p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Placements</p>
          <p class="mt-3 text-3xl font-semibold text-base-content"><%= @placements.count(&:workflow_validated?) %></p>
          <p class="mt-2 text-sm text-base-content/60">Placements validés par Rivyr</p>
        </article>
        <article class="<%= surface_card_class %> p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Paiements</p>
          <p class="mt-3 text-3xl font-semibold text-base-content"><%= number_to_currency(@available_wallet_cents / 100.0, unit: "€", precision: 0) %></p>
          <p class="mt-2 text-sm text-base-content/60">Disponible au wallet freelance</p>
        </article>
      </div>
    </header>

    <div class="grid gap-4 xl:grid-cols-[minmax(0,1.5fr)_minmax(0,1fr)]">
      <div class="space-y-4">
        <section class="<%= surface_card_class %> p-5">
          <div class="flex items-center justify-between gap-3">
            <div>
              <h2 class="text-xl font-semibold text-base-content">Vue d’ensemble</h2>
              <p class="mt-1 text-sm text-base-content/60">Accède à chaque étape du cycle finance.</p>
            </div>
          </div>

          <div class="mt-4 grid gap-3 md:grid-cols-3">
            <%= link_to dashboard_my_missions_path, class: "rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4 transition hover:bg-white" do %>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Signatures</p>
              <p class="mt-2 text-lg font-semibold text-[#4c1f2a]"><%= @placements.count { |placement| placement.mission.contract_signed? } %> suivis</p>
              <p class="mt-2 text-sm text-[#7b4b5a]">Contrats client et documents signés.</p>
            <% end %>

            <%= link_to placements_path, class: "rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4 transition hover:bg-white" do %>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Placements</p>
              <p class="mt-2 text-lg font-semibold text-[#4c1f2a]"><%= @placements.count %> dossiers</p>
              <p class="mt-2 text-sm text-[#7b4b5a]">Validation conformité, package et candidats.</p>
            <% end %>

            <%= link_to dashboard_invoices_path, class: "rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4 transition hover:bg-white" do %>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Paiements</p>
              <p class="mt-2 text-lg font-semibold text-[#4c1f2a]"><%= number_to_currency(@waiting_client_payments_cents / 100.0, unit: "€", precision: 0) %></p>
              <p class="mt-2 text-sm text-[#7b4b5a]">Encaissements clients et demandes de virement.</p>
            <% end %>
          </div>
        </section>

        <section class="<%= surface_card_class %> p-5">
          <div class="flex items-center justify-between gap-3">
            <div>
              <h2 class="text-xl font-semibold text-base-content">Placements actifs</h2>
              <p class="mt-1 text-sm text-base-content/60">Les placements qui nécessitent encore une action.</p>
            </div>
            <%= link_to "Voir tous les placements", placements_path, class: "text-sm font-semibold text-[#8b4452] underline hover:text-[#6f2d3a]" %>
          </div>

          <% if @placements.any? %>
            <div class="mt-4 space-y-3">
              <% @placements.first(6).each do |placement| %>
                <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4">
                  <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                    <div>
                      <p class="text-lg font-semibold text-[#4c1f2a]"><%= placement.mission.title %></p>
                      <p class="mt-1 text-sm text-[#7b4b5a]"><%= placement.mission.client_contact.client.brand_name.presence || placement.mission.client_contact.client.legal_name %> · <%= [placement.candidate.first_name, placement.candidate.last_name].join(" ") %></p>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold <%= placement.workflow_validated? ? 'border-[#d7e9dc] bg-[#edf8f0] text-[#2f6b3c]' : (placement.workflow_refused? ? 'border-[#f1c9d3] bg-[#fff1f4] text-[#b14360]' : 'border-[#f3dfc8] bg-[#fff3e8] text-[#ba6d2f]') %>">
                        <%= placement.workflow_validated? ? "Validé" : (placement.workflow_refused? ? "Refusé" : "En cours") %>
                      </span>
                      <%= link_to "Voir", placement_path(placement), class: "inline-flex items-center rounded-full border border-[#f1a38b] bg-[#f4a58a] px-4 py-2 text-sm font-semibold text-white transition hover:border-[#e39479] hover:bg-[#ee977c]" %>
                    </div>
                  </div>
                </article>
              <% end %>
            </div>
          <% else %>
            <p class="mt-4 text-sm text-base-content/60">Aucun placement actif pour le moment.</p>
          <% end %>
        </section>
      </div>

      <aside class="space-y-4">
        <section class="<%= surface_card_class %> p-5">
          <h2 class="text-xl font-semibold text-base-content">Snapshot annuel</h2>
          <div class="mt-4 space-y-3 text-sm text-base-content/70">
            <p><strong>Année:</strong> <%= @yearly_revenue_snapshot[:year] %></p>
            <p><strong>Placements:</strong> <%= @yearly_revenue_snapshot[:placements_count] %></p>
            <p><strong>Réalisé:</strong> <%= number_to_currency(@yearly_revenue_snapshot[:realized_cents] / 100.0, unit: "€", precision: 0) %></p>
            <p><strong>En attente:</strong> <%= number_to_currency(@yearly_revenue_snapshot[:pending_cents] / 100.0, unit: "€", precision: 0) %></p>
            <p><strong>Projeté:</strong> <%= number_to_currency(@yearly_revenue_snapshot[:projected_cents] / 100.0, unit: "€", precision: 0) %></p>
          </div>
        </section>

        <section class="<%= surface_card_class %> p-5">
          <h2 class="text-xl font-semibold text-base-content">Flux finance</h2>
          <% if @finance_feed.any? %>
            <div class="mt-4 space-y-3">
              <% @finance_feed.each do |event| %>
                <article class="rounded-2xl border border-[#ead2dc] bg-[#fff8fb]/95 p-3">
                  <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]"><%= l(event[:date], format: "%d/%m/%Y") %></p>
                  <p class="mt-2 text-sm text-[#5f3647]"><%= event[:message] %></p>
                </article>
              <% end %>
            </div>
          <% else %>
            <p class="mt-4 text-sm text-base-content/60">Aucun événement finance récent.</p>
          <% end %>
        </section>
      </aside>
    </div>
  </section>
</div>
