<div class="max-w-5xl mx-auto p-6 space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Clients</h1>
    <%= link_to "Nouveau client", new_client_path, class: "btn btn-primary" %>
  </div>
  <%= render "shared/index_filters", path: clients_path, q: @q, status: nil, status_options: nil, status_param: :status %>

  <div class="overflow-x-auto bg-base-100 rounded-lg">
    <% if @clients.any? %>
      <table class="table w-full">
        <thead>
          <tr>
            <th>Nom</th>
            <th>Secteur</th>
            <th>Localisation</th>
            <th>Actif</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @clients.each do |client| %>
            <tr>
              <td><%= client.legal_name %></td>
              <td><%= client.sector.presence || "-" %></td>
              <td><%= client.location.presence || "-" %></td>
              <td><%= client.active ? "Oui" : "Non" %></td>
              <td class="text-right">
                <%= link_to "Voir", client_path(client), class: "btn btn-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-8 text-center space-y-3">
        <p class="text-lg font-medium">Aucun client pour le moment</p>
        <%= link_to "Creer le premier client", new_client_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
  <%= render "shared/pagination", page: @page, total_pages: @total_pages, extra_params: { q: @q }, path: ->(params) { clients_path(params) } %>
</div>
