<% content_for :title, "Connexion | Rivyr" %>

<div class="min-h-screen px-4 py-8 sm:px-6 lg:px-8">
  <div class="mx-auto grid min-h-[calc(100vh-4rem)] max-w-7xl overflow-hidden rounded-[32px] border border-white/60 bg-white/80 shadow-[0_28px_90px_rgba(15,23,42,0.14)] backdrop-blur xl:grid-cols-[1.05fr_0.95fr]">
    <section class="relative overflow-hidden bg-[radial-gradient(circle_at_top_left,_rgba(237,14,100,0.18),_transparent_36%),linear-gradient(145deg,#fff5f9_0%,#fffdfa_42%,#fff1e7_100%)] px-8 py-10 sm:px-10 lg:px-12 lg:py-14">
      <div class="absolute inset-x-0 top-0 h-1 bg-[#ED0E64]"></div>
      <div class="relative flex h-full flex-col justify-between">
        <div>
          <div class="inline-flex items-center gap-3 rounded-full border border-white/70 bg-white/80 px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm">
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-[#ED0E64] text-white">
              <%= inline_svg_tag("icon_pers.svg", class: "h-4 w-4") %>
            </span>
            Espace freelance Rivyr
          </div>

          <div class="mt-10 max-w-xl space-y-5">
            <h1 class="text-4xl font-semibold leading-tight tracking-tight text-slate-900 md:text-5xl">
              Reprenez la main sur vos missions, vos revenus et votre collectif.
            </h1>
            <p class="text-base leading-relaxed text-slate-600 md:text-lg">
              Connectez-vous a votre cockpit Rivyr pour suivre vos missions en cours, vos signatures, votre portefeuille et la vie du collectif.
            </p>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-3">
            <div class="rounded-[24px] border border-white/70 bg-white/75 p-4 shadow-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Missions actives</p>
              <p class="mt-3 text-3xl font-semibold text-slate-900">12</p>
              <p class="mt-1 text-sm text-slate-500">Une vision claire de vos priorites du jour.</p>
            </div>
            <div class="rounded-[24px] border border-white/70 bg-white/75 p-4 shadow-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Signatures</p>
              <p class="mt-3 text-3xl font-semibold text-slate-900">4</p>
              <p class="mt-1 text-sm text-slate-500">Contrats, avenants et documents a relancer.</p>
            </div>
            <div class="rounded-[24px] border border-white/70 bg-white/75 p-4 shadow-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Paiements</p>
              <p class="mt-3 text-3xl font-semibold text-slate-900">8 500€</p>
              <p class="mt-1 text-sm text-slate-500">Une lecture immediate de ce qui arrive.</p>
            </div>
          </div>
        </div>

        <div class="mt-10 rounded-[28px] border border-white/70 bg-slate-950 px-6 py-5 text-white shadow-[0_20px_55px_rgba(15,23,42,0.24)]">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-white/55">Le collectif Rivyr</p>
              <p class="mt-2 text-lg font-semibold">Un reseau selectif, oriente execution et resultats.</p>
            </div>
            <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white/80">Label actif</span>
          </div>
          <div class="mt-5 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl bg-white/6 p-3">
              <p class="text-sm font-medium">Opportunites compatibles</p>
              <p class="mt-2 text-2xl font-semibold">6</p>
            </div>
            <div class="rounded-2xl bg-white/6 p-3">
              <p class="text-sm font-medium">Freelances certifies</p>
              <p class="mt-2 text-2xl font-semibold">48</p>
            </div>
            <div class="rounded-2xl bg-white/6 p-3">
              <p class="text-sm font-medium">Indice Rivyr moyen</p>
              <p class="mt-2 text-2xl font-semibold">8.7</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="flex items-center bg-white px-6 py-10 sm:px-10 lg:px-14">
      <div class="mx-auto w-full max-w-md">
        <div class="mb-8">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#B40C4D]">Connexion</p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900">Acceder a votre espace Rivyr</h2>
          <p class="mt-2 text-sm leading-relaxed text-slate-500">
            Utilisez vos identifiants pour retrouver votre dashboard, vos missions et vos documents.
          </p>
        </div>

        <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
          <div class="space-y-4">
            <div>
              <label class="mb-2 block text-sm font-medium text-slate-700" for="<%= "#{resource_name}_email" %>">Email</label>
              <%= f.input_field :email,
                    required: false,
                    autofocus: true,
                    autocomplete: "email",
                    class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-slate-900 outline-none transition focus:border-[#ED0E64] focus:bg-white focus:ring-4 focus:ring-[#FDE7F1]" %>
            </div>

            <div>
              <div class="mb-2 flex items-center justify-between gap-3">
                <label class="block text-sm font-medium text-slate-700" for="<%= "#{resource_name}_password" %>">Mot de passe</label>
                <%= link_to "Mot de passe oublie ?", new_password_path(resource_name), class: "text-sm font-medium text-[#B40C4D] transition hover:text-[#ED0E64]" %>
              </div>
              <%= f.input_field :password,
                    required: false,
                    autocomplete: "current-password",
                    class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-slate-900 outline-none transition focus:border-[#ED0E64] focus:bg-white focus:ring-4 focus:ring-[#FDE7F1]" %>
            </div>

            <% if devise_mapping.rememberable? %>
              <label class="inline-flex items-center gap-3 text-sm text-slate-600">
                <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-[#ED0E64] focus:ring-[#ED0E64]" %>
                <span>Se souvenir de moi</span>
              </label>
            <% end %>
          </div>

          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="space-y-3">
            <%= f.button :submit, "Se connecter", class: "inline-flex w-full items-center justify-center rounded-full bg-[#ED0E64] px-5 py-3.5 text-base font-semibold text-white shadow-[0_18px_44px_rgba(237,14,100,0.28)] transition hover:brightness-105" %>
            <%= link_to root_path, class: "inline-flex w-full items-center justify-center rounded-full border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-600 transition hover:border-slate-300 hover:text-slate-900" do %>
              Retour a l'accueil
            <% end %>
          </div>
        <% end %>

        <div class="mt-8 border-t border-slate-200 pt-6 text-sm text-slate-500">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </section>
  </div>
</div>
