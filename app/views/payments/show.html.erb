<div class="max-w-5xl mx-auto p-6 space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Paiement #<%= @payment.id %></h1>
    <div class="flex gap-2">
      <%= link_to "Modifier", edit_payment_path(@payment), class: "btn btn-primary" %>
      <%= link_to "Supprimer", payment_path(@payment), data: { turbo_method: :delete, turbo_confirm: "Confirmer la suppression ?" }, class: "btn btn-error" %>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-4">
    <p><strong>Facture:</strong> <%= link_to @payment.invoice.number, invoice_path(@payment.invoice), class: "link link-primary" %></p>
    <p><strong>Commission:</strong> <%= link_to "##{@payment.commission_id}", commission_path(@payment.commission), class: "link link-primary" %></p>
    <p><strong>Statut:</strong> <%= @payment.status %></p>
    <p><strong>Montant (cents):</strong> <%= @payment.amount_cents %></p>
    <p><strong>Type:</strong> <%= @payment.payment_type.presence || "-" %></p>
    <p><strong>Reference:</strong> <%= @payment.reference.presence || "-" %></p>
    <p><strong>Paye le:</strong> <%= @payment.paid_at.presence || "-" %></p>
  </div>

  <%= link_to "Retour a la liste", payments_path, class: "btn" %>
</div>
