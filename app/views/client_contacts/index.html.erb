<div class="max-w-6xl mx-auto p-6 space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Contacts clients</h1>
    <%= link_to "Nouveau contact", new_client_contact_path, class: "btn btn-primary" %>
  </div>
  <%= render "shared/index_filters", path: client_contacts_path, q: @q, status: nil, status_options: nil, status_param: :status %>

  <div class="overflow-x-auto bg-base-100 rounded-lg">
    <% if @client_contacts.any? %>
      <table class="table w-full">
        <thead>
          <tr>
            <th>Nom</th>
            <th>Client</th>
            <th>Email</th>
            <th>Téléphone</th>
            <th>Principal</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @client_contacts.each do |contact| %>
            <tr>
              <td>
                <div class="flex items-center gap-3">
                  <% if contact.avatar.present? %>
                    <%= image_tag contact.avatar, alt: [contact.first_name, contact.last_name].join(" "), class: "h-10 w-10 rounded-full object-cover" %>
                  <% else %>
                    <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-base-200 text-xs font-semibold uppercase">
                      <%= [contact.first_name, contact.last_name].filter_map { |part| part.to_s.first }.join.first(2) %>
                    </span>
                  <% end %>
                  <span><%= [contact.first_name, contact.last_name].join(" ") %></span>
                </div>
              </td>
              <td><%= contact.client.legal_name %></td>
              <td><%= contact.email.presence || "-" %></td>
              <td><%= contact.phone.presence || "-" %></td>
              <td><%= contact.primary_contact ? "Oui" : "Non" %></td>
              <td class="text-right">
                <%= link_to "Voir", client_contact_path(contact), class: "btn btn-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-8 text-center space-y-3">
        <p class="text-lg font-medium">Aucun contact client pour le moment</p>
        <%= link_to "Créer le premier contact", new_client_contact_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
  <%= render "shared/pagination", page: @page, total_pages: @total_pages, extra_params: { q: @q }, path: ->(params) { client_contacts_path(params) } %>
</div>
