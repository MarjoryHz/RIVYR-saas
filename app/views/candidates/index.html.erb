<% surface_card_class = "rounded-[1.45rem] border border-base-100/70 bg-base-100/88 shadow-lg" %>
<% tone_classes = {
  "emerald" => "bg-emerald-50 text-emerald-700 ring-emerald-200",
  "amber"   => "bg-amber-50 text-amber-700 ring-amber-200",
  "slate"   => "bg-slate-100 text-slate-600 ring-slate-200",
  "pink"    => "bg-[#FDE7F1] text-[#B40C4D] ring-[#F7C4DA]",
  "sky"     => "bg-sky-50 text-sky-700 ring-sky-200"
} %>

<div class="mx-auto max-w-7xl p-4 md:p-6">
  <section class="space-y-6">

    <header class="space-y-5">
      <div class="space-y-2">
        <h1 class="text-3xl font-semibold tracking-tight text-base-content md:text-4xl">CVthèque</h1>
        <p class="text-base text-base-content/60">Une vue claire des candidats vus par le collectif, de leur niveau de qualification et des actions à engager.</p>
      </div>

    </header>

    <div class="<%= surface_card_class %> overflow-hidden">
      <div class="border-b border-base-200/70 px-6 py-4">
        <div class="relative">
          <div class="flex flex-wrap gap-3">
            <button
              type="button"
              class="inline-flex items-center gap-2 rounded-2xl border border-base-200 bg-base-100/75 px-5 py-3 text-base font-medium text-base-content/70 shadow-sm transition hover:bg-base-100/95"
              aria-controls="candidates-filtres"
              aria-expanded="false"
              onclick="document.getElementById('candidates-filtres').classList.toggle('hidden'); this.setAttribute('aria-expanded', String(!document.getElementById('candidates-filtres').classList.contains('hidden')));">
              <i class="fa-solid fa-sliders text-[#ed0e64]"></i>
              Filtres
              <i class="fa-solid fa-angle-down text-xs text-[#ed0e64]"></i>
            </button>

            <%= link_to request.path + "?only_favorites=#{@only_favorites ? '0' : '1'}",
                  class: "inline-flex items-center gap-2 rounded-2xl border px-5 py-3 text-base font-medium shadow-sm transition #{@only_favorites ? 'border-[#f1a38b] bg-[#f4a58a] text-white' : 'border-base-200 bg-base-100/75 text-base-content/70 hover:bg-base-100/95'}" do %>
              <i class="fa-<%= @only_favorites ? 'solid' : 'regular' %> fa-heart text-[#ed0e64]"></i>
              Favoris
            <% end %>

            <%= link_to new_candidate_path, class: "inline-flex items-center gap-2 rounded-2xl border border-[#f1a38b] bg-[#f4a58a] px-5 py-3 text-base font-medium text-white shadow-sm transition hover:border-[#e39479] hover:bg-[#ee977c]" do %>
              <i class="fa-solid fa-plus"></i>
              Nouveau candidat
            <% end %>
          </div>

          <div id="candidates-filtres" class="absolute inset-x-0 top-full z-30 mt-3 hidden rounded-[1.45rem] border border-base-200 bg-base-100 p-4 shadow-xl">
            <%= form_with url: request.path, method: :get, local: true, class: "grid gap-3 md:grid-cols-2 xl:grid-cols-4", html: { onsubmit: "document.getElementById('candidates-filtres').classList.add('hidden')" } do %>
              <div>
                <label class="mb-1 block text-sm font-medium text-base-content/70">Recherche</label>
                <%= text_field_tag :q, @q, placeholder: "Nom, email, source...", class: "input input-bordered w-full" %>
              </div>

              <div>
                <label class="mb-1 block text-sm font-medium text-base-content/70">Statut</label>
                <%= select_tag :status,
                      options_for_select([["Tous les statuts", ""]] + Candidate.statuses.keys.map { |v| [v.humanize, v] }, @status),
                      class: "select select-bordered w-full" %>
              </div>

              <div class="flex items-end gap-2 md:col-span-2 xl:col-span-2">
                <%= submit_tag "Appliquer", class: "btn btn-primary flex-1" %>
                <% if @q.present? || @status.present? %>
                  <%= link_to "Réinitialiser", request.path, class: "btn btn-ghost" %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <% if @candidate_rows.any? %>
        <div class="divide-y divide-base-200/70">
          <% @candidate_rows.each do |row| %>
            <% candidate = row[:candidate] %>
            <% status_badge = row[:status_badge] %>
            <% search_badge = row[:search_status] %>
            <article class="px-6 py-5 transition hover:bg-base-100/60">
              <div class="grid items-center gap-4 xl:grid-cols-[auto_minmax(0,1fr)_auto]">

                <div class="relative shrink-0">
                  <%= image_tag row[:avatar_path], alt: row[:full_name], class: "h-12 w-12 rounded-full object-cover ring-2 ring-[#F7C4DA]" %>
                  <% if row[:certified] %>
                    <span class="absolute -bottom-1 -right-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-[#ED0E64] text-[10px] text-white ring-2 ring-white" title="Profil qualifié par Rivyr">
                      <i class="fa-solid fa-certificate"></i>
                    </span>
                  <% end %>
                </div>

                <div class="min-w-0 space-y-1.5">
                  <div class="flex flex-wrap items-center gap-2">
                    <h2 class="truncate text-xl font-semibold text-base-content"><%= row[:full_name] %></h2>
                    <% if row[:seen] %>
                      <span class="inline-flex items-center rounded-full bg-base-200/70 px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-[0.16em] text-base-content/50">déjà vu</span>
                    <% end %>
                    <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ring-1 <%= tone_classes.fetch(status_badge[:tone]) %>"><%= status_badge[:label] %></span>
                    <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ring-1 <%= tone_classes.fetch(search_badge[:tone]) %>"><%= search_badge[:label] %></span>
                  </div>
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-base-content/55">
                    <span><i class="fa-solid fa-envelope mr-1"></i><%= candidate.email.presence || "Email non renseigné" %></span>
                    <span class="text-base-content/20">•</span>
                    <span><i class="fa-solid fa-phone mr-1"></i><%= candidate.phone.presence || "Téléphone non renseigné" %></span>
                  </div>
                </div>

                <div class="flex flex-wrap items-center gap-2 xl:justify-end">
                  <% is_favorite = @favorite_candidate_ids.include?(candidate.id) %>
                  <%= link_to toggle_favorite_candidate_path(candidate, return_to: request.fullpath), method: :patch, data: { turbo_method: :patch },
                        class: "inline-flex h-10 w-10 items-center justify-center rounded-full border transition #{is_favorite ? 'border-[#f7c4da] bg-[#fff0f6] text-[#ed0e64]' : 'border-base-200 bg-base-100/75 text-base-content/40 hover:text-[#ed0e64]'}",
                        title: is_favorite ? "Retirer des favoris" : "Ajouter aux favoris" do %>
                    <i class="fa-<%= is_favorite ? 'solid' : 'regular' %> fa-heart"></i>
                  <% end %>
                  <%= link_to (request.path.start_with?("/dashboard") ? dashboard_candidate_path(candidate) : candidate_path(candidate)),
                        class: "inline-flex h-10 w-10 items-center justify-center rounded-full border border-base-200 bg-base-100/75 text-base-content/60 transition hover:border-base-300 hover:text-base-content",
                        title: "Voir la fiche" do %>
                    <i class="fa-regular fa-eye"></i>
                  <% end %>
                </div>

              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="p-8 text-center text-base-content/65">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-base-200/60 text-base-content/40">
            <i class="fa-solid fa-folder-open text-xl"></i>
          </div>
          <h2 class="mt-5 text-xl font-semibold text-base-content">Aucun candidat à afficher</h2>
          <p class="mt-2 text-sm text-base-content/55">Ajuste tes filtres ou ajoute un nouveau profil dans la CVthèque.</p>
          <%= link_to "Créer un candidat", new_candidate_path, class: "mt-6 inline-flex items-center gap-2 rounded-full border border-[#f1a38b] bg-[#f4a58a] px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:border-[#e39479] hover:bg-[#ee977c]" %>
        </div>
      <% end %>

      <div class="border-t border-base-200/70 px-6 py-4">
        <%= render "shared/pagination",
              page: @page,
              total_pages: @total_pages,
              extra_params: { q: @q, status: @status },
              path: ->(params) { request.path.start_with?("/dashboard") ? dashboard_candidates_path(params) : candidates_path(params) } %>
      </div>
    </div>

  </section>
</div>
