<div class="max-w-4xl mx-auto p-6 space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold"><%= [@candidate.first_name, @candidate.last_name].join(" ") %></h1>
    <div class="flex gap-2">
      <%= link_to "Modifier", edit_candidate_path(@candidate), class: "btn btn-primary" %>
      <%= link_to "Supprimer", candidate_path(@candidate), data: { turbo_method: :delete, turbo_confirm: "Confirmer la suppression ?" }, class: "btn btn-error" %>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-4">
    <p><strong>Email:</strong> <%= @candidate.email.presence || "-" %></p>
    <p><strong>Telephone:</strong> <%= @candidate.phone.presence || "-" %></p>
    <p><strong>LinkedIn:</strong> <%= @candidate.linkedin_url.presence || "-" %></p>
    <p><strong>Statut:</strong> <%= @candidate.status.presence || "-" %></p>
    <p><strong>Source:</strong> <%= @candidate.source.presence || "-" %></p>
  </div>

  <div>
    <p><strong>Notes:</strong></p>
    <p><%= @candidate.notes.presence || "-" %></p>
  </div>

  <%= link_to "Retour a la liste", candidates_path, class: "btn" %>
</div>
