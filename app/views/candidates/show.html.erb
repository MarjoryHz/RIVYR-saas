<script>
  const TABS = ['profil', 'contribution', 'notes', 'docs', 'historique'];
  switchTab('profil');

  let expExpanded = false;
  function toggleExperiences() {
    expExpanded = !expExpanded;
    document.querySelectorAll('.exp-extra').forEach(el => el.classList.toggle('hidden', !expExpanded));
    document.querySelectorAll('.exp-line').forEach(el => el.classList.toggle('hidden', !expExpanded));
    const icon  = document.getElementById('exp-toggle-icon');
    const label = document.getElementById('exp-toggle-label');
    const count = document.querySelectorAll('.exp-extra').length;
    if (expExpanded) {
      icon.classList.replace('fa-chevron-down', 'fa-chevron-up');
      label.textContent = 'Voir moins';
    } else {
      icon.classList.replace('fa-chevron-up', 'fa-chevron-down');
      label.textContent = 'Voir plus (' + count + ' de plus)';
    }
  }

  function switchTab(name) {
    TABS.forEach(tab => {
      const btn   = document.getElementById('tab-' + tab);
      const panel = document.getElementById('panel-' + tab);
      const active = tab === name;

      panel.classList.toggle('hidden', !active);
      if (!btn) return;
      btn.classList.toggle('bg-[#ed0e64]',        active);
      btn.classList.toggle('text-white',           active);
      btn.classList.toggle('shadow-sm',            active);
      btn.classList.toggle('font-semibold',        active);
      btn.classList.toggle('bg-white',             !active);
      btn.classList.toggle('border',               !active);
      btn.classList.toggle('border-[#ead2dc]',     !active);
      btn.classList.toggle('font-medium',          !active);
      btn.classList.toggle('text-[#9a5a68]',       !active);
    });
  }

  // ===== Notes : édition inline =====

  function editNote(id) {
    const card = document.getElementById('candidate-note-' + id);
    card.querySelector('.note-display').classList.add('hidden');
    card.querySelector('.note-edit').classList.remove('hidden');
    card.querySelector('.note-edit textarea').focus();
  }

  function cancelEdit(id) {
    const card = document.getElementById('candidate-note-' + id);
    card.querySelector('.note-edit').classList.add('hidden');
    card.querySelector('.note-display').classList.remove('hidden');
  }

  // ===== Demande de documents =====

  const CANDIDATE_FIRST_NAME = '<%= @candidate.first_name %>';
  const CANDIDATE_ID         = '<%= @candidate.id %>';

  const DOC_CATALOG = [
    { key: 'diplomes',        label: 'Diplômes',                      uploaded: true,  duration: '2 ans' },
    { key: 'motivation',      label: 'Lettre de motivation',          uploaded: true,  duration: '2 ans' },
    { key: 'recommandation',  label: 'Lettre de recommandation',      uploaded: false, duration: '2 ans' },
    { key: 'prise_reference', label: 'Accord de prise de référence',  uploaded: false, duration: '2 ans' },
    { key: 'autorisation',    label: 'Autorisation de travail',       uploaded: true,  duration: '2 ans' },
    { key: 'permis',          label: 'Permis de conduire',            uploaded: true,  duration: '2 ans' },
  ];

  function openDocRequestModal() {
    const modal = document.getElementById('doc-request-modal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');

    // Render checkboxes
    const container = document.getElementById('doc-checkboxes');
    container.innerHTML = DOC_CATALOG.map(doc => `
      <label class="flex cursor-pointer items-center gap-3 rounded-xl border border-[#ead2dc] bg-white px-3 py-2.5 transition hover:bg-[#fff0f6]">
        <input type="checkbox" class="doc-checkbox h-4 w-4 accent-[#ed0e64]"
          data-key="${doc.key}" data-label="${doc.label}" data-duration="${doc.duration}"
          ${!doc.uploaded ? 'checked' : ''}>
        <span class="text-[13px] font-medium text-[#4c1f2a]">${doc.label}</span>
        ${doc.uploaded ? '<span class="ml-auto text-[10px] text-[#9a5a68]">déjà importé</span>' : ''}
      </label>
    `).join('');

    document.querySelectorAll('.doc-checkbox').forEach(cb =>
      cb.addEventListener('change', updateEmailPreview)
    );

    updateEmailPreview();
  }

  function closeDocRequestModal(event) {
    if (event && event.target !== event.currentTarget) return;
    const modal = document.getElementById('doc-request-modal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  function getCheckedDocs() {
    return Array.from(document.querySelectorAll('.doc-checkbox:checked')).map(cb => ({
      key:      cb.dataset.key,
      label:    cb.dataset.label,
      duration: cb.dataset.duration,
    }));
  }

  function uploadLink(key) {
    // Placeholder — à brancher sur la vraie route upload
    return `https://app.rivyr.com/candidats/${CANDIDATE_ID}/documents/${key}/deposer?token=TOKEN_UNIQUE`;
  }

  function updateEmailPreview() {
    const docs  = getCheckedDocs();
    const preview = document.getElementById('email-preview');

    if (docs.length === 0) {
      preview.textContent = 'Sélectionnez au moins un document pour générer le message.';
      return;
    }

    const docLines = docs.map(d =>
      `  • ${d.label}\n    → ${uploadLink(d.key)}`
    ).join('\n\n');

    const consentLines = docs.map(d =>
      `  • ${d.label} : conservé ${d.duration} à compter du dépôt`
    ).join('\n');

    preview.textContent = [
`Objet : Votre dossier candidat – Documents à compléter`,
``,
`Bonjour ${CANDIDATE_FIRST_NAME},`,
``,
`Dans le cadre de votre profil candidat, nous souhaitons compléter votre dossier.`,
`Merci de bien vouloir déposer les documents suivants en cliquant sur les liens ci-dessous :`,
``,
docLines,
``,
`Chaque lien est personnel et sécurisé — il vous permet de déposer directement`,
`le document au bon endroit dans votre dossier.`,
``,
`─────────────────────────────────────────────`,
`ACCORD DE CONSERVATION DES DONNÉES (RGPD)`,
`─────────────────────────────────────────────`,
``,
`En déposant vos documents via les liens ci-dessus, vous acceptez les conditions`,
`suivantes concernant la conservation de vos données personnelles :`,
``,
`Durée de conservation par document :`,
consentLines,
``,
`• Sécurité : vos documents sont stockés de manière sécurisée et ne sont`,
`  transmis qu'aux clients directement concernés par vos candidatures.`,
``,
`• Droit de suppression : vous pouvez demander la suppression de l'ensemble`,
`  ou d'une partie de vos documents à tout moment, en répondant simplement`,
`  à cet email. Votre demande sera traitée sous 72 h.`,
``,
`• Droit d'accès : vous pouvez à tout moment demander à consulter les`,
`  documents que nous conservons vous concernant.`,
``,
`Le dépôt de vos documents via les liens ci-dessus vaut acceptation de ces`,
`conditions de conservation.`,
``,
`─────────────────────────────────────────────`,
``,
`Cordialement,`,
`L'équipe RIVYR`,
    ].join('\n');
  }

  function copyEmailPreview() {
    const text = document.getElementById('email-preview').textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = event.currentTarget;
      const original = btn.innerHTML;
      btn.innerHTML = '<i class="fa-solid fa-check text-xs"></i> Copié !';
      setTimeout(() => { btn.innerHTML = original; }, 2000);
    });
  }
</script>
