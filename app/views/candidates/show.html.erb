<% is_favorite = current_user.favorite_candidates.exists?(candidate_id: @candidate.id) %>
<%
  status_config = {
    "new"          => { label: "À qualifier",    bg: "bg-slate-100",   text: "text-slate-600",   ring: "ring-slate-200"   },
    "qualified"    => { label: "Qualifié Rivyr", bg: "bg-[#FDE7F1]",   text: "text-[#B40C4D]",   ring: "ring-[#F7C4DA]"   },
    "presented"    => { label: "Présenté",        bg: "bg-sky-50",      text: "text-sky-700",     ring: "ring-sky-200"     },
    "interviewing" => { label: "En entretien",    bg: "bg-emerald-50",  text: "text-emerald-700", ring: "ring-emerald-200" },
    "placed"       => { label: "Placé",           bg: "bg-emerald-100", text: "text-emerald-800", ring: "ring-emerald-300" }
  }
  badge = status_config[@candidate.status] || status_config["new"]
  avatar_index = (@candidate.id || @candidate.email.to_s.sum) % 10 + 1
  last_title = @candidate.work_experiences.first&.title || @candidate.job_titles&.last
  whatsapp_number = @candidate.phone.to_s.gsub(/\D/, '')
%>

<div class="w-full max-w-none px-6 pt-0 pb-5 md:px-11 lg:px-10">
  <div class="space-y-4">

    <%# ── Hero ── %>
    <section class="relative overflow-hidden p-6">
      <div class="relative z-10 flex items-center gap-5">
        <%= image_tag "avatars/avatar-#{format('%02d', avatar_index)}.png",
              alt: "#{@candidate.first_name} #{@candidate.last_name}",
              class: "h-24 w-24 rounded-full object-cover ring-4 ring-white shadow-md shrink-0" %>
        <div class="space-y-2">
          <h1 class="text-3xl font-bold text-[#3d1a24] md:text-4xl"><%= @candidate.first_name %> <%= @candidate.last_name %></h1>
          <% if last_title.present? %>
            <p class="text-[15px] font-medium text-[#7b4b5a]"><%= last_title %></p>
          <% end %>
          <div class="flex flex-wrap items-center gap-2">
            <span class="inline-flex items-center rounded-full px-4 py-1.5 text-sm font-semibold ring-1 <%= badge[:bg] %> <%= badge[:text] %> <%= badge[:ring] %>"><%= badge[:label] %></span>
            <% if @candidate.source.present? %>
              <span class="inline-flex items-center rounded-full bg-[#e8e0f5] px-4 py-1.5 text-sm font-semibold text-[#6b4fa8]"><%= @candidate.source.humanize %></span>
            <% end %>
          </div>
        </div>
      </div>
      <span class="pointer-events-none absolute -right-6 -top-6 h-36 w-36 rounded-full bg-white/20"></span>
      <span class="pointer-events-none absolute right-20 top-6 h-14 w-14 rounded-full bg-white/30"></span>
      <span class="pointer-events-none absolute right-8 bottom-4 h-9 w-9 rounded-full bg-white/20"></span>
      <span class="pointer-events-none absolute right-40 bottom-2 h-6 w-6 rounded-full bg-white/25"></span>
    </section>

    <%# ── Tabs ── %>
    <div class="flex items-center gap-3" id="candidate-tabs">
      <button type="button" onclick="switchTab('profil')" id="tab-profil"
        class="inline-flex items-center gap-2 rounded-xl bg-[#ed0e64] px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition">
        <i class="fa-regular fa-user"></i> Profil
      </button>
      <button type="button" onclick="switchTab('contribution')" id="tab-contribution"
        class="inline-flex items-center gap-2 rounded-xl border border-[#ead2dc] bg-white px-5 py-2.5 text-sm font-medium text-[#9a5a68] transition">
        <i class="fa-regular fa-handshake"></i> Contribution
      </button>
      <button type="button" onclick="switchTab('notes')" id="tab-notes" class="hidden"></button>
      <button type="button" onclick="switchTab('docs')" id="tab-docs" class="hidden"></button>
      <button type="button" onclick="switchTab('historique')" id="tab-historique" class="hidden"></button>
    </div>

    <%# ══════════════════════════════════ %>
    <%# ── Panneau : Profil ── %>
    <%# ══════════════════════════════════ %>
    <div id="panel-profil" class="grid gap-4 xl:grid-cols-[1fr_2fr_1fr]">

      <%# Gauche %>
      <div class="space-y-4">
        <div class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4 space-y-2.5 text-[13px] text-[#5c3143]">
          <h4 class="text-base font-semibold text-[#5b2633]">Informations</h4>
          <div class="flex items-center gap-1.5">
            <div class="flex items-center gap-1.5">
              <% if @candidate.linkedin_url.present? %>
                <%= link_to @candidate.linkedin_url, target: "_blank", rel: "noopener",
                      class: "inline-flex h-7 w-7 items-center justify-center rounded-full bg-[#0A66C2] text-white hover:bg-[#004182] transition" do %>
                  <i class="fa-brands fa-linkedin-in text-xs"></i>
                <% end %>
              <% else %>
                <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-base-200 bg-base-200/50 text-base-content/25"><i class="fa-brands fa-linkedin-in text-xs"></i></span>
              <% end %>
              <% if whatsapp_number.present? %>
                <%= link_to "https://wa.me/#{whatsapp_number}", target: "_blank", rel: "noopener",
                      class: "inline-flex h-7 w-7 items-center justify-center rounded-full bg-[#25D366] text-white hover:bg-[#1da851] transition" do %>
                  <i class="fa-brands fa-whatsapp text-xs"></i>
                <% end %>
              <% else %>
                <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-base-200 bg-base-200/50 text-base-content/25"><i class="fa-brands fa-whatsapp text-xs"></i></span>
              <% end %>
              <% if @candidate.website_url.present? %>
                <%= link_to @candidate.website_url, target: "_blank", rel: "noopener",
                      class: "inline-flex h-7 w-7 items-center justify-center rounded-full border border-[#ead2dc] bg-white text-[#6b3f4f] hover:bg-[#fff0f6] transition" do %>
                  <i class="fa-solid fa-globe text-xs"></i>
                <% end %>
              <% else %>
                <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-base-200 bg-base-200/50 text-base-content/25"><i class="fa-solid fa-globe text-xs"></i></span>
              <% end %>
            </div>
          </div>
          <div class="border-t border-[#ead2dc] pt-2.5 space-y-2.5">
          <% if @candidate.email.present? %>
            <%= mail_to @candidate.email, class: "flex items-center gap-2 hover:text-[#ed0e64] transition" do %>
              <i class="fa-solid fa-envelope w-4 text-center text-[#ed0e64]"></i>
              <span class="truncate"><%= @candidate.email %></span>
            <% end %>
          <% end %>
          <% if @candidate.phone.present? %>
            <p class="flex items-center gap-2">
              <i class="fa-solid fa-phone w-4 text-center text-[#ed0e64]"></i>
              <span><%= @candidate.phone %></span>
            </p>
          <% end %>
          <% if @candidate.location.present? %>
            <p class="flex items-center gap-2">
              <i class="fa-solid fa-location-dot w-4 text-center text-[#ed0e64]"></i>
              <span><%= @candidate.location %></span>
            </p>
          <% end %>
          </div>
        </div>

        <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4 space-y-3 text-[13px] text-[#5c3143]">
          <h4 class="text-base font-semibold text-[#5b2633]">Recherche</h4>

          <%# Disponibilité %>
          <div>
            <p class="mb-1.5 text-[11px] font-medium uppercase tracking-wide text-[#9a5a68]">Disponibilité</p>
            <% if @candidate.availability.present? %>
              <span class="inline-flex items-center gap-1.5 rounded-full border border-[#ead2dc] bg-white px-2.5 py-1 text-xs font-medium text-[#4c1f2a]">
                <i class="fa-regular fa-calendar-check text-[#ed0e64] text-[10px]"></i>
                <%= Candidate::AVAILABILITY_LABELS[@candidate.availability] %>
              </span>
            <% else %>
              <span class="text-[12px] text-[#c4a0b0] italic">Non renseignée</span>
            <% end %>
          </div>

          <%# Zone de mobilité %>
          <div>
            <p class="mb-1.5 text-[11px] font-medium uppercase tracking-wide text-[#9a5a68]">Zone de mobilité</p>
            <% if @candidate.mobility_zone.present? %>
              <span class="inline-flex items-center gap-1.5 rounded-full border border-[#ead2dc] bg-white px-2.5 py-1 text-xs font-medium text-[#4c1f2a]">
                <i class="fa-solid fa-location-dot text-[#ed0e64] text-[10px]"></i>
                <%= @candidate.mobility_zone %>
              </span>
            <% else %>
              <span class="text-[12px] text-[#c4a0b0] italic">Non renseignée</span>
            <% end %>
          </div>

          <%# Types de contrat %>
          <div>
            <p class="mb-1.5 text-[11px] font-medium uppercase tracking-wide text-[#9a5a68]">Contrats souhaités</p>
            <% if @candidate.contract_types&.any? %>
              <div class="flex flex-wrap gap-1">
                <% @candidate.contract_types.each do |ct| %>
                  <span class="rounded-full border border-[#ead2dc] bg-white px-2.5 py-1 text-xs font-medium text-[#6b3f4f]">
                    <%= Candidate::CONTRACT_LABELS[ct] || ct %>
                  </span>
                <% end %>
              </div>
            <% else %>
              <span class="text-[12px] text-[#c4a0b0] italic">Non renseignés</span>
            <% end %>
          </div>

          <%# Rémunération %>
          <div>
            <p class="mb-1.5 text-[11px] font-medium uppercase tracking-wide text-[#9a5a68]">Rémunération souhaitée</p>
            <% if @candidate.salary_range.present? %>
              <span class="inline-flex items-center gap-1.5 rounded-full border border-[#ead2dc] bg-white px-2.5 py-1 text-xs font-medium text-[#4c1f2a]">
                <i class="fa-solid fa-euro-sign text-[#ed0e64] text-[10px]"></i>
                <%= @candidate.salary_range %>
              </span>
            <% else %>
              <span class="text-[12px] text-[#c4a0b0] italic">Non renseignée</span>
            <% end %>
          </div>
        </article>

      </div>

      <%# Centre %>
      <div class="space-y-4">
        <% experiences = @candidate.work_experiences %>
        <% if experiences.any? %>
          <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
            <h3 class="text-lg font-semibold text-[#5b2633]">Expérience professionnelle</h3>
            <ol class="mt-4" id="experiences-list">
              <% experiences.each_with_index do |exp, i| %>
                <li class="flex gap-3<%= i >= 4 ? ' exp-extra hidden' : '' %>">
                  <div class="flex flex-col items-center">
                    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full shadow-sm text-xs <%= exp.current? ? 'bg-[#ed0e64] text-white' : 'border border-[#ead2dc] bg-white text-[#ed0e64]' %>">
                      <i class="fa-regular fa-building text-[11px]"></i>
                    </span>
                    <% unless i == experiences.length - 1 %>
                      <span class="my-1.5 flex-1 w-px bg-[#ead2dc] exp-line<%= i >= 3 ? ' hidden' : '' %>"></span>
                    <% end %>
                  </div>
                  <div class="pb-4 pt-1">
                    <p class="text-[15px] font-semibold text-[#4c1f2a]"><%= exp.title %></p>
                    <% if exp.company.present? %>
                      <p class="mt-0.5 text-[13px] font-medium text-[#7b4b5a]"><%= exp.company %></p>
                    <% end %>
                    <p class="mt-0.5 text-[11px] text-[#9a5a68]"><%= exp.date_range %></p>
                    <% if exp.skills.any? %>
                      <div class="mt-2 flex flex-wrap gap-1">
                        <% exp.skills.each do |skill| %>
                          <span class="rounded-full border border-[#ead2dc] bg-white px-2 py-0.5 text-[11px] font-medium text-[#6b3f4f]"><%= skill %></span>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ol>
            <% if experiences.length > 4 %>
              <button id="exp-toggle-btn" onclick="toggleExperiences()" class="mt-2 flex items-center gap-1.5 text-[12px] font-medium text-[#ed0e64] hover:text-[#c40b52] transition-colors">
                <i id="exp-toggle-icon" class="fa-solid fa-chevron-down text-[10px]"></i>
                <span id="exp-toggle-label">Voir plus (<%= experiences.length - 4 %> de plus)</span>
              </button>
            <% end %>
          </article>
        <% end %>

        <%
          diplomas       = @candidate.educations.select(&:diploma?)
          certifications = @candidate.educations.select(&:certification?)
          formations     = @candidate.educations.select(&:formation?)
        %>

        <% if diplomas.any? %>
          <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
            <div class="mb-4 flex items-center gap-2">
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-[#fff0f6] text-[#ed0e64]">
                <i class="fa-solid fa-graduation-cap text-xs"></i>
              </span>
              <h3 class="text-base font-semibold text-[#5b2633]">Diplômes</h3>
            </div>
            <ol>
              <% diplomas.each_with_index do |edu, i| %>
                <li class="flex gap-3">
                  <div class="flex flex-col items-center">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-[#ead2dc] bg-white text-[#ed0e64]">
                      <i class="fa-solid fa-scroll text-[10px]"></i>
                    </span>
                    <% unless i == diplomas.length - 1 %>
                      <span class="my-1.5 flex-1 w-px bg-[#ead2dc]"></span>
                    <% end %>
                  </div>
                  <div class="pb-4 pt-0.5">
                    <p class="text-[13px] font-semibold text-[#4c1f2a]"><%= edu.title %></p>
                    <% if edu.institution.present? %>
                      <p class="text-[12px] font-medium text-[#7b4b5a]"><%= edu.institution %></p>
                    <% end %>
                    <% if edu.date_range.present? %>
                      <p class="mt-0.5 text-[11px] text-[#9a5a68]"><%= edu.date_range %></p>
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ol>
          </article>
        <% end %>

        <% if certifications.any? %>
          <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
            <div class="mb-4 flex items-center gap-2">
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-[#e8e0f5] text-[#6b4fa8]">
                <i class="fa-solid fa-certificate text-xs"></i>
              </span>
              <h3 class="text-base font-semibold text-[#5b2633]">Certifications</h3>
            </div>
            <ol>
              <% certifications.each_with_index do |edu, i| %>
                <li class="flex gap-3">
                  <div class="flex flex-col items-center">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-[#ead2dc] bg-white text-[#ed0e64]">
                      <i class="fa-solid fa-check text-[10px]"></i>
                    </span>
                    <% unless i == certifications.length - 1 %>
                      <span class="my-1.5 flex-1 w-px bg-[#ead2dc]"></span>
                    <% end %>
                  </div>
                  <div class="pb-4 pt-0.5">
                    <p class="text-[13px] font-semibold text-[#4c1f2a]"><%= edu.title %></p>
                    <% if edu.institution.present? %>
                      <p class="text-[12px] font-medium text-[#7b4b5a]"><%= edu.institution %></p>
                    <% end %>
                    <% if edu.date_range.present? %>
                      <p class="mt-0.5 text-[11px] text-[#9a5a68]"><%= edu.date_range %></p>
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ol>
          </article>
        <% end %>

        <% if formations.any? %>
          <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
            <div class="mb-4 flex items-center gap-2">
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-[#fef3e2] text-[#c47c1a]">
                <i class="fa-solid fa-chalkboard-user text-xs"></i>
              </span>
              <h3 class="text-base font-semibold text-[#5b2633]">Formations</h3>
            </div>
            <ol>
              <% formations.each_with_index do |edu, i| %>
                <li class="flex gap-3">
                  <div class="flex flex-col items-center">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-[#ead2dc] bg-white text-[#ed0e64]">
                      <i class="fa-solid fa-arrow-right text-[9px]"></i>
                    </span>
                    <% unless i == formations.length - 1 %>
                      <span class="my-1.5 flex-1 w-px bg-[#ead2dc]"></span>
                    <% end %>
                  </div>
                  <div class="pb-4 pt-0.5">
                    <p class="text-[13px] font-semibold text-[#4c1f2a]"><%= edu.title %></p>
                    <% if edu.institution.present? %>
                      <p class="text-[12px] font-medium text-[#7b4b5a]"><%= edu.institution %></p>
                    <% end %>
                    <% if edu.date_range.present? %>
                      <p class="mt-0.5 text-[11px] text-[#9a5a68]"><%= edu.date_range %></p>
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ol>
          </article>
        <% end %>

      </div>

      <%# Droite : CV & Docs + Historique résumé %>
      <aside class="space-y-4">

        <%# CV & Docs %>
        <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4">
          <div class="flex items-center justify-between mb-3">
            <h4 class="text-base font-semibold text-[#5b2633]">CV & Docs</h4>
            <button onclick="switchTab('docs')" class="text-[12px] font-medium text-[#ed0e64] hover:text-[#c40b52] transition">Voir tout</button>
          </div>
          <div class="space-y-2">
            <button class="flex w-full items-center gap-2.5 rounded-2xl border border-[#ead2dc] bg-white px-3.5 py-2.5 text-left hover:bg-[#fff0f6] transition">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#fff0f6] text-[#ed0e64]">
                <i class="fa-regular fa-file-lines text-xs"></i>
              </span>
              <span class="text-[13px] font-medium text-[#4c1f2a]">Générer CV blindé</span>
            </button>
            <button class="flex w-full items-center gap-2.5 rounded-2xl border border-[#ead2dc] bg-white px-3.5 py-2.5 text-left hover:bg-[#fff0f6] transition">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#fff0f6] text-[#ed0e64]">
                <i class="fa-regular fa-file-pdf text-xs"></i>
              </span>
              <span class="text-[13px] font-medium text-[#4c1f2a]">Générer CV complet</span>
            </button>
            <button onclick="switchTab('docs')" class="flex w-full items-center gap-2.5 rounded-2xl border border-dashed border-[#ead2dc] bg-white/60 px-3.5 py-2.5 text-left hover:bg-[#fff0f6] transition">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#fff0f6] text-[#ed0e64]">
                <i class="fa-solid fa-arrow-up-from-bracket text-xs"></i>
              </span>
              <span class="text-[13px] font-medium text-[#9a5a68]">Stocker un document</span>
            </button>
          </div>
        </article>

        <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4">
          <div class="flex items-center justify-between">
            <h4 class="text-base font-semibold text-[#5b2633]">Historique</h4>
            <button onclick="switchTab('historique')" class="text-[12px] font-medium text-[#ed0e64] hover:text-[#c40b52] transition">Voir tout</button>
          </div>
          <ul class="mt-3 space-y-3 text-[13px]">
            <li class="flex items-start gap-2">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#ed0e64]"></span>
              <div>
                <p class="font-semibold text-[#4c1f2a]">Entretien de qualification</p>
                <p class="text-[#9a5a68]">03/04/2024 · 11:00</p>
              </div>
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#c88ea1]"></span>
              <div>
                <p class="font-semibold text-[#4c1f2a]">Résumé envoyé à Hexa Retail</p>
                <p class="text-[#9a5a68]">01/04/2024</p>
              </div>
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#c88ea1]"></span>
              <div>
                <p class="font-semibold text-[#4c1f2a]">CV transmis au client</p>
                <p class="text-[#9a5a68]">30/03/2024</p>
              </div>
            </li>
          </ul>
        </article>

        <% if @candidate.notes.present? %>
          <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
            <div class="flex items-center justify-between">
              <h3 class="text-base font-semibold text-[#5b2633]">Notes</h3>
              <button onclick="switchTab('notes')" class="text-[12px] font-medium text-[#ed0e64] hover:text-[#c40b52] transition">Voir tout</button>
            </div>
            <p class="mt-2 text-[13px] leading-relaxed text-[#5f3647]"
               style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;">
              <%= @candidate.notes %>
            </p>
          </article>
        <% end %>
      </aside>

    </div>

    <%# ══════════════════════════════════ %>
    <%# ── Panneau : Contribution ── %>
    <%# ══════════════════════════════════ %>
    <div id="panel-contribution" class="hidden">
      <%# Contenu à venir %>
    </div>

    <%# ── Panneau : Historique ── %>
    <%# ══════════════════════════════════ %>
    <div id="panel-historique" class="hidden space-y-4">

      <div class="grid gap-4 xl:grid-cols-[1fr_1fr]">

        <%# Grandes étapes collectives %>
        <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
          <h3 class="text-lg font-semibold text-[#5b2633]">Activité du collectif</h3>
          <p class="mt-1 text-xs text-[#9a5a68]">Actions des autres freelances sur ce profil</p>
          <ul class="mt-4 space-y-4">
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-emerald-50 text-emerald-600">
                <i class="fa-solid fa-check text-xs"></i>
              </span>
              <div class="text-[13px]">
                <p class="font-semibold text-[#4c1f2a]">Recruté sur <span class="text-emerald-600">Directeur Commercial</span></p>
                <p class="text-[#9a5a68]">par Antoine Mercier · Hexa Retail Performance</p>
                <p class="mt-0.5 text-xs text-[#c0849a]">05/04/2024</p>
              </div>
