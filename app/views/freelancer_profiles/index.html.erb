<div class="max-w-6xl mx-auto p-6 space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Freelancer profiles</h1>
    <%= link_to "Nouveau profil", new_freelancer_profile_path, class: "btn btn-primary" %>
  </div>
  <%= render "shared/index_filters", path: freelancer_profiles_path, q: @q, status: @operational_status, status_options: FreelancerProfile.operational_statuses.keys, status_param: :operational_status %>

  <div class="overflow-x-auto bg-base-100 rounded-lg">
    <% if @freelancer_profiles.any? %>
      <table class="table w-full">
        <thead>
          <tr>
            <th>Freelancer</th>
            <th>Region</th>
            <th>Specialite</th>
            <th>Disponibilite</th>
            <th>Score</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @freelancer_profiles.each do |profile| %>
            <tr>
              <td><%= [profile.user.first_name, profile.user.last_name].join(" ") %></td>
              <td><%= profile.region&.name || "-" %></td>
              <td><%= profile.specialty&.name || "-" %></td>
              <td><%= profile.availability_status.presence || "-" %></td>
              <td><%= profile.rivyr_score_current.nil? ? "-" : profile.rivyr_score_current %></td>
              <td class="text-right">
                <%= link_to "Voir", freelancer_profile_path(profile), class: "btn btn-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-8 text-center space-y-3">
        <p class="text-lg font-medium">Aucun profil freelancer pour le moment</p>
        <%= link_to "Creer le premier profil", new_freelancer_profile_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
  <%= render "shared/pagination", page: @page, total_pages: @total_pages, extra_params: { q: @q, operational_status: @operational_status }, path: ->(params) { freelancer_profiles_path(params) } %>
</div>
