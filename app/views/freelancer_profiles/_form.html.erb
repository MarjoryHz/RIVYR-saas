<%= form_with(model: freelancer_profile, class: "space-y-4") do |f| %>
  <% if freelancer_profile.errors.any? %>
    <div class="alert alert-error">
      <div>
        <p><strong><%= pluralize(freelancer_profile.errors.count, "erreur") %> ont empeche l'enregistrement :</strong></p>
        <ul class="list-disc ml-6 mt-2">
          <% freelancer_profile.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :user_id, "Utilisateur", class: "block font-medium" %>
    <%= f.collection_select :user_id, @users, :id, ->(u) { "#{u.first_name} #{u.last_name} (#{u.email})" }, { prompt: "Selectionner un utilisateur" }, { class: "select select-bordered w-full" } %>
  </div>

  <div class="grid md:grid-cols-2 gap-4">
    <div>
      <%= f.label :region_id, "Region", class: "block font-medium" %>
      <%= f.collection_select :region_id, @regions, :id, :name, { prompt: "Selectionner une region" }, { class: "select select-bordered w-full" } %>
    </div>

    <div>
      <%= f.label :specialty_id, "Specialite", class: "block font-medium" %>
      <%= f.collection_select :specialty_id, @specialties, :id, :name, { prompt: "Selectionner une specialite" }, { class: "select select-bordered w-full" } %>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-4">
    <div>
      <%= f.label :operational_status, "Statut operationnel", class: "block font-medium" %>
      <%= f.text_field :operational_status, class: "input input-bordered w-full" %>
    </div>

    <div>
      <%= f.label :availability_status, "Disponibilite", class: "block font-medium" %>
      <%= f.text_field :availability_status, class: "input input-bordered w-full" %>
    </div>
  </div>

  <div>
    <%= f.label :rivyr_score_current, "Score Rivyr", class: "block font-medium" %>
    <%= f.number_field :rivyr_score_current, min: 0, class: "input input-bordered w-full" %>
  </div>

  <section class="space-y-4 rounded-2xl border border-[#f0d8e0] bg-[#fff9fb] p-4">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">Parametres financiers</p>
      <p class="mt-1 text-sm text-[#7b4b5a]">Ces donnees alimentent les KPI de ton espace finance.</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= f.label :freelance_legal_status, "Statut juridique", class: "block font-medium" %>
        <%= f.select :freelance_legal_status, options_for_select(FreelancerProfile::FREELANCE_LEGAL_STATUSES.map { |key, label| [label, key] }, freelancer_profile.freelance_legal_status), { include_blank: "Selectionner un statut" }, { class: "select select-bordered w-full" } %>
      </div>

      <div>
        <%= f.label :annual_revenue_target_eur, "Objectif annuel (€)", class: "block font-medium" %>
        <%= f.number_field :annual_revenue_target_eur, min: 0, step: 1000, class: "input input-bordered w-full", placeholder: "120000" %>
      </div>
    </div>

    <% month_names = I18n.t("date.abbr_month_names").compact %>
    <div>
      <p class="block font-medium">Objectifs mensuels (€)</p>
      <div class="mt-3 grid gap-3 md:grid-cols-3 xl:grid-cols-4">
        <% (1..12).each do |month_number| %>
          <% month_key = format("%02d", month_number) %>
          <div>
            <label class="mb-1 block text-sm font-medium text-[#7b4b5a]"><%= month_names[month_number - 1] %></label>
            <%= number_field_tag "freelancer_profile[monthly_revenue_targets_eur][#{month_key}]", freelancer_profile.monthly_revenue_targets_eur.to_h[month_key], min: 0, step: 100, class: "input input-bordered w-full", placeholder: "10000" %>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <section class="space-y-4 rounded-2xl border border-[#f0d8e0] bg-[#fff9fb] p-4">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">Coordonnees bancaires</p>
      <p class="mt-1 text-sm text-[#7b4b5a]">Ces comptes sont proposes lors des demandes de paiement.</p>
    </div>

    <div class="grid gap-4 xl:grid-cols-2">
      <% primary_bank_title = freelancer_profile.primary_bank_account_label.presence || "Compte bancaire 1" %>
      <div class="space-y-3 rounded-2xl border border-[#f3dfe5] bg-white px-4 py-4">
        <div>
          <label class="mb-2 flex items-center gap-2 text-sm font-semibold text-[#4c1f2a]">
            <i class="fa-solid fa-pen-to-square text-[#ed0e64]"></i>
            <span>Nom du compte</span>
          </label>
          <%= f.text_field :primary_bank_account_label, value: primary_bank_title, class: "input input-bordered w-full", placeholder: "Compte bancaire 1" %>
        </div>
        <div>
          <p class="text-sm font-semibold text-[#4c1f2a]"><%= primary_bank_title %></p>
        </div>
        <div>
          <%= f.label :primary_bank_iban, "IBAN", class: "block font-medium" %>
          <%= f.text_field :primary_bank_iban, class: "input input-bordered w-full", placeholder: "FR76..." %>
        </div>
        <div>
          <%= f.label :primary_bank_bic, "BIC", class: "block font-medium" %>
          <%= f.text_field :primary_bank_bic, class: "input input-bordered w-full", placeholder: "AGRIFRPP" %>
        </div>
      </div>

      <% secondary_bank_title = freelancer_profile.secondary_bank_account_label.presence || "Compte bancaire 2" %>
      <div class="space-y-3 rounded-2xl border border-[#f3dfe5] bg-white px-4 py-4">
        <div>
          <label class="mb-2 flex items-center gap-2 text-sm font-semibold text-[#4c1f2a]">
            <i class="fa-solid fa-pen-to-square text-[#ed0e64]"></i>
            <span>Nom du compte</span>
          </label>
          <%= f.text_field :secondary_bank_account_label, value: secondary_bank_title, class: "input input-bordered w-full", placeholder: "Compte bancaire 2" %>
        </div>
        <div>
          <p class="text-sm font-semibold text-[#4c1f2a]"><%= secondary_bank_title %></p>
        </div>
        <div>
          <%= f.label :secondary_bank_iban, "IBAN", class: "block font-medium" %>
          <%= f.text_field :secondary_bank_iban, class: "input input-bordered w-full", placeholder: "FR76..." %>
        </div>
        <div>
          <%= f.label :secondary_bank_bic, "BIC", class: "block font-medium" %>
          <%= f.text_field :secondary_bank_bic, class: "input input-bordered w-full", placeholder: "BNPAFRPP" %>
        </div>
      </div>
    </div>
  </section>

  <div>
    <%= f.label :linkedin_url, "LinkedIn", class: "block font-medium" %>
    <%= f.url_field :linkedin_url, class: "input input-bordered w-full" %>
  </div>

  <div>
    <%= f.label :website_url, "Site web", class: "block font-medium" %>
    <%= f.url_field :website_url, class: "input input-bordered w-full" %>
  </div>

  <div>
    <%= f.label :bio, "Bio", class: "block font-medium" %>
    <%= f.text_area :bio, rows: 4, class: "textarea textarea-bordered w-full" %>
  </div>

  <div class="form-control">
    <label class="label cursor-pointer justify-start gap-3">
      <%= f.check_box :profile_private, class: "checkbox" %>
      <span class="label-text">Profil prive</span>
    </label>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Annuler", freelancer_profiles_path, class: "btn" %>
  </div>
<% end %>
