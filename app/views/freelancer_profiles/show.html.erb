<% card = @profile_view[:card] %>

<div class="w-full max-w-none space-y-5 px-6 py-5 md:px-11 lg:px-10">
  <section class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
    <div class="grid gap-4 xl:grid-cols-[2.2fr_1fr]">
      <div class="space-y-4">
        <div class="flex items-start gap-4">
          <%= image_tag card[:avatar_path], alt: card[:name], class: "h-20 w-20 rounded-full object-cover ring-2 ring-[#F7C4DA]" %>
          <div class="space-y-2">
            <div class="flex flex-wrap items-center gap-3">
              <h1 class="text-3xl font-semibold tracking-tight text-[#4c1f2a] md:text-4xl"><%= card[:name] %></h1>
              <span class="rounded-full border border-[#f2c9d8] bg-[#fff1f6] px-4 py-2 text-sm font-semibold text-[#a33d68]">Indice RIVYR <%= card[:rivyr_index] %></span>
            </div>
            <p class="text-lg text-[#6b3f4f]"><%= card[:title] %></p>
            <div class="flex flex-wrap gap-2">
              <% card[:tags].first(3).each do |tag| %>
                <span class="rounded-full border border-[#ead2dc] bg-white px-3 py-1 text-xs font-semibold text-[#6b3f4f]"><%= tag %></span>
              <% end %>
              <span class="rounded-full border border-[#ead2dc] bg-white px-3 py-1 text-xs font-semibold text-[#6b3f4f]">📍 <%= @freelancer_profile.region&.name || "France" %></span>
            </div>
          </div>
        </div>

        <div class="grid gap-3 rounded-2xl border border-[#ead2dc] bg-[#fff8fb]/95 p-3 md:grid-cols-2 xl:grid-cols-4">
          <div><p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Placements realises</p><p class="text-[15px] font-medium text-[#5c3143]"><%= @profile_view[:stats][:placements] %></p></div>
          <div><p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Missions en cours</p><p class="text-[15px] font-medium text-[#5c3143]"><%= @profile_view[:stats][:active_missions] %></p></div>
          <div><p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Entretiens realises</p><p class="text-[15px] font-medium text-[#5c3143]"><%= @profile_view[:stats][:interviews] %></p></div>
          <div><p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Taux de succes</p><p class="text-[15px] font-medium text-[#5c3143]"><%= @profile_view[:stats][:success_rate] %>%</p></div>
        </div>
      </div>

      <aside class="space-y-3">
        <div class="rounded-2xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Disponibilite</p>
          <span class="mt-3 inline-flex items-center gap-2 rounded-full border px-3 py-1 text-sm font-semibold <%= card[:availability][:classes] %>">
            <span><%= card[:availability][:icon] %></span>
            <span><%= card[:availability][:label] %></span>
          </span>
          <div id="contact" class="mt-4">
            <%= link_to "Contacter ce freelance", @freelancer_profile.linkedin_url.presence || @freelancer_profile.website_url.presence || "#", class: "btn w-full rounded-full border-[#ed0e64] bg-[#ed0e64] text-white hover:border-[#cf0c57] hover:bg-[#cf0c57]", target: (@freelancer_profile.linkedin_url.present? || @freelancer_profile.website_url.present?) ? "_blank" : nil, rel: "noopener" %>
          </div>
        </div>

        <div class="rounded-2xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4">
          <h2 class="text-lg font-semibold text-[#5b2633]">Activite RIVYR</h2>
          <div class="mt-3 space-y-3 text-sm text-[#5f3647]">
            <div>
              <div class="mb-1 flex items-center justify-between"><span>Placements</span><span><%= card[:activity][:placements] %>%</span></div>
              <div class="h-2 rounded-full bg-[#f2e9ee]"><div class="h-full rounded-full bg-[#ed0e64]" style="width: <%= card[:activity][:placements] %>%"></div></div>
            </div>
            <div>
              <div class="mb-1 flex items-center justify-between"><span>Participation</span><span><%= card[:activity][:participation] %>%</span></div>
              <div class="h-2 rounded-full bg-[#f2e9ee]"><div class="h-full rounded-full bg-[#d85b8b]" style="width: <%= card[:activity][:participation] %>%"></div></div>
            </div>
            <div>
              <div class="mb-1 flex items-center justify-between"><span>Satisfaction client</span><span><%= card[:activity][:satisfaction] %>%</span></div>
              <div class="h-2 rounded-full bg-[#f2e9ee]"><div class="h-full rounded-full bg-[#7f7ae6]" style="width: <%= card[:activity][:satisfaction] %>%"></div></div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="grid gap-4 xl:grid-cols-[2fr_1fr]">
    <div class="space-y-4">
      <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
        <h2 class="text-2xl font-semibold text-[#5b2633]">Expertise</h2>
        <p class="mt-3 text-[15px] leading-relaxed text-[#5f3647]"><%= @profile_view[:expertise_text] %></p>
      </article>

      <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
        <h2 class="text-2xl font-semibold text-[#5b2633]">Placements recents</h2>
        <ul class="mt-3 space-y-2 text-[15px] text-[#5f3647]">
          <% @profile_view[:recent_placements].each do |placement| %>
            <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#c88ea1]"></span><span><%= placement %></span></li>
          <% end %>
        </ul>
      </article>

      <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
        <h2 class="text-2xl font-semibold text-[#5b2633]">Avis clients</h2>
        <div class="mt-4 space-y-4">
          <% @profile_view[:testimonials].each do |testimonial| %>
            <div class="rounded-2xl border border-[#efdbe4] bg-white/75 p-4">
              <p class="text-lg text-[#ed0e64]">★★★★★</p>
              <p class="mt-2 text-[15px] leading-relaxed text-[#5f3647]"><%= testimonial[:body] %></p>
              <p class="mt-3 text-sm font-semibold text-[#7a5562]"><%= testimonial[:author] %></p>
            </div>
          <% end %>
        </div>
      </article>
    </div>

    <aside class="space-y-4">
      <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
        <h2 class="text-2xl font-semibold text-[#5b2633]">Specialites</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          <% card[:tags].each do |tag| %>
            <span class="rounded-full border border-[#ead2dc] bg-white px-3 py-1 text-xs font-semibold text-[#6b3f4f]"><%= tag %></span>
          <% end %>
        </div>
      </article>

      <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
        <h2 class="text-2xl font-semibold text-[#5b2633]">Experience</h2>
        <ul class="mt-3 space-y-2 text-[15px] text-[#5f3647]">
          <% @profile_view[:experience_points].each do |point| %>
            <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#9bbf9c]"></span><span><%= point %></span></li>
          <% end %>
        </ul>
      </article>

      <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
        <h2 class="text-2xl font-semibold text-[#5b2633]">Coordonnees bancaires</h2>
        <% if @freelancer_profile.bank_accounts.any? %>
          <div class="mt-3 space-y-3">
            <% @freelancer_profile.bank_accounts.each do |account| %>
              <div class="rounded-2xl border border-[#efdbe4] bg-white/75 p-4 text-[15px] text-[#5f3647]">
                <p class="font-semibold text-[#4c1f2a]"><%= account[:label].presence || "Compte bancaire" %></p>
                <p class="mt-1">IBAN: <%= account[:iban].presence || "Non renseigne" %></p>
                <p class="mt-1">BIC: <%= account[:bic].presence || "Non renseigne" %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="mt-3 text-[15px] text-[#5f3647]">Aucune coordonnee bancaire renseignee.</p>
        <% end %>
      </article>

      <% if policy(@freelancer_profile).edit? %>
        <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4">
          <div class="flex flex-wrap gap-2">
            <%= link_to "Modifier", edit_freelancer_profile_path(@freelancer_profile), class: "btn rounded-full border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]" %>
            <% if policy(@freelancer_profile).destroy? %>
              <%= link_to "Supprimer", freelancer_profile_path(@freelancer_profile), data: { turbo_method: :delete, turbo_confirm: "Confirmer la suppression ?" }, class: "btn rounded-full border-[#f2c9d8] bg-[#fff1f6] text-[#a33d68] hover:bg-[#fde7f0]" %>
            <% end %>
          </div>
        </article>
      <% end %>
    </aside>
  </section>
</div>
