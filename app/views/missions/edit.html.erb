<% if current_user.role_freelance? %>
  <div class="mx-auto max-w-7xl p-4 md:p-6">
    <%= render "freelance_mission_wizard", mission: @mission %>
  </div>
<% else %>
  <div class="max-w-4xl mx-auto p-6 space-y-6">
    <h1 class="text-2xl font-bold">Modifier la mission</h1>
    <%= render "form", mission: @mission %>
  </div>
<% end %>
