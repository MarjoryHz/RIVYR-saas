<%
  surface_card_class = "rounded-[1.8rem] border border-[#ead2dc] bg-[#fff8fb]/95 shadow-[0_22px_45px_rgba(100,37,56,0.08)]"
  soft_card_class = "rounded-[1.5rem] border border-[#efdbe4] bg-white/80"
  stats_conversion = @dashboard_performance[:conversion_rate].to_i.clamp(0, 100)
  resumes_envoyes = @dashboard_missions.sum { |item| item[:presented_candidates].to_i }
  entretiens_realises = @dashboard_pipeline[:interviews].to_i
  missions_reussies = @dashboard_performance[:won_missions].to_i
  agenda_items = Array(@dashboard_week_schedule).first(3)
  todo_preview = Array(@dashboard_todo_preview)
  feed_preview = Array(@dashboard_feed_preview).presence || Array(@dashboard_rivyr_feed).first(2).map do |item|
    {
      title: item[:message],
      author: "RIVYR",
      role: "Signal du réseau",
      time: distance_of_time_in_words_to_now(item[:date]),
      avatar: "avatars/avatar-05.png",
      likes: 0,
      comments: 0
    }
  end
  invoice_chart_points = Array(@dashboard_invoice_snapshot[:trend_points]).each_with_index.map do |value, index|
    x = 10 + (index * 42)
    y = 66 - (value.to_f * 42)
    "#{x},#{y.round(1)}"
  end.join(" ")
%>

<div class="w-full max-w-none space-y-6 px-6 py-5 md:px-11 lg:px-10">
  <section class="relative overflow-hidden">
    <div class="relative">
      <section class="space-y-6">
        <div class="space-y-3">
          <h1 class="text-4xl font-semibold tracking-tight text-[#4c1f2a] md:text-5xl">Bonjour <%= @dashboard_greeting_name %> !</h1>
          <p class="max-w-2xl text-lg text-[#6b3f4f] md:text-xl">
            Prête à décrocher de nouvelles missions aujourd’hui ?
          </p>
        </div>

        <div class="grid gap-4 xl:grid-cols-[minmax(0,1.05fr)] xl:max-w-[52rem]">
          <div class="grid min-w-0 overflow-hidden rounded-[1.45rem] border border-[#efdbe4] bg-white/82 shadow-[0_16px_35px_rgba(100,37,56,0.06)] md:grid-cols-3">
            <div class="p-4 md:border-r md:border-[#f0dce4] md:pr-6">
              <p class="text-3xl font-semibold text-[#4c1f2a]"><%= number_to_currency(@total_potential_cents.to_i / 100.0, unit: "€", precision: 0) %></p>
              <p class="mt-1 text-base text-[#6b3f4f]/80">Potentiel total</p>
            </div>
            <div class="p-4 md:border-r md:border-[#f0dce4] md:px-6">
              <p class="text-3xl font-semibold text-[#4c1f2a]"><%= @average_open_days.to_i %> jours</p>
              <p class="mt-1 text-base text-[#6b3f4f]/80">Ouverture moyenne</p>
            </div>
            <div class="p-4 md:px-6">
              <p class="text-3xl font-semibold text-[#4c1f2a]"><%= @total_sent_candidates.to_i %></p>
              <p class="mt-1 text-base text-[#6b3f4f]/80">Candidats chez le client</p>
            </div>
          </div>

        </div>
      </section>
    </div>
  </section>

  <section class="grid gap-5" style="grid-template-columns: minmax(360px,1.02fr) minmax(340px,0.85fr) minmax(340px,0.96fr); grid-template-rows: 1fr auto 1fr; min-height: 900px">
    <section class="<%= surface_card_class %> p-5">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-[#fff2f7] text-[#f08d72]">
            <i class="fa-solid fa-gift text-lg"></i>
          </span>
          <h2 class="text-2xl font-semibold text-[#5b2633]">Missions suggérées</h2>
        </div>
        <%= link_to "Tout", dashboard_library_missions_path(status: "open"), class: "text-sm font-medium text-[#9a5a68]" %>
      </div>

      <div class="mt-5">
        <% if @dashboard_recommended_missions.any? %>
          <div class="carousel w-full">
            <% @dashboard_recommended_missions.each_with_index do |item, index| %>
              <% mission = item[:mission] %>
              <% slide_id = "dashboard-suggestion-item-#{index + 1}" %>
              <div id="<%= slide_id %>" class="carousel-item w-full">
                <div class="w-full">
                  <%= render "missions/suggestion_card",
                    mission: mission,
                    dom_id_suffix: "dashboard",
                    compact: false %>
                </div>
              </div>
            <% end %>
          </div>

          <% if @dashboard_recommended_missions.size > 1 %>
            <div class="flex w-full justify-center gap-2 py-3">
              <% @dashboard_recommended_missions.each_with_index do |_item, index| %>
                <button
                  type="button"
                  onclick="document.getElementById('dashboard-suggestion-item-<%= index + 1 %>').scrollIntoView({behavior:'smooth',block:'nearest',inline:'start'})"
                  class="btn btn-xs h-8 min-h-0 w-8 rounded-full border border-[#efdbe4] bg-white/85 px-0 text-[#8f4a58] shadow-sm hover:border-[#ed0e64] hover:bg-[#fff2f7] hover:text-[#ed0e64]">
                  <%= index + 1 %>
                </button>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <p class="rounded-2xl border border-[#efdbe4] bg-white/80 px-4 py-3 text-sm text-[#8a5b6a]">
            Aucune mission suggérée pour le moment.
          </p>
        <% end %>
      </div>
    </section>

    <%= link_to dashboard_my_missions_path, class: "#{surface_card_class} block p-5 transition hover:bg-white", style: "grid-column: span 2" do %>
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-[#fff2f7] text-[#f08d72]">
            <i class="fa-solid fa-users-viewfinder text-lg"></i>
          </span>
          <h2 class="text-2xl font-semibold text-[#5b2633]">Missions en cours</h2>
        </div>
        <span class="text-sm font-medium text-[#9a5a68]">Tout</span>
      </div>

      <div class="mt-5 space-y-3 max-h-112 overflow-y-auto pr-1">
        <% @dashboard_missions.each do |item| %>
          <article class="rounded-[1.35rem] border <%= item[:urgent] ? 'border-[#f2a0a0] bg-[#fff5f5]' : 'border-[#efdbe4] bg-white/80' %> px-4 py-3">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <p class="truncate text-[1.1rem] font-semibold text-[#4c1f2a]"><%= item[:mission].title %></p>
                  <% if item[:urgent] %>
                    <span class="shrink-0 inline-flex items-center gap-1 rounded-full bg-[#7f2f2a] px-2 py-0.5 text-[10px] font-semibold text-white">
                      <i class="fa-solid fa-bolt text-[9px]"></i> Urgent
                    </span>
                  <% end %>
                </div>
                <p class="mt-1 truncate text-sm text-[#8a5b6a]"><%= item[:company_name] %> · <%= item[:location] %></p>
              </div>
              <span class="rounded-full border px-3 py-1 text-sm font-semibold <%= item[:stage_classes] %>"><%= item[:stage] %></span>
            </div>
            <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-[#7a5562]">
              <span><i class="fa-regular fa-user mr-1 text-[#ed0e64]"></i><%= item[:presented_candidates] %> candidats</span>
              <span><i class="fa-regular fa-clock mr-1 text-[#ed0e64]"></i><%= item[:next_event] %></span>
            </div>
          </article>
        <% end %>
      </div>
    <% end %>

    <%= link_to dashboard_feed_path, class: "#{surface_card_class} block p-4 transition hover:bg-white", style: "grid-column: span 3" do %>
      <div class="flex items-center gap-4">
        <div class="flex shrink-0 items-center gap-2 text-[#5b2633]">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-[#fff2f7] text-[#ed7a9d]">
            <i class="fa-solid fa-newspaper text-sm"></i>
          </span>
          <span class="text-base font-semibold">Fil d'actualités</span>
        </div>
        <div class="mx-2 h-5 w-px shrink-0 bg-[#efdbe4]"></div>
        <div class="flex min-w-0 flex-1 gap-4 overflow-hidden">
          <% feed_preview.each do |item| %>
            <div class="flex min-w-0 flex-1 items-center gap-3">
              <div class="h-9 w-9 shrink-0 overflow-hidden rounded-xl bg-[#f7e4eb]">
                <%= image_tag item[:avatar], alt: item[:author], class: "h-full w-full object-cover" %>
              </div>
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-[#4c1f2a]"><%= item[:title] %></p>
                <p class="text-xs text-[#8a5b6a]"><%= item[:author] %> · <%= item[:time] %></p>
              </div>
            </div>
          <% end %>
        </div>
        <i class="fa-solid fa-chevron-right shrink-0 text-xs text-[#d9a4b7]"></i>
      </div>
    <% end %>

    <section class="<%= surface_card_class %> p-5">
      <div class="flex items-center gap-3">
        <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-[#fff2f7] text-[#ed0e64]">
          <i class="fa-regular fa-calendar-days text-lg"></i>
        </span>
        <h2 class="text-2xl font-semibold text-[#5b2633]">Agenda</h2>
      </div>

      <div class="mt-5 space-y-3 overflow-y-auto pr-1" style="max-height: calc(100% - 4rem)">
        <% agenda_items.each do |item| %>
          <article class="rounded-[1.2rem] border border-[#efdbe4] bg-white/80 px-4 py-3">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="truncate text-base font-semibold text-[#4c1f2a]"><%= item[:title] %></p>
                <p class="mt-1 text-sm text-[#8a5b6a]"><%= item[:detail] %></p>
              </div>
              <span class="shrink-0 rounded-full bg-[#fff2f7] px-2.5 py-1 text-xs font-semibold text-[#ed0e64]"><%= item[:when_label] %></span>
            </div>
          </article>
        <% end %>
        <% if agenda_items.empty? %>
          <p class="rounded-[1.2rem] border border-[#efdbe4] bg-white/80 px-4 py-3 text-sm text-[#8a5b6a]">
            Aucun rendez-vous planifié pour le moment.
          </p>
        <% end %>
      </div>
    </section>

    <section class="<%= surface_card_class %> p-5" style="grid-column: span 2">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-[#fff2f7] text-[#ed7a9d]">
            <i class="fa-solid fa-square-check text-lg"></i>
          </span>
          <h2 class="text-2xl font-semibold text-[#5b2633]">Ma To-Do List</h2>
        </div>
        <%= link_to dashboard_todo_list_path, class: "inline-flex h-8 w-8 items-center justify-center rounded-full bg-[#fff2f7] text-[#a15c70] hover:bg-[#ffe4ef] hover:text-[#ed0e64]" do %>
          <i class="fa-solid fa-plus text-sm"></i>
        <% end %>
      </div>

      <%= turbo_frame_tag "dashboard-todo-list" do %>
        <div class="mt-5 space-y-3 max-h-56 overflow-y-auto pr-1">
          <% priority_styles = { "high" => "border-[#f2a0a0] bg-[#fff5f5]", "medium" => "border-[#f2dda0] bg-[#fffdf0]", "low" => "border-[#efdbe4] bg-white/80" } %>
          <% priority_dot = { "high" => "bg-[#e53e3e]", "medium" => "bg-[#d97706]", "low" => "bg-[#9ca3af]" } %>
          <% todo_preview.each do |task| %>
            <div class="flex items-start gap-3 rounded-2xl border px-4 py-3 <%= task[:done] ? 'border-[#efdbe4] bg-white/80' : priority_styles[task[:priority]] %>">
              <%= form_with url: todo_task_path(task[:id]), method: :patch, data: { turbo_frame: "dashboard-todo-list" } do %>
                <input type="hidden" name="todo_task[status]" value="<%= task[:done] ? 'todo' : 'done' %>">
                <input type="hidden" name="return_to" value="<%= dashboard_path %>">
                <button type="submit" class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center text-[#ed0e64] hover:opacity-70">
                  <i class="fa-<%= task[:done] ? 'solid fa-circle-check' : 'regular fa-circle' %> text-lg"></i>
                </button>
              <% end %>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <% unless task[:done] %>
                    <span class="h-2 w-2 shrink-0 rounded-full <%= priority_dot[task[:priority]] %>"></span>
                  <% end %>
                  <p class="truncate text-base font-semibold <%= task[:done] ? 'line-through text-[#b08a96]' : 'text-[#4c1f2a]' %>"><%= task[:title] %></p>
                </div>
                <p class="mt-1 text-sm text-[#8a5b6a]"><%= task[:category] %><%= " · #{task[:due_label]}" if task[:due_label].present? %></p>
              </div>
            </div>
          <% end %>
          <% if todo_preview.empty? %>
            <p class="rounded-2xl border border-[#efdbe4] bg-white/80 px-4 py-3 text-sm text-[#8a5b6a]">Aucune tâche pour le moment.</p>
          <% end %>
        </div>
      <% end %>

      <div class="mt-4 flex justify-end border-t border-[#f0dce4] pt-3">
        <%= link_to "Tout", dashboard_todo_list_path, class: "text-sm font-medium text-[#9a5a68] hover:text-[#ed0e64]" %>
      </div>
    </section>

  </section>
</div>
