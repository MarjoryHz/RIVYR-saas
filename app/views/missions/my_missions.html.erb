<%
  surface_card_class = "rounded-[1.45rem] border border-base-100/70 bg-base-100/88 shadow-lg"
  current_tab_class = @tab == "current" ? "bg-[#f4a58a] font-semibold text-white" : "font-medium text-base-content/75 transition hover:text-base-content"
  drafts_tab_class = @tab == "drafts" ? "bg-[#f4a58a] font-semibold text-white" : "font-medium text-base-content/75 transition hover:text-base-content"
  refused_tab_class = @tab == "refused" ? "bg-[#f4a58a] font-semibold text-white" : "font-medium text-base-content/75 transition hover:text-base-content"
  closed_tab_class = @tab == "closed" ? "bg-[#f4a58a] font-semibold text-white" : "font-medium text-base-content/75 transition hover:text-base-content"
%>

<div class="mx-auto max-w-7xl p-4 md:p-6">
  <section class="space-y-6">
    <div class="missions-summary-sticky">
      <header class="space-y-5">
        <div class="space-y-5">
          <div class="space-y-2">
            <h1 class="text-3xl font-semibold tracking-tight text-base-content md:text-4xl">Mes missions</h1>
          </div>

          <div class="inline-flex flex-wrap items-center rounded-full border border-base-200/80 bg-base-100/72 p-1 text-[#7f5260] shadow-sm">
            <%= link_to my_missions_missions_path, class: "inline-flex items-center rounded-full px-7 py-3 text-base #{current_tab_class}" do %>
              En cours (<%= @current_missions_count %>)
            <% end %>
            <%= link_to my_missions_missions_path(tab: "drafts"), class: "inline-flex items-center rounded-full px-6 py-3 text-base #{drafts_tab_class}" do %>
              Brouillons (<%= @draft_missions_count.to_i %>)
            <% end %>
            <%= link_to pending_missions_missions_path, class: "px-6 py-3 text-base font-medium text-base-content/75 transition hover:text-base-content" do %>
              En attente de validation (<%= @pending_validation_count.to_i %>)
            <% end %>
            <%= link_to my_missions_missions_path(tab: "refused"), class: "inline-flex items-center rounded-full px-6 py-3 text-base #{refused_tab_class}" do %>
              RefusГ©es (<%= @rejected_missions_count.to_i %>)
            <% end %>
            <span class="text-base-content/20">|</span>
            <%= link_to my_missions_missions_path(tab: "closed"), class: "inline-flex items-center rounded-full px-6 py-3 text-base #{closed_tab_class}" do %>
              TerminГ©es (<%= @closed_missions_count.to_i %>)
            <% end %>
          </div>

          <div class="grid min-w-0 overflow-hidden md:grid-cols-3 <%= surface_card_class %>">
            <div class="p-4 md:border-r md:border-base-200/80 md:pr-6">
              <% if @tab == "drafts" %>
                <p class="text-3xl font-semibold text-base-content"><%= @draft_missions_count.to_i %></p>
                <p class="mt-1 text-base text-base-content/60">Brouillons enregistrГ©s</p>
              <% elsif @tab == "refused" %>
                <p class="text-3xl font-semibold text-base-content"><%= number_to_currency(@rejected_total_potential_cents / 100.0, unit: "в‚¬", precision: 0) %></p>
                <p class="mt-1 text-base text-base-content/60">Potentiel refusГ©</p>
              <% else %>
                <p class="text-3xl font-semibold text-base-content"><%= number_to_currency((@tab == "closed" ? @closed_total_potential_cents : @total_potential_cents) / 100.0, unit: "в‚¬", precision: 0) %></p>
                <p class="mt-1 text-base text-base-content/60"><%= @tab == "closed" ? "Potentiel archivГ©" : "Potentiel total" %></p>
              <% end %>
            </div>
            <div class="p-4 md:border-r md:border-base-200/80 md:px-6">
              <% if @tab == "drafts" %>
                <p class="text-3xl font-semibold text-base-content"><%= @draft_last_updated_label.present? ? l(@draft_last_updated_label, format: "%d/%m") : "-" %></p>
                <p class="mt-1 text-base text-base-content/60">DerniГЁre sauvegarde</p>
              <% elsif @tab == "refused" %>
                <p class="text-3xl font-semibold text-base-content"><%= @rejected_average_days %> jours</p>
                <p class="mt-1 text-base text-base-content/60">DГ©lai moyen avant refus</p>
              <% else %>
                <p class="text-3xl font-semibold text-base-content"><%= @tab == "closed" ? @closed_average_open_days : @average_open_days %> jours</p>
                <p class="mt-1 text-base text-base-content/60"><%= @tab == "closed" ? "DurГ©e moyenne avant clГґture" : "Ouverture moyenne" %></p>
              <% end %>
            </div>
            <div class="p-4 md:px-6">
              <% if @tab == "drafts" %>
                <p class="text-3xl font-semibold text-base-content"><%= @draft_mission_rows.count { |row| row[:company_name] != "Entreprise Г  dГ©finir" } %></p>
                <p class="mt-1 text-base text-base-content/60">Entreprises renseignГ©es</p>
              <% elsif @tab == "refused" %>
                <p class="text-3xl font-semibold text-base-content"><%= @rejected_total_candidates %></p>
                <p class="mt-1 text-base text-base-content/60">Candidats prГ©sentГ©s</p>
              <% else %>
                <p class="text-3xl font-semibold text-base-content"><%= @tab == "closed" ? @closed_total_sent_candidates : @total_sent_candidates %></p>
                <p class="mt-1 text-base text-base-content/60">Candidats chez le client</p>
              <% end %>
            </div>
          </div>
        </div>
      </header>
    </div>

    <div class="missions-content-scroll space-y-6">
      <div class="<%= surface_card_class %> overflow-hidden">
        <div class="border-b border-base-200/70 px-6 py-4">
          <div class="relative">
            <div class="flex flex-wrap gap-3">
              <button
                type="button"
                class="inline-flex items-center gap-2 rounded-2xl border border-base-200 bg-base-100/75 px-5 py-3 text-base font-medium text-base-content/70 shadow-sm transition hover:bg-base-100/95"
                aria-controls="missions-filtres"
                aria-expanded="false"
                onclick="document.getElementById('missions-filtres').classList.toggle('hidden'); this.setAttribute('aria-expanded', String(!document.getElementById('missions-filtres').classList.contains('hidden')));">
                <i class="fa-solid fa-sliders text-[#ed0e64]"></i>
                Filtres
                <i class="fa-solid fa-angle-down text-xs text-[#ed0e64]"></i>
              </button>

              <%= link_to new_mission_path, target: "_blank", rel: "noopener", class: "inline-flex items-center gap-2 rounded-full border border-[#f1a38b] bg-[#f4a58a] px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:border-[#e39479] hover:bg-[#ee977c]" do %>
                <i class="fa-solid fa-plus text-[#ed0e64]"></i>
                CrГ©er une mission
              <% end %>
            </div>

            <div id="missions-filtres" class="absolute inset-x-0 top-full z-30 mt-3 hidden rounded-[1.45rem] border border-base-200 bg-base-100 p-4 shadow-xl">
              <%= form_with url: my_missions_missions_path, method: :get, class: "grid gap-3 md:grid-cols-2 xl:grid-cols-5", html: { onsubmit: "document.getElementById('missions-filtres').classList.add('hidden')" } do %>
                <% if @tab == "closed" %>
                  <%= hidden_field_tag :tab, "closed" %>
                <% elsif @tab == "refused" %>
                  <%= hidden_field_tag :tab, "refused" %>
                <% elsif @tab == "drafts" %>
                  <%= hidden_field_tag :tab, "drafts" %>
                <% end %>
                <div>
                  <label for="amount-filter" class="mb-1 block text-sm font-medium text-base-content/70">Montant</label>
                  <%= select_tag :amount,
                    options_for_select(
                      [
                        ["Tous les montants", ""],
                        ["Moins de 5 000 в‚¬", "under_5000"],
                        ["5 000 в‚¬ Г  10 000 в‚¬", "5000_10000"],
                        ["10 000 в‚¬ Г  20 000 в‚¬", "10000_20000"],
                        ["Plus de 20 000 в‚¬", "over_20000"]
                      ],
                      @amount_filter
                    ),
                    id: "amount-filter",
                    class: "select select-bordered w-full" %>
                </div>

                <div>
                  <label for="region-filter" class="mb-1 block text-sm font-medium text-base-content/70">Ville</label>
                  <%= select_tag :region,
                    options_for_select([["Toutes les villes", ""]] + @region_options.map { |region| [region, region] }, @region_filter),
                    id: "region-filter",
                    class: "select select-bordered w-full" %>
                </div>

                <div>
                  <label for="urgent-filter" class="mb-1 block text-sm font-medium text-base-content/70">Urgence</label>
                  <%= select_tag :urgent,
                    options_for_select([["Toutes", ""], ["Urgentes", "urgent"], ["Non urgentes", "normal"]], @urgent_filter),
                    id: "urgent-filter",
                    class: "select select-bordered w-full" %>
                </div>

                <div>
                  <label for="company-filter" class="mb-1 block text-sm font-medium text-base-content/70">SociГ©tГ©</label>
                  <%= select_tag :company,
                    options_for_select([["Toutes les sociГ©tГ©s", ""]] + @company_options.map { |company| [company, company] }, @company_filter),
                    id: "company-filter",
                    class: "select select-bordered w-full" %>
                </div>

                <div class="flex items-end gap-2">
                  <%= submit_tag "Appliquer", class: "btn btn-primary flex-1" %>
                  <%= link_to "RГ©initialiser", my_missions_missions_path(tab: (@tab.in?(%w[closed drafts refused]) ? @tab : nil)), class: "btn btn-ghost" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <% rows = case @tab
                 when "drafts" then @draft_mission_rows
                 when "refused" then @rejected_mission_rows
                 when "closed" then @closed_mission_rows
                 else @mission_rows
                 end %>
        <% if rows.any? %>
          <div class="divide-y divide-base-200/70">
            <% rows.each do |row| %>
              <% mission = row[:mission] %>
              <article class="px-6 py-5">
                <div class="space-y-4">
                  <div class="grid items-center gap-4 xl:grid-cols-[minmax(0,1fr)_auto]">
                    <div class="min-w-0 flex items-center gap-3">
                      <h2 class="min-w-0 truncate whitespace-nowrap text-xl font-semibold leading-tight text-base-content md:text-2xl"><%= @tab == "drafts" ? row[:title] : mission.title %></h2>
                      <% if mission.region.present? %>
                        <span class="shrink-0 text-base-content/30">|</span>
                        <span class="shrink-0 whitespace-nowrap text-sm font-medium text-base-content/55 md:text-base"><%= mission.region.name %></span>
                      <% end %>
                    </div>

                    <% if @tab == "drafts" %>
                      <div class="flex flex-wrap items-center justify-self-end gap-3">
                        <span class="inline-flex items-center rounded-full border border-[#e8c6d3] bg-[#fff3f8] px-4 py-2 text-sm font-semibold text-[#a33d68]">
                          Brouillon
                        </span>
                        <span class="text-sm font-medium text-base-content/55">
                          SauvegardГ© le <%= l(row[:updated_at], format: :default) rescue row[:updated_at].strftime("%d/%m/%Y") %>
                        </span>
                      </div>
                    <% elsif @tab == "closed" %>
                      <div class="flex flex-wrap items-center justify-self-end gap-3">
                        <%= render "missions/origin_badge", mission: mission %>
                        <span class="inline-flex items-center rounded-full border px-4 py-2 text-sm font-semibold <%= row[:closed_badge_class] %>">
                          <%= row[:closed_label] %>
                        </span>
                        <span class="text-sm font-medium text-base-content/55">
                          ArchivГ©e le <%= l(row[:archived_at], format: :default) rescue row[:archived_at].strftime("%d/%m/%Y") %>
                        </span>
                      </div>
                    <% elsif @tab == "refused" %>
                      <div class="flex flex-wrap items-center justify-self-end gap-3">
                        <%= render "missions/origin_badge", mission: mission %>
                        <span class="relative inline-flex group">
                          <span class="inline-flex items-center rounded-full border border-[#f1c9d3] bg-[#fff1f4] px-4 py-2 text-sm font-semibold text-[#b14360]">
                            Candidature non retenue par RIVYR.
                          </span>
                          <span class="pointer-events-none absolute right-0 top-full z-20 mt-2 hidden min-w-[260px] max-w-[360px] rounded-xl border border-[#f1c9d3] bg-white px-3 py-2 text-sm text-[#6b3f4f] shadow-lg group-hover:block">
                            <span class="block text-[11px] font-semibold uppercase tracking-[0.16em] text-[#a15c70]">Motif du refus</span>
                            <span class="mt-1 block"><%= row[:review_reason].presence || "Refus remontГ© par l'Г©quipe Rivyr." %></span>
                          </span>
                        </span>
                        <span class="text-sm font-medium text-base-content/55">
                          RefusГ©e le <%= l(row[:rejected_at], format: :default) rescue row[:rejected_at].strftime("%d/%m/%Y") %>
                        </span>
                      </div>
                    <% else %>
                      <div class="flex flex-wrap items-center justify-self-end gap-3">
                        <%= render "missions/origin_badge", mission: mission %>
                        <ul class="steps steps-horizontal text-xs md:text-sm">
                          <% row[:recruitment_steps].each_with_index do |step, index| %>
                            <li class="step <%= 'step-primary' if step[:done] %>" data-content="<%= index + 1 %>"><%= step[:label] %></li>
                          <% end %>
                        </ul>

                        <span class="text-sm font-medium <%= row[:open_days_tone] %>">
                          <%= row[:open_days] %> jours
                        </span>

                        <%= form_with url: toggle_freelance_urgent_mission_path(mission), method: :patch, local: true do |form| %>
                          <label class="<%= row[:urgent] ? 'border-[#ed0e64] bg-[#ed0e64] text-white' : 'border-[#f3c1d4] bg-[#ffe3ed] text-[#8c5665]' %> inline-flex items-center gap-2 rounded-full border px-3 py-1.5 shadow-sm transition">
                            <%= form.check_box :urgent,
                              {
                                checked: row[:urgent],
                                class: "toggle toggle-sm border-white/70 bg-white/35 text-white [--tglbg:#ffffff] checked:border-white checked:bg-white/25 checked:text-[#ed0e64]",
                                onchange: "this.form.requestSubmit()"
                              },
                              "true",
                              "false" %>
                            <span class="text-sm font-semibold">Urgent</span>
                          </label>
                        <% end %>
                      </div>
                    <% end %>
                  </div>

                  <div class="grid gap-4 xl:grid-cols-[minmax(0,1.1fr)_auto] xl:items-center">
                    <div class="flex min-h-[3.25rem] items-center gap-4 text-base text-base-content/75">
                      <% if @tab != "drafts" && row[:company_logo].present? %>
                        <div class="flex h-12 w-12 items-center justify-center overflow-hidden rounded-full border border-base-200 bg-base-100">
                          <%= image_tag client_logo_src(row[:company_logo]), alt: row[:company_name], class: "h-full w-full object-cover" %>
                        </div>
                      <% else %>
                        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/18 text-[#ed0e64]">
                          <i class="fa-regular fa-building text-lg"></i>
                        </div>
                      <% end %>

                      <div class="space-y-1">
                        <p class="font-medium text-base-content"><%= row[:company_name] %></p>
                        <p class="text-sm text-base-content/55"><%= row[:client_contact_name].presence || "Contact client" %></p>
                      </div>
                    </div>

                    <div class="flex flex-wrap items-center gap-3 xl:justify-end">
                      <% if @tab == "drafts" %>
                        <%= link_to edit_mission_path(mission), target: "_blank", rel: "noopener", class: "inline-flex min-w-[14rem] items-center justify-center rounded-full border border-[#f1a38b] bg-[#f4a58a] px-6 py-2.5 text-base font-semibold text-white shadow-sm transition hover:border-[#e39479] hover:bg-[#ee977c]" do %>
                          Reprendre le brouillon
                        <% end %>
                      <% else %>
                        <p class="min-w-[8rem] text-xl font-semibold md:text-2xl xl:text-right"><%= number_to_currency(row[:potential_cents] / 100.0, unit: "в‚¬", precision: 0) %></p>
                      <% end %>

                      <% if @tab == "current" %>
                        <button type="button" class="inline-flex min-w-[12rem] items-center justify-center gap-2 rounded-full border border-[#f6d6db] bg-[#ffe8ec] px-4 py-2.5 text-sm font-medium text-[#8c5665]">
                          <i class="fa-regular fa-comment-dots text-[#ed0e64]"></i>
                          Envoyer un candidat
                        </button>

                        <button type="button" class="inline-flex min-w-[14rem] items-center justify-center gap-2 rounded-full border border-[#ead7dc] bg-base-100/82 px-4 py-2.5 text-sm font-medium text-[#8c5665]">
                          Suivre <%= row[:sent_candidates_count] %> candidats envoyГ©s
                        </button>
                      <% elsif @tab == "refused" %>
                        <div class="min-w-[14rem] rounded-[1.1rem] border border-[#f2d5db] bg-[#fff7f9] px-4 py-3 text-sm text-[#8c5665]">
                          <p class="font-medium text-[#6d4050]">Survole le statut de refus pour voir le motif dГ©taillГ©.</p>
                        </div>
                      <% end %>

                      <% unless @tab == "drafts" %>
                        <%= link_to mission_path(mission), class: "inline-flex min-w-[11rem] items-center justify-center rounded-full border border-[#f1a38b] bg-[#f4a58a] px-6 py-2.5 text-base font-semibold text-white shadow-sm transition hover:border-[#e39479] hover:bg-[#ee977c]" do %>
                          Voir la mission
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="p-8 text-center text-base-content/65">
            <%= @tab == "closed" ? "Aucune mission terminГ©e pour le moment." : (@tab == "drafts" ? "Aucun brouillon pour le moment." : (@tab == "refused" ? "Aucune mission refusГ©e pour le moment." : "Aucune mission en cours pour le moment.")) %>
          </div>
        <% end %>
      </div>
    </div>
  </section>
</div>
