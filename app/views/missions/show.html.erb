<% origin_badge = mission_origin_badge(@mission) %>
<% client = @mission.client_contact.client %>
<% client_name = client.brand_name.presence || client.legal_name %>
<% contact_name = [@mission.client_contact.first_name, @mission.client_contact.last_name].compact.join(" ") %>
<% freelancer_name = [@mission.freelancer_profile.user.first_name, @mission.freelancer_profile.user.last_name].compact.join(" ") %>
<% fee_breakdown = mission_fee_breakdown_for(@mission) %>
<% current_application = current_user&.role_freelance? ? current_user.freelancer_profile&.freelance_mission_applications&.find_by(mission_id: @mission.id) : nil %>
<% already_applied = current_application.present? %>
<% positioned_count = FreelanceMissionApplication.where(mission_id: @mission.id).count %>
<% presented_count = Candidate.joins(:placements).where(placements: { mission_id: @mission.id }).distinct.count %>
<% mission_assigned = @mission.freelancer_profile.user.role != "admin" %>
<% freelance_origin_mission = @mission.origin_type.to_s == "freelancer" %>
<% client_visible = mission_assigned || policy(@mission).view_client_identity? %>
<% masked_client = "************" %>
<% masked_sector = "********" %>
<% freelance_owns_assigned_mission = current_user&.role_freelance? && @mission.freelancer_profile_id == current_user.freelancer_profile&.id %>
<% freelance_created_mission = freelance_owns_assigned_mission && @mission.origin_type.to_s == "freelancer" %>
<% mission_placed = mission_placed?(@mission) %>
<% placed_candidate = mission_placed ? @mission.placement&.candidate : nil %>
<% closure_reason_options = [
  "Mission gagnee",
  "Le client a recruté par ses propres moyens",
  "Le client ferme le recrutement",
  "Aucun retour du client",
  "Je ne souhaite plus travailler la mission"
] %>

<%
  parse_meta = lambda do |raw|
    raw.to_s.split("||").each_with_object({}) do |chunk, hash|
      key, value = chunk.split("=", 2)
      next if key.blank? || value.blank?

      hash[key.strip] = value.strip
    end
  end

  to_list = lambda do |value|
    value.to_s.split(";").map { |item| item.to_s.strip }.reject(&:blank?)
  end

  brief_meta = parse_meta.call(@mission.brief_summary)
  search_meta = parse_meta.call(@mission.search_constraints)

  why_items = to_list.call(brief_meta["why"])
  enjeux_items = to_list.call(brief_meta["enjeux"])
  mission_items = to_list.call(search_meta["details"])
  must_have_items = to_list.call(search_meta["must_have"])
  nice_to_have_items = to_list.call(search_meta["nice_to_have"])
  advantage_items = to_list.call(search_meta["advantages"])
  resources_items = to_list.call(search_meta["resources"])
  constraints_items = to_list.call(search_meta["constraints"])
  industrial_bu_role = @mission.title.to_s.casecmp("Directeur de Business Unit Industrie").zero?

  why_items = [ brief_meta["context"].presence || "Contexte non renseigne." ] if why_items.empty?
  enjeux_items = [ "Structurer l execution", "Securiser le delivery", "Ameliorer la performance" ] if enjeux_items.empty?
  mission_items = [ @mission.search_constraints.to_s.presence || "Mission non renseignee." ] if mission_items.empty?
  must_have_items = [ search_meta["profil"].presence || "Experience comparable obligatoire" ] if must_have_items.empty?
  nice_to_have_items = [ "Transformation d organisation", "Leadership transverse" ] if nice_to_have_items.empty?
  advantage_items = [ "13eme mois", "Tickets restaurants", "Voiture de fonction" ] if advantage_items.empty?
  resources_items = [ "Job description complete", "Presentation entreprise" ] if resources_items.empty?
  constraints_items = [ "Mobilite", "Disponibilite", "Niveau de package" ] if constraints_items.empty?

  if industrial_bu_role
    brief_meta["creation_or_replacement"] = "Creation de poste dans le cadre d une nouvelle phase de croissance" if brief_meta["creation_or_replacement"].blank?
    brief_meta["client_context"] = "ETI industrielle multi-sites en phase d acceleration, avec un enjeu fort de structuration de la business unit" if brief_meta["client_context"].blank?
    brief_meta["business"] = "La direction souhaite renforcer le pilotage du P&L, fiabiliser l execution operationnelle et accelerer le developpement commercial sur des comptes industriels strategiques." if brief_meta["business"].blank?
    brief_meta["organisation"] = "La business unit regroupe les equipes commerce, projets, operations et service client, avec un management direct des responsables de pole." if brief_meta["organisation"].blank?
    brief_meta["org_position"] = "Rattachement direct a la direction generale avec forte exposition au comite de direction." if brief_meta["org_position"].blank?

    mission_items = [
      "Prendre la responsabilite complete du P&L de la business unit et construire la trajectoire de croissance a 3 ans.",
      "Piloter les equipes commerce, operations, projets et support afin d aligner execution terrain et ambitions de rentabilite.",
      "Structurer la gouvernance de la BU avec des rituels de pilotage, des KPI clairs et un suivi fin de la marge par activite.",
      "Securiser la performance industrielle en coordination avec les sites, notamment sur les sujets qualite, delais et productivite.",
      "Developper le portefeuille clients existant et ouvrir de nouveaux relais de croissance sur des comptes cibles.",
      "Manager et faire monter en puissance les responsables d equipe pour renforcer l autonomie et la responsabilisation de la ligne managériale.",
      "Porter les arbitrages d investissement, de capacite et d organisation avec une forte orientation resultat."
    ]

    enjeux_items = [
      "Remettre la business unit sur une trajectoire de croissance rentable avec une ambition claire de progression de marge.",
      "Reprendre le pilotage commercial de plusieurs comptes industriels strategiques et renforcer la qualite de l execution client.",
      "Harmoniser les pratiques entre les differents sites ou poles pour gagner en lisibilite, en productivite et en fiabilite.",
      "Stabiliser l organisation managériale et clarifier les responsabilites sur les sujets commerce, delivery et performance.",
      "Construire un plan de transformation concret autour des outils de pilotage, de la culture de resultat et de la discipline operationnelle.",
      "Installer une relation de confiance forte avec la direction generale en apportant une vision, des priorites et un rythme d execution."
    ]
  end

  job_type = case @mission.mission_type.to_s
    when "retained" then "CDI"
    when "exclusive" then "Management de transition"
    when "contingency" then "CDI"
    else "CDI"
  end

  hierarchy_level = brief_meta["hierarchy_level"].presence || mission_level_for(@mission)
  company_size_label = brief_meta["company_size"].presence || client.company_size
  company_headcount = brief_meta["company_headcount"].presence || "-"
  company_revenue = brief_meta["company_revenue_meur"].presence || "-"
  max_freelancers = search_meta["collab_max_freelancers"].presence || "3"
  closing_probability = search_meta["closing_probability"].to_i
  closing_probability = 65 if closing_probability.zero?
  client_relation = search_meta["client_relation"].presence || "Nouveau client RIVYR"
  difficulty_level = search_meta["difficulty"].presence || "Elevee"
  exigence_level = search_meta["client_exigence"].presence || "Elevee"
  shortlist_deadline_days = search_meta["collab_deadline_days"].to_i
  shortlist_deadline_days = 14 if shortlist_deadline_days.zero?
  position_deadline = (@mission.opened_at || Date.current) + shortlist_deadline_days

  quality_score = client_relation.include?("historique") ? 8.8 : 7.2
  difficulty_score = { "Moyenne" => 7.0, "Elevee" => 8.0, "Tres elevee" => 8.6, "Critique" => 9.0 }[difficulty_level] || 8.0
  attractiveness_score = @mission.priority_level.to_s.downcase == "critical" ? 8.9 : 8.1
  closing_score = (closing_probability / 10.0).round(1)
  rivyr_index = ((quality_score + difficulty_score + attractiveness_score + closing_score) / 4.0).round(1)
  priority_border_classes = {
    "critical" => "border-t-[#a84b4f]",
    "high" => "border-t-[#dc7b67]",
    "medium" => "border-t-[#f09a6f]",
    "low" => "border-t-[#f4d0c5]"
  }[@mission.priority_level.to_s.downcase] || "border-t-[#f4d0c5]"

  timeline_start_date = @mission.opened_at || Date.current
  timeline_steps = [
    { title: "Mission publiee", desc: "Ouverte aux freelances RIVYR.", offset_days: 0 },
    { title: "Positionnement des freelances", desc: "Positionnements en cours.", offset_days: 3 },
    { title: "Briefing mission", desc: "Brief detaille avec le client.", offset_days: 5 },
    { title: "Phase de sourcing", desc: "Recherche et qualification des candidats.", offset_days: 19 },
    { title: "Shortlist envoyee", desc: "Presentation des meilleurs profils.", offset_days: 27 },
    { title: "Entretiens client", desc: "Rencontres client-candidats.", offset_days: 34 },
    { title: "Choix du candidat", desc: "Selection du finaliste.", offset_days: 38 },
    { title: "Offre et negociation", desc: "Finalisation des conditions.", offset_days: 42 },
    { title: "Placement valide", desc: "Accord confirme.", offset_days: 46 },
    { title: "Signature du contrat", desc: "Contrat signe.", offset_days: 49 },
    { title: "Demarrage du candidat", desc: "Prise de poste confirmee.", offset_days: 52 }
  ]

  filled_steps = case @mission.status.to_s
  when "open" then 3
  when "in_progress" then 8
  when "closed" then 12
  else 3
  end

  current_step_index = [ [ filled_steps - 1, 0 ].max, timeline_steps.size - 1 ].min
  visible_timeline_start = [ current_step_index - 1, 0 ].max
  visible_timeline_end = [ visible_timeline_start + 2, timeline_steps.size - 1 ].min
  visible_timeline_start = [ visible_timeline_end - 2, 0 ].max if (visible_timeline_end - visible_timeline_start + 1) < 3
  visible_timeline_steps = timeline_steps[visible_timeline_start..visible_timeline_end]

  can_apply = policy(@mission).apply? && @mission.status == "open"
  show_withdraw = can_apply && already_applied && !freelance_owns_assigned_mission
  show_apply = can_apply && !already_applied && !freelance_owns_assigned_mission
  show_closed = @mission.status != "open"

  assigned_and_accepted =
    current_user&.role_freelance? &&
    (
      @mission.freelancer_profile_id == current_user.freelancer_profile&.id ||
      current_application&.status_accepted?
    )

  signature_sent_on = begin
    Date.parse(search_meta["signature_sent_at"].to_s)
  rescue ArgumentError, TypeError
    nil
  end
  contract_transmitted_on = signature_sent_on || (@mission.opened_at || Date.current) + 31.days
  signature_followup = search_meta["signature_followup"].presence
  signature_note = search_meta["signature_note"].presence
  contract_signature_state =
    search_meta["signature_status"].presence ||
    if @mission.contract_signed?
      "signed"
    elsif @mission.status_in_progress?
      "client_changes_requested"
    else
      "client_signing"
    end

  contract_status_config = {
    "transmitted" => {
      label: "Transmis",
      classes: "border-[#f2c46f] bg-[#fff4d9] text-[#8a5a00]"
    },
    "client_signing" => {
      label: "En cours de signature client",
      classes: "border-[#e5dbe0] bg-[#faf5f7] text-[#7a5a67]"
    },
    "client_changes_requested" => {
      label: "Modification client demandée",
      classes: "border-[#d8b3c2] bg-[#fff1f6] text-[#a33d68]"
    },
    "signed" => {
      label: "Signé",
      classes: "border-[#97c6a3] bg-[#edf8f0] text-[#2f6b3c]"
    },
    "refused" => {
      label: "Refusé",
      classes: "border-[#f1cfda] bg-[#fff1f6] text-[#a33d68]"
    },
    "expired" => {
      label: "Délais dépassé",
      classes: "border-[#e5dbe0] bg-[#faf5f7] text-[#7a5a67]"
    }
  }
  contract_status = contract_status_config.fetch(contract_signature_state, contract_status_config["client_signing"])
  signature_steps =
    case contract_signature_state
    when "transmitted"
      [
        { label: "Cree", done: true },
        { label: "Transmis le #{contract_transmitted_on.strftime("%d/%m")}", done: true },
        { label: "En cours signature client", done: false },
        { label: "Signe", done: false }
      ]
    when "client_signing"
      [
        { label: "Cree", done: true },
        { label: "Transmis le #{contract_transmitted_on.strftime("%d/%m")}", done: true },
        { label: "En cours signature client", done: true },
        { label: "Signe", done: false }
      ]
    when "client_changes_requested"
      [
        { label: "Cree", done: true },
        { label: "Transmis le #{contract_transmitted_on.strftime("%d/%m")}", done: true },
        { label: "En cours signature client", done: true },
        { label: "Modification client demandée", done: true }
      ]
    when "signed"
      [
        { label: "Cree", done: true },
        { label: "Transmis le #{contract_transmitted_on.strftime("%d/%m")}", done: true },
        { label: "En cours signature client", done: true },
        { label: "Signe", done: true }
      ]
    when "refused"
      [
        { label: "Cree", done: true },
        { label: "Transmis le #{contract_transmitted_on.strftime("%d/%m")}", done: true },
        { label: "En cours signature client", done: true },
        { label: "Refusé", done: true }
      ]
    when "expired"
      [
        { label: "Cree", done: true },
        { label: "Transmis le #{contract_transmitted_on.strftime("%d/%m")}", done: true },
        { label: "En cours signature client", done: false },
        { label: "Délais dépassé", done: true }
      ]
    else
      [
        { label: "Cree", done: true },
        { label: "Transmis le #{contract_transmitted_on.strftime("%d/%m")}", done: true },
        { label: "En cours signature client", done: false },
        { label: "Signe", done: false }
      ]
    end
  signature_current_index = signature_steps.rindex { |step| step[:done] } || 0

  months_fr = %w[Janvier Fevrier Mars Avril Mai Juin Juillet Aout Septembre Octobre Novembre Decembre]
  format_fr_date = lambda { |date| "#{date.day} #{months_fr[date.month - 1]} #{date.year}" }
  current_tab = params[:tab].presence_in(%w[mission enjeux deroulee profil]) || "profil"
  detail_tabs = [
    { key: "profil", label: "Profil recherche et avantages" },
    { key: "mission", label: "Mission et responsabilites" },
    { key: "enjeux", label: "Enjeux des 12 premiers mois" },
    { key: "deroulee", label: "Deroulee du recrutement" }
  ]
  job_description_text = <<~TEXT
    Job description - #{@mission.reference}

    Mission:
    #{@mission.title}

    Entreprise:
    #{client_name}
    Secteur: #{client.sector.presence || "-"}
    Localisation: #{@mission.region.name}

    Contexte:
    #{brief_meta["client_context"].presence || brief_meta["context"].presence || "Contexte a confirmer"}

    Responsabilites:
    #{mission_items.join("\n")}

    Profil recherche:
    #{must_have_items.join("\n")}
  TEXT
  company_presentation_text = <<~TEXT
    Presentation entreprise - #{@mission.reference}

    Entreprise:
    #{client_name}
    Secteur: #{client.sector.presence || "-"}
    Taille: #{company_size_label}
    Effectif: #{company_headcount}
    Chiffre d'affaires: #{company_revenue} M€

    Contexte:
    #{brief_meta["client_context"].presence || "#{client_name} - #{client.sector}"}
  TEXT
  contract_text = <<~TEXT
    Contrat mission - #{@mission.reference}

    Mission:
    #{@mission.title}
    Freelance:
    #{freelancer_name}
    Entreprise:
    #{client_name}

    Statut signature:
    #{contract_status[:label]}

    Etapes:
    #{signature_steps.map { |step| "- #{step[:label]}" }.join("\n")}
  TEXT
  download_text_href = lambda { |content| "data:text/plain;charset=utf-8,#{ERB::Util.url_encode(content)}" }
%>

<div class="w-full max-w-none px-6 py-5 md:px-11 lg:px-10">
  <div class="space-y-5">
    <section class="mt-2 rounded-3xl bg-[#fff8fb]/95 p-4 md:p-5">
      <div class="space-y-4">
        <div>
          <div>
            <div class="flex items-start justify-between gap-3">
              <h1 class="flex items-center gap-3 text-3xl font-semibold tracking-tight text-[#4c1f2a] md:text-4xl">
                <span><%= @mission.title %></span>
                <% if current_user&.role_freelance? %>
                  <%= button_to toggle_favorite_mission_path(@mission, return_to: request.fullpath), method: :post, class: "inline-flex items-center text-[#b56c5f] transition hover:scale-110 hover:text-[#8f4034]" do %>
                    <i class="<%= favorite_mission?(@mission) ? 'fa-solid' : 'fa-regular' %> fa-heart text-2xl"></i>
                  <% end %>
                <% end %>
              </h1>
              <div class="shrink-0">
                <%= render "missions/origin_badge", mission: @mission %>
              </div>
            </div>
            <div class="mt-2 flex flex-wrap items-center gap-2 text-[14px] font-medium text-[#7b4b5a]">
              <% if client_visible %>
                <span><%= client_name %> <%= client.sector %></span>
                <span><%= client_relation %></span>
                <span>Score: <strong><%= rivyr_index %>/10</strong></span>
                <button type="button" class="inline-flex items-center rounded-full border border-[#d8b3c2] bg-[#fff1f6] px-3 py-1 text-xs font-semibold text-[#a33d68] hover:bg-[#fde7f0]" onclick="document.getElementById('rivyr_score_modal').showModal()">details</button>
              <% else %>
                <span class="relative inline-flex cursor-help items-center gap-1" onmouseenter="this.querySelector('.client-lock-help').classList.remove('hidden')" onmouseleave="this.querySelector('.client-lock-help').classList.add('hidden')">
                  <span><%= masked_client %> <%= masked_sector %></span>
                  <i class="fa-solid fa-lock text-[#b4798b]"></i>
                  <span class="client-lock-help pointer-events-none absolute left-0 top-full z-40 mt-1 hidden w-72 rounded-xl border border-[#f2ddd6] bg-white px-2.5 py-2 text-[11px] text-[#6f332b] shadow-lg">Tant que la mission n est pas attribuee, les informations client restent masquees.</span>
                </span>
                <span><%= client_relation %></span>
                <span class="inline-flex items-center gap-2">
                  <span>Score: <strong><%= rivyr_index %>/10</strong></span>
                  <button type="button" class="inline-flex items-center rounded-full border border-[#d8b3c2] bg-[#fff1f6] px-3 py-1 text-xs font-semibold text-[#a33d68] hover:bg-[#fde7f0]" onclick="document.getElementById('rivyr_score_modal').showModal()">details</button>
                </span>
              <% end %>
            </div>
          </div>
        </div>

        <div class="grid items-stretch gap-4 xl:grid-cols-[minmax(0,3fr)_minmax(18rem,1fr)]">
          <div class="flex h-full flex-col gap-4">
          <div class="grid gap-3 rounded-2xl border border-[#ead2dc] bg-[#fff8fb]/95 p-3 md:grid-cols-2 xl:grid-cols-3">
            <div><p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Localisation</p><p class="text-[14px] font-medium text-[#5c3143]"><%= @mission.region.name %></p></div>
            <div><p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Type de poste</p><p class="text-[14px] font-medium text-[#5c3143]"><%= job_type %></p></div>
            <div><p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Package cible</p><p class="text-[14px] font-medium text-[#5c3143]"><%= euro_display(@mission.compensation_summary.presence || "-") %></p></div>
          </div>

          <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5 xl:flex-1">
            <h2 class="text-2xl font-semibold text-[#5b2633]">Contexte du recrutement</h2>
            <div class="mt-3 rounded-2xl border border-[#efdbe4] bg-white/70 px-4 py-3 text-[15px] text-[#5f3647]">
              <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">En bref</span>
              <p class="mt-2 leading-7">
                <%= freelance_origin_mission ? (brief_meta["en_bref"].presence || "En bref non renseigné.") : "Remplacement d un Directeur de Business Unit sur un perimetre industriel structure (#{company_headcount} collaborateurs, #{company_revenue} M€ de CA), avec rattachement direct a la Direction Generale." %>
              </p>
            </div>

            <div class="mt-4 grid gap-4 md:grid-cols-2">
              <div class="rounded-2xl border border-[#efdbe4] bg-white/80 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Le contexte</p>
                <div class="mt-3 space-y-3 text-[15px] leading-7 text-[#5f3647]">
                  <% if freelance_origin_mission %>
                    <p><%= brief_meta["context"].presence || "Contexte non renseigné." %></p>
                  <% else %>
                    <p>Entreprise industrielle de taille intermediaire (200-500 personnes), avec un perimetre large et expose.</p>
                    <p>Le poste s inscrit dans un environnement exigeant, avec de forts enjeux de performance, de structuration et de communication manageriale.</p>
                  <% end %>
                </div>
              </div>

              <div class="rounded-2xl border border-[#efdbe4] bg-white/80 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Le role</p>
                <div class="mt-3 space-y-3 text-[15px] leading-7 text-[#5f3647]">
                  <% if freelance_origin_mission %>
                    <p><%= brief_meta["role"].presence || "Rôle non renseigné." %></p>
                  <% else %>
                    <p>Responsable d un perimetre multi-equipes, avec pilotage budgetaire et responsabilites operationnelles etendues.</p>
                    <p>Le poste implique une forte proximite avec la Direction Generale et un role cle dans la priorisation strategique et la performance globale.</p>
                  <% end %>
                </div>
              </div>
            </div>

          </article>

          </div>

        <aside class="flex flex-col self-start">
          <article class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
            <div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Commission freelance estimee</p>
                <div class="mt-1 flex items-center gap-2">
                  <p class="text-2xl font-semibold text-[#5f3247]"><%= format_amount(fee_breakdown[:fee_amount]) %>€</p>
                  <button type="button" class="inline-flex items-center text-sm text-[#8b4452] transition hover:text-[#5f3247]" onclick="document.getElementById('commission_breakdown_modal').showModal()" aria-label="Informations sur le detail du calcul de commission">
                    <i class="fa-solid fa-circle-info"></i>
                  </button>
                </div>
              </div>
            </div>

            <% if show_withdraw %>
                <span class="mt-4 block rounded-2xl border border-[#d2dfd4] bg-[#edf7ef] px-4 py-3 text-center text-base font-semibold text-[#3b6d4d]">Deja positionne</span>
              <button type="button" class="btn mt-3 w-full rounded-2xl border-[#e7b2bb] bg-[#fff1f3] text-[#b43e53] hover:bg-[#ffe5e9]" onclick="document.getElementById('withdraw_modal').showModal()">
                <i class="fa-solid fa-xmark mr-1"></i>Se retirer
              </button>
            <% elsif show_apply %>
              <%= button_to "Se positionner sur la mission",
                            apply_mission_path(@mission, return_to: (request.referer.to_s.include?("/dashboard") ? dashboard_library_missions_path(status: "open") : library_missions_path(status: "open"))),
                            method: :post,
                            class: "btn mt-4 w-full rounded-2xl border-[#ED0E64] bg-[#ED0E64] text-base text-white hover:border-[#cf0c57] hover:bg-[#cf0c57]" %>
            <% elsif mission_placed %>
              <span class="mt-4 block rounded-2xl border border-[#cfe4d4] bg-[#edf8f0] px-4 py-3 text-center text-base font-semibold text-[#2f6b3c]">Mission placée</span>
            <% elsif @mission.status_closed? %>
              <span class="mt-4 block rounded-2xl border border-[#e8d3d9] bg-[#f7f2f5] px-4 py-3 text-center text-base font-semibold text-[#8f6c78]">Mission fermée</span>
            <% elsif mission_assigned %>
              <span class="mt-4 block rounded-2xl border border-[#cfe4d4] bg-[#edf8f0] px-4 py-3 text-center text-base font-semibold text-[#2f6b3c]">Mission en cours</span>
            <% elsif show_closed %>
              <span class="mt-4 block rounded-2xl border border-[#e3d8de] bg-[#f7f2f5] px-4 py-3 text-center text-base font-semibold text-[#8f6c78]">Mission fermée</span>
            <% end %>
            <button type="button" class="btn mt-3 w-full rounded-2xl border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]">Poser une question a RIVYR</button>
            <% if mission_assigned || freelance_origin_mission %>
              <%= link_to company_showcase_path(client_id: client.id), class: "btn mt-3 w-full rounded-2xl border-[#ead2dc] bg-white text-[#8b4452] hover:bg-[#fdeef3] flex items-center justify-center gap-2" do %>
                <i class="fa-regular fa-building"></i>
                Voir la page entreprise
              <% end %>
            <% end %>
            <% if freelance_created_mission && policy(@mission).edit? %>
              <%= link_to "Modifier", edit_mission_path(@mission), class: "btn mt-3 w-full rounded-2xl border-[#dfbcc9] bg-[#fff2f7] text-[#7a3a49] hover:bg-[#fce7ef]" %>
            <% end %>
            <% if freelance_owns_assigned_mission && !@mission.status_closed? %>
              <button type="button" class="btn mt-3 w-full rounded-2xl border-[#e7b2bb] bg-[#fff1f3] text-[#b43e53] hover:bg-[#ffe5e9]" onclick="document.getElementById('close_mission_modal').showModal()">
                <i class="fa-solid fa-folder-minus mr-1"></i>Clôturer la mission
              </button>
            <% end %>
            <% if mission_placed && placed_candidate.present? %>
              <%= link_to candidate_path(placed_candidate), class: "mt-3 flex w-full items-center gap-3 rounded-2xl border border-[#d7e9dc] bg-[#edf8f0] px-4 py-3 text-left transition hover:bg-[#e4f4e8]" do %>
                <%= image_tag avatar_asset_src(placed_candidate), alt: placed_candidate.display_name, class: "h-11 w-11 rounded-full object-cover ring-2 ring-white" %>
                <span class="min-w-0">
                  <span class="block text-xs font-semibold uppercase tracking-wide text-[#5d8a68]">Candidat placé</span>
                  <span class="block truncate text-base font-semibold text-[#2f6b3c]"><%= placed_candidate.display_name %></span>
                </span>
              <% end %>
            <% end %>

          </article>

            <% if mission_assigned %>
              <h4 class="mt-4 text-lg font-semibold text-[#5b2633]">Documents utiles</h4>
              <div class="mt-3 space-y-2 text-[14px] text-[#5f3647]">
                  <div class="flex items-center justify-between gap-2 rounded-xl border border-[#ead2dc] px-3 py-2">
                    <span>Job description complete</span>
                    <% if assigned_and_accepted %>
                      <div class="flex items-center gap-2">
                        <button type="button" class="btn btn-xs rounded-full border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]" title="Job description video" onclick="document.getElementById('job_description_video_modal').showModal()">
                          <i class="fa-solid fa-video"></i>
                        </button>
                        <button type="button" class="btn btn-xs rounded-full border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]" title="Job description" onclick="document.getElementById('job_description_modal').showModal()">
                          <i class="fa-solid fa-file-lines"></i>
                        </button>
                      </div>
                    <% else %>
                      <span class="relative inline-flex cursor-help items-center" onmouseenter="this.querySelector('.document-lock-help').classList.remove('hidden')" onmouseleave="this.querySelector('.document-lock-help').classList.add('hidden')">
                        <span class="btn btn-xs pointer-events-none rounded-full border-[#e7d7de] bg-[#f7f2f5] text-[#c4aab4]" title="Disponible apres affectation">
                          <i class="fa-solid fa-file-lines"></i>
                        </span>
                        <span class="document-lock-help pointer-events-none absolute right-0 top-full z-40 mt-2 hidden w-56 rounded-xl border border-[#f2ddd6] bg-white px-3 py-2 text-left text-xs text-[#6f332b] shadow-lg">Disponible apres affectation</span>
                      </span>
                    <% end %>
                  </div>

                  <div class="flex items-center justify-between gap-2 rounded-xl border border-[#ead2dc] px-3 py-2">
                    <div class="min-w-0">
                      <span class="<%= assigned_and_accepted ? 'text-[#5f3647]' : 'text-[#9a7582]' %>">Presentation entreprise</span>
                    </div>
                    <% if assigned_and_accepted %>
                      <div class="flex items-center gap-2">
                        <% if mission_assigned && client_visible %>
                          <%= link_to client_path(client), class: "btn btn-xs rounded-full border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]", title: "Fiche entreprise" do %>
                            <i class="fa-regular fa-building"></i>
                          <% end %>
                        <% end %>
                        <button type="button" class="btn btn-xs rounded-full border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]" title="Presentation entreprise" onclick="document.getElementById('company_modal').showModal()">
                          <i class="fa-solid fa-file-lines"></i>
                        </button>
                      </div>
                    <% else %>
                      <span class="relative inline-flex cursor-help items-center" onmouseenter="this.querySelector('.document-lock-help').classList.remove('hidden')" onmouseleave="this.querySelector('.document-lock-help').classList.add('hidden')">
                        <span class="btn btn-xs pointer-events-none rounded-full border-[#e7d7de] bg-[#f7f2f5] text-[#c4aab4]" title="Disponible apres affectation">
                          <i class="fa-solid fa-file-lines"></i>
                        </span>
                        <span class="document-lock-help pointer-events-none absolute right-0 top-full z-40 mt-2 hidden w-56 rounded-xl border border-[#f2ddd6] bg-white px-3 py-2 text-left text-xs text-[#6f332b] shadow-lg">Disponible apres affectation</span>
                      </span>
                    <% end %>
                  </div>

                  <div class="flex items-center justify-between gap-2 rounded-xl border border-[#ead2dc] px-3 py-2">
                    <div class="min-w-0 flex items-center gap-2">
                      <span class="<%= assigned_and_accepted ? 'text-[#5f3647]' : 'text-[#9a7582]' %>">Contrat</span>
                      <span class="relative inline-flex cursor-help items-center" onmouseenter="this.querySelector('.signature-status-help').classList.remove('hidden')" onmouseleave="this.querySelector('.signature-status-help').classList.add('hidden')">
                        <span class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold <%= contract_status[:classes] %>"><%= contract_status[:label] %></span>
                        <span class="signature-status-help pointer-events-none absolute right-0 top-full z-40 mt-2 hidden w-72 rounded-xl border border-[#f2ddd6] bg-white px-3 py-3 text-left shadow-lg">
                          <span class="block text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Etapes de signature</span>
                          <ul class="mt-2 space-y-2 text-sm text-[#5f3647]">
                            <% signature_steps.each_with_index do |step, idx| %>
                              <li class="flex items-center gap-2">
                                <span class="<%= step[:done] ? 'border-[#97c6a3] bg-[#edf8f0] text-[#2f6b3c]' : 'border-[#e7d7de] bg-[#f7f2f5] text-[#b49aa4]' %> flex h-5 w-5 items-center justify-center rounded-full border text-[10px] font-semibold"><%= idx + 1 %></span>
                                <span class="<%= idx == signature_current_index ? 'font-semibold text-[#4c1f2a]' : 'text-[#6f4a58]' %>"><%= step[:label] %></span>
                              </li>
                          <% end %>
                        </ul>
                      </span>
                    </span>
                  </div>
                    <% if assigned_and_accepted %>
                      <div class="flex items-center gap-2">
                        <button type="button" class="btn btn-xs rounded-full border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]" title="Créer et envoyer le contrat" onclick="document.getElementById('contract_signature_modal').showModal()">
                          <i class="fa-solid fa-signature"></i>
                        </button>
                        <button type="button" class="btn btn-xs rounded-full border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]" title="Contrat" onclick="document.getElementById('contract_modal').showModal()">
                          <i class="fa-solid fa-file-lines"></i>
                        </button>
                      </div>
                    <% else %>
                      <span class="relative inline-flex cursor-help items-center" onmouseenter="this.querySelector('.document-lock-help').classList.remove('hidden')" onmouseleave="this.querySelector('.document-lock-help').classList.add('hidden')">
                        <span class="btn btn-xs pointer-events-none rounded-full border-[#e7d7de] bg-[#f7f2f5] text-[#c4aab4]" title="Disponible apres affectation">
                          <i class="fa-solid fa-file-lines"></i>
                        </span>
                        <span class="document-lock-help pointer-events-none absolute right-0 top-full z-40 mt-2 hidden w-56 rounded-xl border border-[#f2ddd6] bg-white px-3 py-2 text-left text-xs text-[#6f332b] shadow-lg">Disponible apres affectation</span>
                      </span>
                    <% end %>
                  </div>
              </div>
            <% end %>

          <% unless mission_assigned %>
            <article class="mt-4 rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-4">
              <div class="relative">
                <div class="absolute left-[0.92rem] top-0 bottom-0 w-px bg-[#eadde5]"></div>
                <div class="space-y-4">
                  <% visible_timeline_steps.each_with_index do |step, local_idx| %>
                    <% idx = visible_timeline_start + local_idx %>
                    <% step_state =
                      if idx < current_step_index
                        :completed
                      elsif idx == current_step_index
                        :current
                      else
                        :upcoming
                      end
                    %>
                    <article class="group relative pl-10">
                      <span class="absolute left-0 top-2 inline-flex h-8 w-8 items-center justify-center rounded-full border text-xs font-semibold shadow-sm <%= step_state == :completed ? 'border-[#f4c9da] bg-[#fff1f6] text-[#ed0e64]' : (step_state == :current ? 'border-[#f2b7cd] bg-[#ed0e64] text-white ring-2 ring-[#fde7f0]' : 'border-[#e1e4eb] bg-[#f6f7fa] text-[#8d95a5]') %>">
                        <%= step_state == :completed ? "✓" : (step_state == :current ? "●" : "○") %>
                      </span>
                      <div class="rounded-2xl border px-4 py-3 <%= step_state == :current ? 'border-[#f2b7cd] bg-[#fff1f6] shadow-[0_12px_30px_rgba(237,14,100,0.08)]' : 'border-[#efdbe4] bg-[#fffafb]' %>">
                        <div class="flex items-center justify-between gap-3">
                          <p class="min-w-0 truncate text-sm <%= step_state == :current ? 'text-[#4c1f2a]' : 'text-[#5f3647]' %>">
                            <span class="font-semibold"><%= step[:title] %></span>
                            <span class="text-[#6f4a58]"> • <%= step[:desc] %></span>
                          </p>
                          <span class="shrink-0 rounded-full border border-[#efdbe4] bg-white px-2.5 py-1 text-[11px] font-semibold text-[#9a5a68]">
                            J+<%= step[:offset_days] %>
                          </span>
                        </div>
                      </div>
                      <div class="pointer-events-none absolute left-10 right-3 top-full z-30 mt-2 hidden rounded-2xl border border-[#efdbe4] bg-white px-4 py-3 text-sm leading-6 text-[#5f3647] shadow-[0_18px_40px_rgba(76,31,42,0.12)] group-hover:block">
                        <span class="font-semibold text-[#4c1f2a]"><%= step[:title] %></span>
                        <span class="text-[#6f4a58]"> • <%= step[:desc] %></span>
                      </div>
                    </article>
                  <% end %>
                </div>
              </div>
            </article>
          <% end %>
        </aside>
        </div>

        <section id="mission-details-tabs" class="rounded-3xl border border-[#ead2dc] bg-[#fff8fb]/95 p-5">
          <div class="grid gap-2 md:grid-cols-4">
            <% detail_tabs.each do |tab| %>
              <%= link_to dashboard_mission_path(@mission, tab: tab[:key], anchor: "mission-details-tabs"), class: "rounded-2xl px-4 py-3 text-sm font-semibold transition #{current_tab == tab[:key] ? 'bg-[#4c1f2a] text-white shadow-[0_12px_24px_rgba(76,31,42,0.14)]' : 'bg-white/80 text-[#7b4b5a] hover:bg-[#fff1f6] hover:text-[#4c1f2a]'}" do %>
                <span><%= tab[:label] %></span>
              <% end %>
            <% end %>
          </div>

          <% if current_tab == "mission" %>
            <div class="mt-4">
              <h2 class="text-2xl font-semibold text-[#5b2633]">Mission et responsabilites</h2>
              <% if freelance_origin_mission %>
                <div class="mt-3 rounded-2xl border border-[#efdbe4] bg-white/80 p-5 text-[15px] leading-7 text-[#5f3647]">
                  <p><%= brief_meta["role"].presence || "Rôle non renseigné." %></p>
                </div>
              <% else %>
                <ul class="mt-3 space-y-2 text-[15px] text-[#5f3647]">
                  <% mission_items.each do |item| %>
                    <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#c88ea1]"></span><span><%= item %></span></li>
                  <% end %>
                </ul>
              <% end %>
            </div>
          <% elsif current_tab == "enjeux" %>
            <div class="mt-4">
              <h2 class="text-2xl font-semibold text-[#5b2633]">Enjeux des 12 premiers mois</h2>
              <ul class="mt-3 space-y-2 text-[15px] text-[#5f3647]">
                <% enjeux_items.each do |item| %>
                  <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#9bbf9c]"></span><span><%= item %></span></li>
                <% end %>
              </ul>
            </div>
          <% elsif current_tab == "deroulee" %>
            <div class="mt-4">
              <h2 class="text-2xl font-semibold text-[#5b2633]">Deroulee du recrutement</h2>
              <% if freelance_origin_mission %>
                <ul class="mt-3 space-y-2 text-[15px] text-[#5f3647]">
                  <% to_list.call(brief_meta["deroulee"]).each do |item| %>
                    <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#c88ea1]"></span><span><%= item %></span></li>
                  <% end %>
                </ul>
              <% else %>
                <ul class="mt-3 space-y-2 text-[15px] text-[#5f3647]">
                  <li><strong>Nombre d entretiens:</strong> 3</li>
                  <li><strong>1er entretien:</strong> Echange RH avec RIVYR</li>
                  <li><strong>2eme entretien:</strong> Rencontre avec le manager operationnel</li>
                  <li><strong>3eme entretien:</strong> Entretien final avec la direction</li>
                  <li><strong>Prise de references:</strong> A l issue du dernier entretien</li>
                  <li><strong>Decision finale:</strong> Sous 72h apres le dernier echange</li>
                </ul>
              <% end %>
            </div>
          <% else %>
            <div class="mt-4">
              <h2 class="text-2xl font-semibold text-[#5b2633]">Profil recherche et avantages</h2>
              <div class="mt-3 grid gap-6 lg:grid-cols-3">
                <div class="rounded-2xl border border-[#efdbe4] bg-white/80 p-5 lg:col-span-2">
                  <h3 class="text-lg font-semibold text-[#5b2633]">Profil recherche</h3>
                  <% if freelance_origin_mission %>
                    <div class="mt-4 rounded-2xl border border-[#efdbe4] bg-[#fff8fb] p-4 text-[15px] leading-7 text-[#5f3647]">
                      <p><%= search_meta["profil"].presence || "Profil recherché non renseigné." %></p>
                    </div>
                  <% else %>
                    <h4 class="mt-4 text-sm font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Indispensable</h4>
                    <ul class="mt-3 space-y-3 text-[15px] text-[#5f3647]">
                      <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#e2a47f]"></span><span>Experience solide en direction de Business Unit dans l industrie</span></li>
                      <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#e2a47f]"></span><span>Management d equipes dans un environnement structure (200-500 collaborateurs)</span></li>
                      <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#e2a47f]"></span><span>Capacite a piloter la performance operationnelle et financiere</span></li>
                      <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#e2a47f]"></span><span>Experience averee de transformation (organisation, performance, structuration)</span></li>
                    </ul>

                    <h4 class="mt-6 text-sm font-semibold uppercase tracking-[0.2em] text-[#9a5a68]">Apprecie</h4>
                    <ul class="mt-3 space-y-3 text-[15px] text-[#5f3647]">
                      <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#c3b0d7]"></span><span>Experience en environnement international</span></li>
                      <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#c3b0d7]"></span><span>Habitude des organisations complexes ou multisites</span></li>
                      <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#c3b0d7]"></span><span>Aisance dans les echanges avec une Direction Generale / COMEX</span></li>
                    </ul>
                  <% end %>
                </div>

                <div class="rounded-2xl border border-[#efdbe4] bg-white/80 p-5">
                  <h3 class="text-lg font-semibold text-[#5b2633]">Avantages</h3>
                  <ul class="mt-4 space-y-3 text-[15px] text-[#5f3647]">
                    <li><strong>Remuneration:</strong> <%= euro_display(@mission.compensation_summary.presence || "90 000€ - 120 000€") %></li>
                    <% if freelance_origin_mission %>
                      <% advantage_items.each do |item| %>
                        <li><%= item %></li>
                      <% end %>
                    <% else %>
                      <li><strong>Voiture de fonction:</strong> Oui</li>
                      <li><strong>13eme mois:</strong> Inclus</li>
                      <li><strong>Tickets restaurants:</strong> Oui</li>
                      <li><strong>Mutuelle:</strong> Premium</li>
                      <li><strong>Bonus:</strong> Variable annuel selon performance</li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          <% end %>
        </section>
      </div>
    </section>

    <% if @favorite_candidates.any? %>
      <section class="mt-6 rounded-[1.45rem] border border-[#ead2dc] bg-[#fff8fb]/95 p-6 shadow-sm">
        <div class="mb-4 flex items-center gap-2">
          <i class="fa-solid fa-heart text-[#ed0e64]"></i>
          <h2 class="text-base font-semibold text-[#4c1f2a]">Candidats mis en favoris pour cette mission</h2>
          <span class="inline-flex items-center rounded-full border border-[#f7c4da] bg-[#fff0f6] px-2.5 py-0.5 text-xs font-semibold text-[#ed0e64]"><%= @favorite_candidates.size %></span>
          <%= link_to favoris_mission_path(@mission), class: "ml-auto text-sm font-medium text-[#ed0e64] hover:underline" do %>
            Voir tout <i class="fa-solid fa-arrow-right text-xs"></i>
          <% end %>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          <% @favorite_candidates.each do |candidate| %>
            <%= link_to candidate_path(candidate), class: "flex items-center gap-3 rounded-2xl border border-[#ead2dc] bg-white px-4 py-3 transition hover:border-[#f7c4da] hover:bg-[#fff5f8]" do %>
              <%= image_tag avatar_asset_src(candidate), alt: candidate.display_name, class: "h-10 w-10 flex-shrink-0 rounded-full object-cover ring-2 ring-[#f7c4da]" %>
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-[#4c1f2a]"><%= candidate.display_name %></p>
                <p class="truncate text-xs text-[#9a5a68]"><%= candidate.job_titles&.last.presence || "Candidat" %></p>
                <% if candidate.availability.present? %>
                  <p class="mt-0.5 text-[11px] text-[#b49aa4]"><%= Candidate::AVAILABILITY_LABELS[candidate.availability] %></p>
                <% end %>
              </div>
              <i class="fa-solid fa-heart ml-auto flex-shrink-0 text-xs text-[#ed0e64]"></i>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>

  </div>
</div>

<dialog id="rivyr_score_modal" class="modal">
  <div class="modal-box max-w-md rounded-2xl border border-[#ead5ce] bg-white">
    <h3 class="text-lg font-semibold text-[#6f332b]">Indice mission RIVYR : <%= rivyr_index %>/10</h3>
    <p class="mt-2 text-sm text-[#6b3f4f]">Cet indice combine 4 dimensions pour aider le freelance a decider vite :</p>
    <ul class="mt-3 space-y-1.5 text-sm text-[#5e3742]">
      <li><strong>Qualite client:</strong> <%= quality_score %>/10</li>
      <li><strong>Niveau de difficulte:</strong> <%= difficulty_score %>/10</li>
      <li><strong>Attractivite du poste:</strong> <%= attractiveness_score %>/10</li>
      <li><strong>Probabilite de closing:</strong> <%= closing_score %>/10</li>
    </ul>
    <p class="mt-3 text-xs text-[#8d5f6b]">Objectif: t aider a trancher en moins de 60 secondes.</p>
    <div class="modal-action">
      <form method="dialog"><button class="btn btn-sm">Fermer</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<dialog id="commission_breakdown_modal" class="modal">
  <div class="modal-box max-w-lg rounded-2xl border border-[#ead5ce] bg-white">
    <h3 class="text-lg font-semibold text-[#6f332b]">Detail du calcul de commission</h3>
    <div class="mt-3 space-y-3 text-sm text-[#5f3647]">
      <p><strong>Remuneration brute moyenne:</strong> <%= format_amount(fee_breakdown[:salary_average]) %>€</p>
      <p><strong>Honoraires RIVYR:</strong> <%= format_amount(fee_breakdown[:salary_average]) %> x <%= (fee_breakdown[:contract_rate] * 100).round %>% = <%= format_amount(fee_breakdown[:gross_fee]) %>€</p>
      <p><strong>Part freelance:</strong> <%= format_amount(fee_breakdown[:gross_fee]) %> x <%= (fee_breakdown[:freelance_rate] * 100).round %>% = <%= format_amount(fee_breakdown[:fee_amount]) %>€</p>
      <p class="rounded-xl border border-[#efdbe4] bg-[#fff8fb] px-3 py-2 text-[#6f4a58]">
        Formule appliquee: remuneration brute moyenne x honoraires RIVYR x part freelance.
      </p>
    </div>
    <div class="modal-action">
      <form method="dialog"><button class="btn btn-sm">Fermer</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<dialog id="company_modal" class="modal">
  <div class="modal-box max-w-lg rounded-2xl border border-[#ead5ce] bg-white">
    <h3 class="text-lg font-semibold text-[#6f332b]">Presentation entreprise</h3>
    <div class="mt-3 space-y-3 text-sm text-[#5f3647]">
      <p><strong>Client:</strong> <%= client_name %></p>
      <p><strong>Secteur:</strong> <%= client.sector.presence || "-" %></p>
      <p><strong>Taille:</strong> <%= company_size_label %></p>
      <p><strong>Effectif:</strong> <%= company_headcount %></p>
      <p><strong>Chiffre d affaires:</strong> <%= company_revenue %> M€</p>
      <p><strong>Contexte:</strong> <%= brief_meta["client_context"].presence || "#{client_name} - #{client.sector}" %></p>
      <% if client.website_url.present? %>
        <p><strong>Site:</strong> <%= link_to client.website_url, client.website_url, class: "text-[#8b4452] underline hover:text-[#6f2d3a]", target: "_blank", rel: "noopener" %></p>
      <% end %>
    </div>
    <div class="modal-action">
      <a href="<%= download_text_href.call(company_presentation_text) %>" download="presentation-entreprise-<%= @mission.reference %>.txt" class="btn btn-sm border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]">
        Télécharger
      </a>
      <button type="button" class="btn btn-sm border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]" onclick="window.print()">
        Imprimer
      </button>
      <form method="dialog"><button class="btn btn-sm">Fermer</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<dialog id="job_description_modal" class="modal">
  <div class="modal-box max-w-2xl rounded-2xl border border-[#ead5ce] bg-white">
    <h3 class="text-lg font-semibold text-[#6f332b]">Job description complete</h3>
    <div class="mt-3 space-y-4 text-sm text-[#5f3647]">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Mission</p>
        <p class="mt-1 text-base font-semibold text-[#4c1f2a]"><%= @mission.title %></p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Entreprise</p>
        <p class="mt-1"><%= client_name %> · <%= client.sector.presence || "-" %></p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Contexte</p>
        <p class="mt-1 leading-6"><%= brief_meta["client_context"].presence || brief_meta["context"].presence || "Contexte a confirmer" %></p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Responsabilites principales</p>
        <ul class="mt-2 space-y-2">
          <% mission_items.first(6).each do |item| %>
            <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#c88ea1]"></span><span><%= item %></span></li>
          <% end %>
        </ul>
      </div>
    </div>
    <div class="modal-action">
      <a href="<%= download_text_href.call(job_description_text) %>" download="job-description-<%= @mission.reference %>.txt" class="btn btn-sm border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]">
        Télécharger
      </a>
      <button type="button" class="btn btn-sm border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]" onclick="window.print()">
        Imprimer
      </button>
      <form method="dialog"><button class="btn btn-sm">Fermer</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<dialog id="job_description_video_modal" class="modal">
  <div class="modal-box max-w-3xl rounded-2xl border border-[#ead5ce] bg-white">
    <h3 class="text-lg font-semibold text-[#6f332b]">Job description vidéo</h3>
    <div class="mt-4 overflow-hidden rounded-2xl border border-[#ead2dc] bg-[#fff8fb]">
      <div class="relative aspect-video bg-[radial-gradient(circle_at_top,_#fff4f7,_#f6d8e2_55%,_#d8a6b6)]">
        <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(76,31,42,0.08),rgba(237,14,100,0.18))]"></div>
        <div class="relative flex h-full flex-col justify-between p-6 text-[#4c1f2a]">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[#9a5a68]">Brief vidéo</p>
              <p class="mt-2 text-2xl font-semibold"><%= @mission.title %></p>
              <p class="mt-2 text-sm text-[#6f4a58]"><%= client_name %> · <%= client.sector.presence || "-" %></p>
            </div>
            <span class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-white/85 text-[#ed0e64] shadow-lg">
              <i class="fa-solid fa-play text-lg"></i>
            </span>
          </div>
          <div class="grid gap-3 md:grid-cols-3">
            <div class="rounded-2xl bg-white/80 p-3">
              <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Contexte</p>
              <p class="mt-2 text-sm leading-6 text-[#5f3647]"><%= brief_meta["client_context"].presence || brief_meta["context"].presence || "Contexte a confirmer" %></p>
            </div>
            <div class="rounded-2xl bg-white/80 p-3 md:col-span-2">
              <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">3 points clés</p>
              <ul class="mt-2 space-y-2 text-sm text-[#5f3647]">
                <% mission_items.first(3).each do |item| %>
                  <li class="flex items-start gap-2"><span class="mt-1.5 h-2 w-2 rounded-full bg-[#ed0e64]"></span><span><%= item %></span></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="mt-3 text-sm text-[#6f4a58]">Version vidéo synthétique de la job description pour relire rapidement les messages clés de la mission.</p>
    <div class="modal-action">
      <form method="dialog"><button class="btn btn-sm">Fermer</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<dialog id="contract_modal" class="modal">
  <div class="modal-box max-w-2xl rounded-2xl border border-[#ead5ce] bg-white">
    <h3 class="text-lg font-semibold text-[#6f332b]">Contrat mission</h3>
    <div class="mt-3 space-y-4 text-sm text-[#5f3647]">
      <div class="rounded-xl border border-[#ead2dc] bg-[#fff8fb] px-4 py-3">
        <p><strong>Mission:</strong> <%= @mission.title %></p>
        <p><strong>Freelance:</strong> <%= freelancer_name %></p>
        <p><strong>Client:</strong> <%= client_name %></p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Statut</p>
        <p class="mt-1"><span class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold <%= contract_status[:classes] %>"><%= contract_status[:label] %></span></p>
      </div>
      <% if signature_followup.present? %>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Complément</p>
          <p class="mt-1 text-sm text-[#5f3647]"><%= signature_followup %></p>
        </div>
      <% end %>
      <% if signature_note.present? %>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Note</p>
          <p class="mt-1 text-sm text-[#5f3647]"><%= signature_note %></p>
        </div>
      <% end %>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-[#9a5a68]">Etapes de signature</p>
        <ul class="mt-2 space-y-2">
          <% signature_steps.each_with_index do |step, idx| %>
            <li class="flex items-center gap-2">
              <span class="<%= step[:done] ? 'border-[#97c6a3] bg-[#edf8f0] text-[#2f6b3c]' : 'border-[#e7d7de] bg-[#f7f2f5] text-[#b49aa4]' %> flex h-5 w-5 items-center justify-center rounded-full border text-[10px] font-semibold"><%= idx + 1 %></span>
              <span><%= step[:label] %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
    <div class="modal-action">
      <a href="<%= download_text_href.call(contract_text) %>" download="contrat-mission-<%= @mission.reference %>.txt" class="btn btn-sm border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]">
        Télécharger
      </a>
      <button type="button" class="btn btn-sm border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]" onclick="window.print()">
        Imprimer
      </button>
      <form method="dialog"><button class="btn btn-sm">Fermer</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

