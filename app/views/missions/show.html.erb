<dialog id="withdraw_modal" class="modal">
  <div class="modal-box max-w-sm rounded-2xl border border-[#f1d3d9] bg-white">
    <h3 class="text-lg font-semibold text-[#8a2f43]">Se retirer de la mission</h3>
