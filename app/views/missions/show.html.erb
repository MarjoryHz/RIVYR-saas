      <div class="rounded-xl border border-[#ead2dc] bg-[#fff8fb] px-4 py-3">
        <p><strong>Mission:</strong> <%= @mission.title %></p>
        <p><strong>Entreprise:</strong> <%= client_name %></p>
        <p><strong>Freelance:</strong> <%= freelancer_name %></p>
      </div>
    </div>
    <div class="modal-action">
      <button type="button" class="btn btn-sm border-[#dfbcc9] bg-[#fff5f8] text-[#8b4452] hover:bg-[#fdeef3]" onclick="document.getElementById('contract_signature_modal').close()">
        Créer et envoyer
      </button>
      <form method="dialog"><button class="btn btn-sm">Fermer</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<dialog id="withdraw_modal" class="modal">
  <div class="modal-box max-w-sm rounded-2xl border border-[#f1d3d9] bg-white">
    <h3 class="text-lg font-semibold text-[#8a2f43]">Se retirer de la mission</h3>
    <p class="mt-2 text-sm text-[#6b3f4f]">Voulez-vous vraiment retirer votre positionnement ?</p>
    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-sm">Annuler</button>
      </form>
      <%= button_to "Se retirer", withdraw_mission_path(@mission), method: :delete, class: "btn btn-sm border-[#e7b2bb] bg-[#fff1f3] text-[#b43e53] hover:bg-[#ffe5e9]" %>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<dialog id="close_mission_modal" class="modal">
  <div class="modal-box max-w-lg rounded-2xl border border-[#f1d3d9] bg-white">
    <h3 class="text-lg font-semibold text-[#8a2f43]">Clôturer la mission</h3>
    <p class="mt-2 text-sm text-[#6b3f4f]">Cette action ferme la mission pour toi. Si la mission est d’origine RIVYR, l’équipe admin sera notifiée.</p>
    <%= form_with url: close_by_freelance_mission_path(@mission), method: :patch, class: "mt-4 space-y-4", html: { id: "close-mission-form" } do |form| %>
      <div>
        <label for="closure_reason" class="mb-2 block text-sm font-semibold text-[#6b3f4f]">Motif</label>
        <%= select_tag :closure_reason, options_for_select(closure_reason_options), id: "closure_reason", class: "select select-bordered w-full", onchange: "toggleCloseMissionFields()" %>
      </div>
      <div id="placed-candidate-field" class="hidden">
        <label for="candidate-search" class="mb-2 block text-sm font-semibold text-[#6b3f4f]">Candidat placé</label>
        <input id="candidate-search" type="text" class="input input-bordered w-full" placeholder="Rechercher un candidat..." oninput="filterMissionCandidates(this.value)">
        <input type="hidden" name="candidate_id" id="selected-candidate-id">
        <div id="selected-candidate-card" class="mt-3 hidden rounded-2xl border border-[#d7e9dc] bg-[#edf8f0] px-4 py-3 text-sm text-[#2f6b3c]"></div>
        <div id="candidate-search-results" class="mt-3 max-h-64 space-y-2 overflow-y-auto">
          <% @close_candidate_options.each do |candidate| %>
            <button
              type="button"
              class="mission-candidate-result flex w-full items-center gap-3 rounded-2xl border border-[#ead2dc] bg-white px-3 py-3 text-left transition hover:border-[#dfbcc9] hover:bg-[#fff5f8]"
              data-candidate-id="<%= candidate.id %>"
              data-candidate-name="<%= candidate.display_name %>"
              onclick="selectMissionCandidate(this)">
              <%= image_tag avatar_asset_src(candidate), alt: candidate.display_name, class: "h-10 w-10 rounded-full object-cover" %>
              <span class="min-w-0">
                <span class="block truncate text-sm font-semibold text-[#4c1f2a]"><%= candidate.display_name %></span>
                <span class="block truncate text-xs text-[#7b4b5a]"><%= candidate.job_titles&.last.presence || candidate.source.to_s.humanize.presence || "Candidat" %></span>
              </span>
            </button>
          <% end %>
        </div>
      </div>
      <div id="closure-note-field">
        <label for="closure_note" class="mb-2 block text-sm font-semibold text-[#6b3f4f]">Note complémentaire</label>
        <%= text_area_tag :closure_note, nil, rows: 4, id: "closure_note", class: "textarea textarea-bordered w-full", placeholder: "Explique brièvement le contexte de fermeture..." %>
      </div>
      <div class="modal-action">
        <button type="button" class="btn btn-sm" onclick="document.getElementById('close_mission_modal').close()">Annuler</button>
        <%= form.button type: :submit, class: "btn btn-sm border-[#e7b2bb] bg-[#fff1f3] text-[#b43e53] hover:bg-[#ffe5e9]" do %>
          Confirmer la clôture
        <% end %>
      </div>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
  function toggleCloseMissionFields() {
    const reasonField = document.getElementById('closure_reason');
    const candidateField = document.getElementById('placed-candidate-field');
    const noteField = document.getElementById('closure-note-field');
    const noteInput = document.getElementById('closure_note');
    const selectedCandidateId = document.getElementById('selected-candidate-id');
    const selectedCandidateCard = document.getElementById('selected-candidate-card');
    const candidateSearch = document.getElementById('candidate-search');
    if (!reasonField || !candidateField || !noteField || !noteInput || !selectedCandidateId || !selectedCandidateCard || !candidateSearch) return;

    const isPlaced = reasonField.value === 'Mission gagnee';
    candidateField.classList.toggle('hidden', !isPlaced);
    noteField.classList.toggle('hidden', isPlaced);
    noteInput.required = false;
    if (!isPlaced) {
      selectedCandidateId.value = '';
      selectedCandidateCard.innerHTML = '';
      selectedCandidateCard.classList.add('hidden');
      candidateSearch.value = '';
      filterMissionCandidates('');
    }
  }

  function filterMissionCandidates(query) {
    const normalizedQuery = (query || '').toLowerCase().trim();
    document.querySelectorAll('.mission-candidate-result').forEach((item) => {
      const name = (item.dataset.candidateName || '').toLowerCase();
      item.classList.toggle('hidden', normalizedQuery.length > 0 && !name.includes(normalizedQuery));
    });
  }

  function selectMissionCandidate(button) {
    const selectedCandidateId = document.getElementById('selected-candidate-id');
    const selectedCandidateCard = document.getElementById('selected-candidate-card');
    const candidateSearch = document.getElementById('candidate-search');
    if (!selectedCandidateId || !selectedCandidateCard || !candidateSearch) return;

    selectedCandidateId.value = button.dataset.candidateId;
    candidateSearch.value = button.dataset.candidateName;
    selectedCandidateCard.innerHTML = button.innerHTML;
    selectedCandidateCard.classList.remove('hidden');
  }

  document.addEventListener('turbo:load', toggleCloseMissionFields);
  document.addEventListener('DOMContentLoaded', toggleCloseMissionFields);
</script>

<dialog id="timeline_modal" class="modal">
  <div class="modal-box max-w-2xl rounded-2xl border border-[#ead5ce] bg-white">
    <h3 class="text-lg font-semibold text-[#6f332b]">Timeline mission complete</h3>
    <p class="mt-1 text-xs text-[#8a6170]">Base planning: sourcing 2 semaines + preselection 1 semaine + finalisation sur 6 a 8 semaines.</p>
    <ul class="timeline timeline-snap-icon timeline-compact timeline-vertical mt-4 w-full">
      <% timeline_steps.each_with_index do |step, idx| %>
        <% step_date = timeline_start_date + step[:offset_days].days %>
        <% step_state =
          if idx < current_step_index
            :completed
          elsif idx == current_step_index
            :current
          else
            :upcoming
          end
        %>
        <li>
          <div class="timeline-middle">
            <span class="flex h-6 w-6 items-center justify-center text-sm font-semibold <%= step_state == :completed ? 'text-[#2f6b3c]' : (step_state == :current ? 'text-[#a33d68]' : 'text-[#b49aa4]') %>">
              <%= step_state == :completed ? "✓" : (step_state == :current ? "●" : "○") %>
            </span>
          </div>
          <div class="timeline-end ms-2 m-2 w-full rounded-lg border border-[#ead2dc] bg-[#fff8fb]/95 p-3">
            <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-[#9a5a68]"><%= format_fr_date.call(step_date) %></p>
            <div class="mb-1 pt-0.5 text-[15px] font-semibold text-[#5b2633]"><%= step[:title] %></div>
            <p class="text-sm text-[#6b4653]"><%= step[:desc] %></p>
          </div>
          <% unless idx == timeline_steps.size - 1 %><hr class="border-[#dcc2ce]" /><% end %>
        </li>
      <% end %>
    </ul>
    <div class="modal-action">
      <form method="dialog"><button class="btn btn-sm">Fermer</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
