<div id="candidate-note-<%= note.id %>" class="rounded-2xl border border-[#ead2dc] bg-white p-4">

  <%# Mode affichage %>
  <div class="note-display">
    <div class="flex items-start justify-between gap-3">
      <div class="flex items-center gap-2">
        <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#fff0f6] text-[11px] font-bold text-[#ed0e64]">
          <%= note.user.first_name.to_s.first.upcase %><%= note.user.last_name.to_s.first.upcase %>
        </span>
        <div>
          <p class="text-[13px] font-semibold text-[#4c1f2a]"><%= note.user.first_name %> <%= note.user.last_name %></p>
          <p class="text-[11px] text-[#9a5a68]">
            <%= note.created_at.strftime("%d/%m/%Y à %H:%M") %>
            <% if note.updated_at > note.created_at + 5.seconds %>
              · <span class="italic">modifiée</span>
            <% end %>
          </p>
        </div>
      </div>
      <% if note.user == current_user %>
        <div class="flex items-center gap-1">
          <button type="button"
            onclick="editNote(<%= note.id %>)"
            class="flex h-7 w-7 items-center justify-center rounded-full border border-[#ead2dc] bg-white text-[#9a5a68] transition hover:border-[#ed0e64] hover:text-[#ed0e64]"
            title="Modifier">
            <i class="fa-regular fa-pen-to-square text-[10px]"></i>
          </button>
          <%= button_to candidate_candidate_note_path(note.candidate, note), method: :delete,
                data: { turbo_stream: true, turbo_confirm: "Supprimer cette note ?" },
                class: "flex h-7 w-7 items-center justify-center rounded-full border border-[#ead2dc] bg-white text-[#9a5a68] transition hover:border-red-200 hover:text-red-500",
                title: "Supprimer" do %>
            <i class="fa-solid fa-trash-can text-[10px]"></i>
          <% end %>
        </div>
      <% end %>
    </div>
    <p class="mt-3 text-[13px] leading-relaxed text-[#4c1f2a] whitespace-pre-wrap"><%= note.body %></p>
  </div>

  <%# Mode édition (masqué par défaut) %>
  <% if note.user == current_user %>
    <div class="note-edit hidden">
      <%= form_with model: [note.candidate, note], data: { turbo_stream: true } do |f| %>
        <%= f.text_area :body,
              rows: 4,
              class: "w-full rounded-2xl border border-[#ed0e64] bg-white px-4 py-3 text-[13px] text-[#4c1f2a] focus:outline-none focus:ring-1 focus:ring-[#ed0e64] resize-none" %>
        <div class="mt-2 flex gap-2">
          <%= f.submit "Enregistrer",
                class: "cursor-pointer rounded-full bg-[#ed0e64] px-4 py-1.5 text-[12px] font-semibold text-white transition hover:bg-[#c4084e]" %>
          <button type="button"
            onclick="cancelEdit(<%= note.id %>)"
            class="rounded-full border border-[#ead2dc] px-4 py-1.5 text-[12px] font-medium text-[#9a5a68] transition hover:text-[#5b2633]">
            Annuler
          </button>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
