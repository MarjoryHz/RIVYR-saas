<div id="notes-form">
  <%= form_with model: [candidate, note], data: { turbo_stream: true } do |f| %>
    <%= f.text_area :body,
          placeholder: "Votre note…",
          rows: 5,
          class: "w-full rounded-2xl border border-[#ead2dc] bg-white px-4 py-3 text-[13px] text-[#4c1f2a] placeholder-[#c4a0b0] focus:border-[#ed0e64] focus:outline-none focus:ring-1 focus:ring-[#ed0e64] resize-none transition" %>
    <% if note.errors[:body].any? %>
      <p class="mt-1 text-xs text-red-600"><%= note.errors[:body].first %></p>
    <% end %>
    <%= f.submit "Ajouter la note",
          class: "mt-3 w-full cursor-pointer rounded-full bg-[#ed0e64] px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-[#c4084e]" %>
  <% end %>
</div>
