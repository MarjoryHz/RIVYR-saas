<% surface_card_class = "rounded-[1.45rem] border border-base-100/70 bg-base-100/88 shadow-lg" %>

<div class="mx-auto max-w-7xl p-4 md:p-6">
  <section class="space-y-6">
    <header class="space-y-5">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[#a15c70]">Finance Rivyr</p>
        <h1 class="text-3xl font-semibold tracking-tight text-base-content md:text-4xl">Placements</h1>
        <p class="text-base text-base-content/60">Validation des placements, conformité de l'offre et préparation du cycle finance.</p>
      </div>

      <div class="inline-flex flex-wrap items-center rounded-full border border-base-200/80 bg-base-100/72 p-1 text-[#7f5260] shadow-sm">
        <%= link_to placements_path(tab: "in_progress"), class: "inline-flex items-center rounded-full px-6 py-3 text-base #{ @tab == 'in_progress' ? 'bg-[#f4a58a] font-semibold text-white' : 'font-medium text-base-content/75 transition hover:text-base-content' }" do %>
          En cours (<%= @placement_counts["in_progress"] %>)
        <% end %>
        <%= link_to placements_path(tab: "validated"), class: "inline-flex items-center rounded-full px-6 py-3 text-base #{ @tab == 'validated' ? 'bg-[#f4a58a] font-semibold text-white' : 'font-medium text-base-content/75 transition hover:text-base-content' }" do %>
          Validés (<%= @placement_counts["validated"] %>)
        <% end %>
        <%= link_to placements_path(tab: "refused"), class: "inline-flex items-center rounded-full px-6 py-3 text-base #{ @tab == 'refused' ? 'bg-[#f4a58a] font-semibold text-white' : 'font-medium text-base-content/75 transition hover:text-base-content' }" do %>
          Refusés (<%= @placement_counts["refused"] %>)
        <% end %>
      </div>

      <div class="grid min-w-0 overflow-hidden md:grid-cols-3 <%= surface_card_class %>">
        <div class="p-4 md:border-r md:border-base-200/80 md:pr-6">
          <p class="text-3xl font-semibold text-base-content"><%= @placement_metrics[:signatures_count] %></p>
          <p class="mt-1 text-base text-base-content/60">Signatures</p>
        </div>
        <div class="p-4 md:border-r md:border-base-200/80 md:px-6">
          <p class="text-3xl font-semibold text-base-content"><%= @placement_metrics[:placements_count] %></p>
          <p class="mt-1 text-base text-base-content/60">Placements validés</p>
        </div>
        <div class="p-4 md:px-6">
          <p class="text-3xl font-semibold text-base-content"><%= @placement_metrics[:payments_count] %></p>
          <p class="mt-1 text-base text-base-content/60">Paiements déclenchés</p>
        </div>
      </div>
    </header>

    <div class="<%= surface_card_class %> overflow-hidden">
      <div class="border-b border-base-200/70 px-6 py-4">
        <div class="relative">
          <div class="flex flex-wrap gap-3">
            <button
              type="button"
              class="inline-flex items-center gap-2 rounded-2xl border border-base-200 bg-base-100/75 px-5 py-3 text-base font-medium text-base-content/70 shadow-sm transition hover:bg-base-100/95"
              aria-controls="placements-filtres"
              aria-expanded="false"
              onclick="document.getElementById('placements-filtres').classList.toggle('hidden'); this.setAttribute('aria-expanded', String(!document.getElementById('placements-filtres').classList.contains('hidden')));">
              <i class="fa-solid fa-sliders text-[#ed0e64]"></i>
              Filtres
              <i class="fa-solid fa-angle-down text-xs text-[#ed0e64]"></i>
            </button>
          </div>

          <div id="placements-filtres" class="absolute inset-x-0 top-full z-30 mt-3 hidden rounded-[1.45rem] border border-base-200 bg-base-100 p-4 shadow-xl">
            <%= form_with url: placements_path, method: :get, class: "grid gap-3 md:grid-cols-2 xl:grid-cols-5", html: { onsubmit: "document.getElementById('placements-filtres').classList.add('hidden')" } do %>
              <%= hidden_field_tag :tab, @tab %>
              <div>
                <label for="amount-filter" class="mb-1 block text-sm font-medium text-base-content/70">Rémunération</label>
                <%= select_tag :amount,
                  options_for_select(
                    [
                      ["Tous les montants", ""],
                      ["Moins de 5 000 €", "under_5000"],
                      ["5 000 € à 10 000 €", "5000_10000"],
                      ["10 000 € à 20 000 €", "10000_20000"],
                      ["Plus de 20 000 €", "over_20000"]
                    ],
                    @amount_filter
                  ),
                  id: "amount-filter",
                  class: "select select-bordered w-full" %>
              </div>

              <div>
                <label for="region-filter" class="mb-1 block text-sm font-medium text-base-content/70">Ville</label>
                <%= select_tag :region,
                  options_for_select([["Toutes les villes", ""]] + @region_options.map { |region| [region, region] }, @region_filter),
                  id: "region-filter",
                  class: "select select-bordered w-full" %>
              </div>

              <div>
                <label for="company-filter" class="mb-1 block text-sm font-medium text-base-content/70">Entreprise</label>
                <%= select_tag :company,
                  options_for_select([["Toutes les sociétés", ""]] + @company_options.map { |company| [company, company] }, @company_filter),
                  id: "company-filter",
                  class: "select select-bordered w-full" %>
              </div>

              <div>
                <label for="q-filter" class="mb-1 block text-sm font-medium text-base-content/70">Recherche</label>
                <%= text_field_tag :q, @q, id: "q-filter", class: "input input-bordered w-full", placeholder: "Mission, candidat..." %>
              </div>

              <div class="flex items-end gap-2">
                <%= submit_tag "Appliquer", class: "btn btn-primary flex-1" %>
                <%= link_to "Réinitialiser", placements_path(tab: @tab), class: "btn btn-ghost" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <% if @placement_rows.any? %>
        <div class="divide-y divide-base-200/70">
          <% @placement_rows.each do |row| %>
            <% placement = row[:placement] %>
            <article class="px-6 py-5">
              <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_auto] xl:items-center">
                <div class="space-y-4">
                  <div class="min-w-0 flex items-center gap-3">
                    <h2 class="min-w-0 truncate whitespace-nowrap text-xl font-semibold leading-tight text-base-content md:text-2xl"><%= row[:mission_title] %></h2>
                    <% if row[:region_name].present? %>
                      <span class="shrink-0 text-base-content/30">|</span>
                      <span class="shrink-0 whitespace-nowrap text-sm font-medium text-base-content/55 md:text-base"><%= row[:region_name] %></span>
                    <% end %>
                  </div>

                  <div class="flex min-h-[3.25rem] items-center gap-4 text-base text-base-content/75">
                    <% if row[:company_logo].present? %>
                      <div class="flex h-12 w-12 items-center justify-center overflow-hidden rounded-full border border-base-200 bg-base-100">
                        <%= image_tag row[:company_logo], alt: row[:company_name], class: "h-full w-full object-cover" %>
                      </div>
                    <% else %>
                      <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/18 text-[#ed0e64]">
                        <i class="fa-regular fa-building text-lg"></i>
                      </div>
                    <% end %>

                    <div class="space-y-1">
                      <p class="font-medium text-base-content"><%= row[:company_name] %></p>
                      <p class="text-sm text-base-content/55"><%= row[:candidate_name] %></p>
                    </div>
                  </div>

                  <div class="flex flex-wrap gap-2 text-sm">
                    <span class="inline-flex items-center rounded-full border px-3 py-1 font-semibold <%= row[:workflow_badge_class] %>"><%= row[:workflow_label] %></span>
                    <span class="inline-flex items-center rounded-full border border-[#ead7dc] bg-base-100/82 px-3 py-1 text-[#8c5665]"><%= row[:compliance_label] %></span>
                    <span class="inline-flex items-center rounded-full border border-[#ead7dc] bg-base-100/82 px-3 py-1 text-[#8c5665]"><%= row[:package_summary] %></span>
                  </div>
                </div>

                <div class="flex flex-wrap items-center gap-3 xl:justify-end">
                  <p class="min-w-[8rem] text-xl font-semibold md:text-2xl xl:text-right"><%= row[:salary_cents].positive? ? number_to_currency(row[:salary_cents] / 100.0, unit: "€", precision: 0) : "À confirmer" %></p>

                  <%= link_to placement_path(placement), class: "inline-flex min-w-[11rem] items-center justify-center rounded-full border border-[#f1a38b] bg-[#f4a58a] px-6 py-2.5 text-base font-semibold text-white shadow-sm transition hover:border-[#e39479] hover:bg-[#ee977c]" do %>
                    Voir le placement
                  <% end %>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="p-8 text-center text-base-content/65">
          Aucun placement dans cet onglet pour le moment.
        </div>
      <% end %>
    </div>
  </section>
</div>
