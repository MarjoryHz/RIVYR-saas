                <span class="inline-flex h-8 w-8 items-center justify-center rounded-2xl bg-[#fdeef3] text-[#b14360]">
                  <i class="fa-solid fa-user"></i>
                </span>
                <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-[#8b4452]">Information candidat</h3>
              </div>
              <div class="mt-4 space-y-3 text-sm text-base-content/80">
                <div class="rounded-2xl border border-base-200 bg-white px-3 py-2" data-editable-field>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/45">Nom et prénom</p>
