                    </div>
                    <div class="flex items-center gap-2">
                      <button type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-[#ed0e64] bg-[#fff1f6] text-[#ed0e64]" data-document-key="candidate_offer" data-document-label="Offre acceptée du candidat" data-action="click->placement-billing-editor#openDocumentModal"><i class="fa-solid fa-cloud-arrow-up"></i></button>
