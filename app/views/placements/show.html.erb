                    <p class="mt-2 font-semibold text-[#4c1f2a]"><%= client_name %></p>
                    <p class="text-sm text-[#7b4b5a]"><%= client.location.presence || "Adresse client non renseignée" %></p>
                    <p class="text-sm text-[#7b4b5a]">Contact: <%= [@mission.client_contact.first_name, @mission.client_contact.last_name].compact.join(" ") %></p>
                    <p class="text-sm text-[#7b4b5a]"><%= @mission.client_contact.email.presence || "Email non renseigné" %></p>
                  </div>
                  <div class="rounded-2xl border border-[#f0dce3] bg-[#fff9fb] p-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">Mission</p>
                    <p class="mt-2 font-semibold text-[#4c1f2a]"><%= @mission.title %></p>
                    <p class="text-sm text-[#7b4b5a]">Candidat: <%= @candidate.display_name %></p>
                    <p class="text-sm text-[#7b4b5a]">Démarrage: <%= placement_start_date.present? ? l(placement_start_date) : "Non renseigné" %></p>
                  </div>
                </div>
                <div class="mt-6 overflow-hidden rounded-2xl border border-[#f0dce3]">
                  <table class="min-w-full text-sm">
                    <thead class="bg-[#fff7fa] text-left text-[11px] font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">
                      <tr>
                        <th class="px-4 py-3">Description</th>
                        <th class="px-4 py-3 text-right">Montant HT</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr class="border-t border-[#f3e2e8]">
                        <td class="px-4 py-4 text-[#4c1f2a]">Honoraires de placement Rivyr - <%= @mission.title %></td>
                        <td class="px-4 py-4 text-right font-semibold text-[#4c1f2a]"><%= number_to_currency(invoice_ht_cents / 100.0, unit: "€") %></td>
                      </tr>
                    </tbody>
                  </table>
                </div>
                <div class="mt-4 ml-auto max-w-sm space-y-2 rounded-2xl border border-[#f0dce3] bg-[#fff9fb] p-4 text-sm">
                  <div class="flex items-center justify-between text-[#7b4b5a]"><span>Total HT</span><span><%= number_to_currency(invoice_ht_cents / 100.0, unit: "€") %></span></div>
                  <div class="flex items-center justify-between text-[#7b4b5a]"><span>TVA 20%</span><span><%= number_to_currency(invoice_vat_cents / 100.0, unit: "€") %></span></div>
                  <div class="flex items-center justify-between text-base font-semibold text-[#4c1f2a]"><span>Total TTC</span><span><%= number_to_currency(invoice_ttc_cents / 100.0, unit: "€") %></span></div>
                </div>
              </div>
              <div class="modal-action">
                <form method="dialog">
                  <button class="btn btn-ghost">Fermer</button>
                </form>
                <button type="button" class="btn border-[#ed0e64] bg-[#ed0e64] text-white hover:border-[#cf0c57] hover:bg-[#cf0c57]" onclick="document.getElementById('client-invoice-modal').close(); document.getElementById('placement-invoice-success-modal').showModal();">
                  Envoyer la facture
                </button>
              </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button>close</button></form>
          </dialog>
          <dialog id="submit-client-invoice-modal" class="modal">
            <div class="modal-box max-w-3xl rounded-[1.75rem] border border-[#f2d5df] bg-base-100 shadow-2xl">
              <div class="flex items-start justify-between gap-4">
                <div class="flex items-center gap-3">
                  <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[#ed0e64] text-lg font-semibold text-white">R</span>
                  <div>
                    <h3 class="text-2xl font-semibold text-[#4c1f2a]">Créer la facture client</h3>
                    <p class="mt-1 text-sm text-[#7b4b5a]">Prévisualisation d'une facture Rivyr à soumettre après validation des documents.</p>
                  </div>
                </div>
                <form method="dialog">
                  <button class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-base-200 bg-base-100/80 text-base-content/60 transition hover:bg-base-100 hover:text-base-content">
                    <i class="fa-solid fa-xmark"></i>
                  </button>
                </form>
              </div>
              <div class="mt-6 rounded-[1.5rem] border border-[#f0dce3] bg-white p-6">
                <div class="flex items-center justify-between gap-6 border-b border-[#f3e2e8] pb-4">
                  <div>
                    <p class="text-2xl font-semibold text-[#ed0e64]">Rivyr</p>
                    <p class="text-sm text-[#7b4b5a]">Facture client - Préparation</p>
                  </div>
                  <div class="text-right text-sm text-[#7b4b5a]">
                    <p>Réf: RIV-CLIENT-<%= @placement.id %></p>
                    <p>Date: <%= l(Date.current) %></p>
                  </div>
                </div>
                <div class="mt-5 grid gap-4 md:grid-cols-2">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">Facturer à</p>
                    <p class="mt-2 font-semibold text-[#4c1f2a]"><%= client_name %></p>
                    <p class="text-sm text-[#7b4b5a]"><%= client.location.presence || "Adresse client non renseignée" %></p>
                    <p class="text-sm text-[#7b4b5a]"><%= @mission.client_contact.email.presence || "Email non renseigné" %></p>
                  </div>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">Détail mission</p>
                    <p class="mt-2 font-semibold text-[#4c1f2a]"><%= @mission.title %></p>
                    <p class="text-sm text-[#7b4b5a]">Placement: <%= @candidate.display_name %></p>
                    <p class="text-sm text-[#7b4b5a]">Date de démarrage: <%= placement_start_date.present? ? l(placement_start_date) : "Non renseignée" %></p>
                  </div>
                </div>
                <div class="mt-6 rounded-2xl border border-[#f0dce3] bg-[#fff9fb] p-4">
                  <div class="flex items-center justify-between text-sm text-[#7b4b5a]">
                    <span>Montant HT</span>
                    <span><%= number_to_currency(invoice_ht_cents / 100.0, unit: "€") %></span>
                  </div>
                  <div class="mt-2 flex items-center justify-between text-sm text-[#7b4b5a]">
                    <span>TVA 20%</span>
                    <span><%= number_to_currency(invoice_vat_cents / 100.0, unit: "€") %></span>
                  </div>
                  <div class="mt-3 flex items-center justify-between text-base font-semibold text-[#4c1f2a]">
                    <span>Total TTC</span>
                    <span><%= number_to_currency(invoice_ttc_cents / 100.0, unit: "€") %></span>
                  </div>
                </div>
              </div>
              <div class="modal-action">
                <form method="dialog">
                  <button class="btn btn-ghost">Fermer</button>
                </form>
                <button type="button" class="btn border-[#ed0e64] bg-[#ed0e64] text-white hover:border-[#cf0c57] hover:bg-[#cf0c57]" onclick="document.getElementById('submit-client-invoice-modal').close(); document.getElementById('placement-invoice-success-modal').showModal();">
                  Soumettre à Rivyr
                </button>
              </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button>close</button></form>
          </dialog>
          <dialog id="placement-invoice-success-modal" class="modal">
            <div class="modal-box max-w-md rounded-[1.75rem] border border-[#f2d5df] bg-base-100 text-center shadow-2xl">
              <form method="dialog" class="flex justify-end">
                <button class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-base-200 bg-base-100/80 text-base-content/60 transition hover:bg-base-100 hover:text-base-content">
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </form>

              <div class="mx-auto mt-2 inline-flex h-16 w-16 items-center justify-center rounded-full bg-[#fff1f6] text-[#ed0e64] shadow-[0_12px_24px_rgba(237,14,100,0.16)]">
                <i class="fa-solid fa-check text-2xl"></i>
              </div>

              <h3 class="mt-4 text-2xl font-semibold text-[#4c1f2a]">Demande prise en compte</h3>
              <p class="mt-2 text-sm text-[#7b4b5a]">
                La facture a bien été enregistrée et transmise dans le flux Rivyr.
              </p>

              <form method="dialog" class="mt-6">
                <button class="btn border-[#ed0e64] bg-[#ed0e64] text-white hover:border-[#cf0c57] hover:bg-[#cf0c57]">Fermer</button>
              </form>
            </div>
            <form method="dialog" class="modal-backdrop"><button>close</button></form>
          </dialog>
          <% if current_user&.role_admin? && @placement.workflow_in_progress? %>
            <div class="mt-3 flex flex-wrap gap-3">
              <%= button_to "Valider la conformité", validate_compliance_placement_path(@placement), method: :patch, class: "btn border-[#cfe4d4] bg-[#edf8f0] text-[#2f6b3c] hover:bg-[#e4f4e8]" %>
              <%= button_to "Refuser", refuse_compliance_placement_path(@placement), method: :patch, params: { admin_review_note: "Placement refusé par l'admin Rivyr" }, class: "btn border-[#f1c9d3] bg-[#fff1f4] text-[#b14360] hover:bg-[#ffe6ec]" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="card border border-base-100/70 bg-base-100/86 shadow">
        <div class="card-body p-4">
          <div class="placement-timeline-scroll">
            <div class="flex min-w-[1250px] items-start gap-0">
              <% @stage_states.each_with_index do |step, index| %>
                <div class="flex min-w-[190px] items-start">
                  <div class="space-y-2">
                    <div class="flex items-center gap-2">
                      <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border <%= step[:done] ? 'border-success bg-success text-success-content' : (step[:active] ? 'border-warning bg-warning text-warning-content' : 'border-base-300 bg-base-200 text-base-content/50') %>">
                        <% if step[:done] %>
                          <i class="fa-solid fa-check text-[10px]"></i>
                        <% elsif step[:active] %>
                          <i class="fa-solid fa-hourglass-half text-[10px]"></i>
                        <% else %>
                          <i class="fa-solid fa-circle text-[6px]"></i>
                        <% end %>
                      </span>
                      <span class="text-xs font-medium text-base-content/80"><%= step[:label] %></span>
                    </div>
                    <div class="h-1 w-40 rounded-full <%= step[:done] ? 'bg-success/60' : (step[:active] ? 'bg-warning/60' : 'bg-base-200') %>"></div>
                  </div>
                  <% unless index == @stage_states.size - 1 %>
                    <div class="mt-3 h-px w-4 bg-base-300"></div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-4 xl:grid-cols-12">
        <div class="xl:col-span-4 space-y-4">
          <div class="card border border-base-100/70 bg-base-100/90 shadow">
            <div class="card-body p-4">
              <h2 class="text-xl font-semibold text-base-content">Candidat retenu</h2>
              <div class="mt-2 flex items-center gap-3">
                <%= image_tag avatar_asset_src(@candidate), alt: @candidate.display_name, class: "h-14 w-14 rounded-full object-cover ring-2 ring-white shadow-sm" %>
                <div>
                  <p class="text-lg font-semibold text-base-content"><%= @candidate.display_name %></p>
                  <p class="text-sm text-base-content/65">Demarrage: <%= @placement.hired_at.present? ? l(@placement.hired_at) : "-" %></p>
                </div>
              </div>
              <div class="mt-3 grid grid-cols-2 gap-2 text-sm">
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Offre acceptée</p>
                  <p class="font-medium text-base-content">
                    <% accepted = (@candidate.status == "placed" || @placement.hired_at.present?) %>
                    <i class="fa-solid <%= accepted ? 'fa-circle-check text-success' : 'fa-circle-xmark text-error' %>"></i>
                    <%= accepted ? "Oui" : "Non" %>
                  </p>
                </div>
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Source</p>
                  <p class="font-medium text-base-content">
                    <i class="<%= source_icon %>"></i>
                    <%= @candidate.source == "jobboard" ? "Hellowork / Jobboard" : @candidate.source %>
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="card border border-base-100/70 bg-base-100/90 shadow">
            <div class="card-body p-4">
              <h2 class="text-xl font-semibold text-base-content">Stats mission</h2>
              <div class="mt-2 grid grid-cols-2 gap-2 text-sm">
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Duree</p>
                  <p class="font-semibold"><%= @mission_stats[:duration_days].present? ? "#{@mission_stats[:duration_days]} jours" : "-" %></p>
                </div>
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Rencontres</p>
                  <p class="font-semibold"><%= @mission_stats[:interviewed_candidates] %></p>
                </div>
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Presents</p>
                  <p class="font-semibold"><%= @mission_stats[:presented_candidates] %></p>
                </div>
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Postules</p>
                  <p class="font-semibold"><%= @mission_stats[:applied_candidates] %></p>
                </div>
                <div class="col-span-2 rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Sources</p>
                  <p class="font-semibold"><%= @mission_stats[:sourced_candidates] %></p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="xl:col-span-5 space-y-4">
          <div class="card border border-base-100/70 bg-base-100/90 shadow">
            <div class="card-body p-4">
              <h2 class="text-xl font-semibold text-base-content">Resume contractuel et financier</h2>
              <div class="mt-2 space-y-2 rounded-xl border border-base-200 bg-base-100/80 p-3 text-sm md:text-base">
                <p>
                  <i class="fa-solid fa-file-signature text-primary"></i>
                  Contrat signé le <strong><%= @mission.opened_at.present? ? l(@mission.opened_at) : "-" %></strong>
                </p>
                <p>
                  <i class="fa-solid fa-user-check text-success"></i>
                  Promesse d'embauche <strong><%= @placement.hired_at.present? ? "validée" : "à confirmer" %></strong>
                </p>
                <p>Date de fin <strong><%= closed_at.present? ? l(closed_at) : "-" %></strong></p>
                <p>Montant facture <strong><%= number_to_currency(billed_amount_cents / 100.0, unit: "€") %></strong></p>
                <p>Commission freelance <strong><%= number_to_currency(mission_amount_cents / 100.0, unit: "€") %></strong></p>
              </div>
            </div>
          </div>

          <div class="card border border-base-100/70 bg-base-100/90 shadow">
            <div class="card-body p-4">
              <h2 class="text-xl font-semibold text-base-content">Checklist de validation facturation</h2>
              <div class="mt-2 space-y-2">
                <% @validation_checks.each do |check| %>
                  <div class="flex items-start justify-between gap-3 rounded-lg border border-base-200 bg-base-100/80 p-2">
                    <div>
                      <p class="text-sm font-medium text-base-content"><%= check[:label] %></p>
                      <p class="text-xs text-base-content/60"><%= check[:detail] %></p>
                    </div>
                    <i class="fa-solid <%= check[:ok] ? 'fa-circle-check text-success' : 'fa-circle-xmark text-error' %>"></i>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <aside class="xl:col-span-3 card border border-base-100/70 bg-base-100/90 shadow">
          <div class="card-body p-4">
            <h2 class="text-xl font-semibold text-base-content">Suivi Rivyr</h2>
            <div class="placement-followups-scroll mt-2 space-y-2">
              <% if @rivyr_followups.any? %>
                <% @rivyr_followups.first(10).each do |event| %>
                  <% badge_class = case event[:tone]
                  when "success" then "badge-success"
                  when "action" then "badge-error"
                  else "badge-info"
                  end %>
                  <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                    <p class="text-xs text-base-content/55"><%= l(event[:occurred_at], format: "%d/%m/%Y %H:%M") %></p>
                    <div class="mt-1 flex items-start gap-2">
                      <span class="badge badge-xs <%= badge_class %>"></span>
                      <div>
                        <p class="text-sm font-medium text-base-content"><%= event[:title] %></p>
                        <p class="text-xs text-base-content/70"><%= event[:detail] %></p>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% else %>
                <p class="text-sm text-base-content/60">Pas encore d'evenement de suivi.</p>
              <% end %>
            </div>
          </div>
        </aside>
      </div>

      <div class="flex flex-wrap gap-2 pt-1">
        <%= link_to "Retour finances", (current_user&.role_freelance? ? dashboard_freelance_finance_path : placements_path), class: "btn btn-ghost btn-sm" %>
