                <div>
                  <p class="text-sm font-semibold text-[#5f3647]" data-placement-billing-editor-target="fieldLabel">Document</p>
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-[#5f3647]">Depuis l'ordinateur</label>
                  <input type="file" class="file-input file-input-bordered w-full" data-placement-billing-editor-target="fileInput">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-[#5f3647]">Ou depuis un lien</label>
                  <input type="text" placeholder="https://..." class="input input-bordered w-full" data-placement-billing-editor-target="remoteInput">
                </div>
              </div>
              <div class="modal-action">
                <button type="button" class="btn btn-ghost" onclick="document.getElementById('placement-document-modal').close()">Annuler</button>
                <button type="button" class="btn border-[#ed0e64] bg-[#ed0e64] text-white hover:border-[#cf0c57] hover:bg-[#cf0c57]" data-action="click->placement-billing-editor#saveDocument">Valider le document</button>
              </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button>close</button></form>
          </dialog>
          <dialog id="client-invoice-modal" class="modal">
