                <div class="rounded-2xl border border-base-200 bg-white px-3 py-2" data-editable-field>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/45">Numéro de téléphone</p>
                  <div class="mt-1 flex items-start justify-between gap-3" data-field-display>
                    <p class="font-semibold text-base-content" data-field-value><%= @candidate.phone.presence || "Non renseigné" %></p>
                    <button type="button" class="text-[#b14360]" data-action="click->placement-billing-editor#toggleField"><i class="fa-solid fa-phone"></i></button>
                  </div>
