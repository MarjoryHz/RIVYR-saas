                    <p class="mt-2 text-lg font-semibold text-[#4c1f2a]">Rivyr</p>
                    <p class="text-sm text-[#7b4b5a]">Finance & facturation</p>
                    <p class="text-sm text-[#7b4b5a]">12 avenue de l'Exécution</p>
                    <p class="text-sm text-[#7b4b5a]">75008 Paris</p>
                  </div>
                  <div class="text-right">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#9a5a68]">Facture</p>
