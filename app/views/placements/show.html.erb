                    </div>
                    <div class="flex items-center gap-2">
                      <button type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-[#ed0e64] bg-[#fff1f6] text-[#ed0e64]" data-document-key="client_offer" data-document-label="Offre signée du client" data-action="click->placement-billing-editor#openDocumentModal"><i class="fa-solid fa-cloud-arrow-up"></i></button>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <section class="rounded-[1.35rem] border border-[#f0dce3] bg-[#fffafc] p-4">
              <div class="flex items-center gap-2">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-2xl bg-[#fdeef3] text-[#b14360]">
                  <i class="fa-solid fa-briefcase"></i>
                </span>
                <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-[#8b4452]">Information placement</h3>
              </div>
              <div class="mt-4 space-y-3 text-sm text-base-content/80">
                <div class="rounded-2xl border border-base-200 bg-white px-3 py-2" data-editable-field>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/45">Rémunération retenue</p>
                  <div class="mt-1 flex items-start justify-between gap-3" data-field-display>
                    <p class="font-semibold text-base-content" data-field-value><%= retained_compensation %></p>
                    <button type="button" class="text-[#b14360]" data-action="click->placement-billing-editor#toggleField"><i class="fa-solid fa-euro-sign"></i></button>
                  </div>
                  <div class="mt-2 hidden gap-2" data-field-editor>
                    <input type="text" value="<%= retained_compensation %>" class="input input-bordered input-sm w-full">
                    <button type="button" class="btn btn-sm border-[#ed0e64] bg-[#ed0e64] text-white" data-action="click->placement-billing-editor#saveField"><i class="fa-solid fa-check"></i></button>
                    <button type="button" class="btn btn-sm" data-action="click->placement-billing-editor#cancelField"><i class="fa-solid fa-xmark"></i></button>
                  </div>
                </div>
                <div class="rounded-2xl border border-base-200 bg-white px-3 py-2" data-editable-field>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/45">Nom du poste</p>
                  <div class="mt-1 flex items-start justify-between gap-3" data-field-display>
                    <p class="font-semibold text-base-content" data-field-value><%= @mission.title %></p>
                    <button type="button" class="text-[#b14360]" data-action="click->placement-billing-editor#toggleField"><i class="fa-solid fa-briefcase"></i></button>
                  </div>
                  <div class="mt-2 hidden gap-2" data-field-editor>
                    <input type="text" value="<%= @mission.title %>" class="input input-bordered input-sm w-full">
                    <button type="button" class="btn btn-sm border-[#ed0e64] bg-[#ed0e64] text-white" data-action="click->placement-billing-editor#saveField"><i class="fa-solid fa-check"></i></button>
                    <button type="button" class="btn btn-sm" data-action="click->placement-billing-editor#cancelField"><i class="fa-solid fa-xmark"></i></button>
                  </div>
                </div>
                <div class="rounded-2xl border border-base-200 bg-white px-3 py-2" data-editable-field>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/45">Date de démarrage</p>
                  <div class="mt-1 flex items-start justify-between gap-3" data-field-display>
                    <p class="font-semibold text-base-content" data-field-value><%= placement_start_date.present? ? l(placement_start_date) : "Non renseignée" %></p>
                    <button type="button" class="text-[#b14360]" data-action="click->placement-billing-editor#toggleField"><i class="fa-regular fa-calendar"></i></button>
                  </div>
                  <div class="mt-2 hidden gap-2" data-field-editor>
                    <input type="text" value="<%= placement_start_date.present? ? l(placement_start_date) : "Non renseignée" %>" class="input input-bordered input-sm w-full">
                    <button type="button" class="btn btn-sm border-[#ed0e64] bg-[#ed0e64] text-white" data-action="click->placement-billing-editor#saveField"><i class="fa-solid fa-check"></i></button>
                    <button type="button" class="btn btn-sm" data-action="click->placement-billing-editor#cancelField"><i class="fa-solid fa-xmark"></i></button>
                  </div>
                </div>
              </div>
            </section>

            <section class="rounded-[1.35rem] border border-[#f0dce3] bg-[#fffafc] p-4">
