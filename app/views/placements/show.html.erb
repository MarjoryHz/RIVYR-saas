                    <button type="button" class="btn btn-sm" data-action="click->placement-billing-editor#cancelField"><i class="fa-solid fa-xmark"></i></button>
                  </div>
                </div>
                <div class="rounded-2xl border border-base-200 bg-white px-3 py-2" data-editable-field>
