                    <button type="button" class="btn btn-sm" data-action="click->placement-billing-editor#cancelField"><i class="fa-solid fa-xmark"></i></button>
                  </div>
                </div>
                <div class="rounded-2xl border border-base-200 bg-white px-3 py-2" data-editable-field>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/45">Adresse mail</p>
                  <div class="mt-1 flex items-start justify-between gap-3" data-field-display>
                    <p class="font-semibold text-base-content" data-field-value><%= @candidate.email.presence || "Non renseignée" %></p>
                    <button type="button" class="text-[#b14360]" data-action="click->placement-billing-editor#toggleField"><i class="fa-regular fa-envelope"></i></button>
                  </div>
                  <div class="mt-2 hidden gap-2" data-field-editor>
