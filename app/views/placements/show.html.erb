                  <div class="mt-1 flex items-start justify-between gap-3" data-field-display>
                    <div>
                      <p class="font-semibold text-base-content" data-field-value><%= [@mission.client_contact.first_name, @mission.client_contact.last_name].compact.join(" ") %></p>
                      <p class="mt-1 text-base-content/70"><%= @mission.client_contact.email.presence || "Email non renseigné" %></p>
                      <p class="text-base-content/70"><%= @mission.client_contact.phone.presence || "Téléphone non renseigné" %></p>
                    </div>
                    <button type="button" class="text-[#b14360]" data-action="click->placement-billing-editor#toggleField"><i class="fa-regular fa-address-card"></i></button>
                  </div>
                  <div class="mt-2 hidden gap-2" data-field-editor>
                    <input type="text" value="<%= [@mission.client_contact.first_name, @mission.client_contact.last_name].compact.join(" ") %>" class="input input-bordered input-sm w-full">
                    <button type="button" class="btn btn-sm border-[#ed0e64] bg-[#ed0e64] text-white" data-action="click->placement-billing-editor#saveField"><i class="fa-solid fa-check"></i></button>
                    <button type="button" class="btn btn-sm" data-action="click->placement-billing-editor#cancelField"><i class="fa-solid fa-xmark"></i></button>
                  </div>
                </div>
                <div class="rounded-2xl border border-base-200 bg-white px-3 py-3">
                  <div class="flex items-center justify-between gap-3">
                    <div>
                      <div class="flex items-center gap-2">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/45">Document à charger</p>
                        <% client_offer_received = @mission.contract_signed? %>
                        <span data-document-badge="client_offer" data-idle-class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold <%= document_badge_classes.call(false) %>" data-loaded-class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold <%= document_badge_classes.call(true) %>" class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold <%= document_badge_classes.call(client_offer_received) %>"><%= document_badge_label.call(client_offer_received) %></span>
                      </div>
                      <p class="mt-1 font-semibold text-base-content">Offre signée du client</p>
