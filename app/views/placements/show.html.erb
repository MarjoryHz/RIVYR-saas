<% client = @mission.client_contact.client %>
<% started_at = @mission.started_at || @mission.opened_at %>
<% closed_at = @mission.closed_at || (started_at ? started_at + 3.months : nil) %>
<% mission_amount_cents = @commission&.freelancer_share_cents.to_i %>
<% billed_amount_cents = @client_invoice&.amount_cents.to_i %>
<% duration_months = if started_at && closed_at
  ((closed_at.year * 12 + closed_at.month) - (started_at.year * 12 + started_at.month)) + 1
end %>
<% candidate_initials = [@candidate.first_name.to_s.first, @candidate.last_name.to_s.first].join.upcase %>
<% source_icon = case @candidate.source
when "linkedin" then "fa-brands fa-linkedin text-info"
when "jobboard" then "fa-solid fa-briefcase text-warning"
when "network" then "fa-solid fa-user-group text-primary"
when "referral" then "fa-solid fa-handshake text-secondary"
else "fa-solid fa-bullseye text-accent"
end %>
<% action_button_base = "btn btn-sm rounded-full border shadow-sm transition" %>
<% action_button_tone = lambda do |style|
  case style
  when "btn-primary"
    "border-[#f1a38b] bg-[#f4a58a] text-white hover:border-[#e39479] hover:bg-[#ee977c]"
  when "btn-secondary"
    "border-[#f0a1b2] bg-[#feeff3] text-[#b44a66] hover:border-[#e58ea3] hover:bg-[#fde3ea]"
  when "btn-accent"
    "border-[#f5b38f] bg-[#fff0e5] text-[#c56a42] hover:border-[#eca178] hover:bg-[#ffe5d4]"
  else
    "border-base-200 bg-base-100/90 text-[#7a4a55] hover:border-base-300 hover:bg-base-100"
  end
end %>

<div class="mx-auto max-w-7xl p-4 md:p-6">
  <section class="space-y-4">
    <div class="placement-summary-sticky space-y-4">
      <header class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
        <div class="space-y-1">
          <p class="badge badge-ghost border-base-300/60 bg-base-100/70">Finance Mission</p>
          <h1 class="text-2xl font-semibold tracking-tight text-base-content md:text-4xl"><%= @mission.title %></h1>
          <p class="text-xl text-base-content/85 md:text-3xl">
            <span class="text-sm align-middle text-base-content/60 md:text-base">Wallonie Engineering</span>
            <span class="mx-1 text-base-content/40">•</span>
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-base-200 bg-base-100 text-sm font-semibold text-primary">S</span>
            <span class="font-semibold"><%= client.brand_name %></span>
            <% if duration_months.present? %>
              <span class="text-base text-base-content/60 md:text-xl">| <%= duration_months %> mois</span>
            <% end %>
          </p>
        </div>

        <div class="card border border-base-100/80 bg-base-100/90 shadow-lg">
          <div class="card-body gap-1 px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.2em] text-base-content/55">Gain mission</p>
            <p class="text-2xl font-semibold text-base-content"><%= number_to_currency(mission_amount_cents / 100.0, unit: "€") %></p>
          </div>
        </div>
      </header>

      <div class="flex flex-wrap gap-2">
        <% @stage_actions.each do |action| %>
          <% action_style = action[:label] == "Voir détails mission" ? "btn-primary" : action[:style] %>
          <% action_class = "#{action_button_base} #{action_button_tone.call(action_style)}" %>
          <% if action[:kind] == :post %>
            <%= button_to action[:label], action[:path], params: action[:params] || {}, class: action_class %>
          <% else %>
            <%= link_to action[:label], action[:path], class: action_class %>
          <% end %>
        <% end %>
        <%= link_to "Demander un avis client", "mailto:#{@mission.client_contact.email}?subject=Retour%20mission%20RIVYR&body=Bonjour%2C%20pourriez-vous%20laisser%20un%20retour%20sur%20la%20mission%20et%20notre%20accompagnement%20%3F", class: "#{action_button_base} #{action_button_tone.call('btn-primary')}" %>
      </div>
    </div>

    <div class="placement-content-scroll space-y-4">
      <div class="card border border-base-100/70 bg-base-100/90 shadow">
        <div class="card-body p-5">
          <div class="flex flex-col gap-3 xl:flex-row xl:items-start xl:justify-between">
            <div>
              <h2 class="text-xl font-semibold text-base-content">Pilotage du placement</h2>
              <p class="mt-1 text-sm text-base-content/60">Renseigne la rémunération, la conformité à l'offre client et l'acceptation du candidat avant validation Rivyr.</p>
            </div>
            <span class="inline-flex items-center rounded-full border px-4 py-2 text-sm font-semibold <%= case @placement.workflow_status
              when 'validated' then 'border-[#d7e9dc] bg-[#edf8f0] text-[#2f6b3c]'
              when 'refused' then 'border-[#f1c9d3] bg-[#fff1f4] text-[#b14360]'
              else 'border-[#f3dfc8] bg-[#fff3e8] text-[#ba6d2f]'
            end %>">
              <%= @placement.workflow_status == "validated" ? "Validé" : (@placement.workflow_status == "refused" ? "Refusé" : "En cours") %>
            </span>
          </div>

          <%= form_with model: @placement, class: "mt-4 grid gap-4 md:grid-cols-2" do |form| %>
            <div>
              <%= form.label :annual_salary_cents, "Rémunération annuelle", class: "mb-2 block text-sm font-semibold text-base-content/70" %>
              <%= form.number_field :annual_salary_cents, min: 0, step: 100, class: "input input-bordered w-full" %>
            </div>
            <div>
              <%= form.label :package_summary, "Package / éléments variables", class: "mb-2 block text-sm font-semibold text-base-content/70" %>
              <%= form.text_field :package_summary, class: "input input-bordered w-full", placeholder: "Fixe, variable, bonus, voiture..." %>
            </div>
            <div>
              <%= form.label :client_offer_compliant, "Conformité à l'offre client", class: "mb-2 block text-sm font-semibold text-base-content/70" %>
              <%= form.select :client_offer_compliant, [["À confirmer", nil], ["Conforme", true], ["Non conforme", false]], {}, class: "select select-bordered w-full" %>
            </div>
            <div>
              <%= form.label :candidate_accepted, "Acceptation du candidat", class: "mb-2 block text-sm font-semibold text-base-content/70" %>
              <%= form.select :candidate_accepted, [["À confirmer", nil], ["Accepté", true], ["Refusé", false]], {}, class: "select select-bordered w-full" %>
            </div>
            <div class="md:col-span-2">
              <%= form.label :notes, "Notes placement", class: "mb-2 block text-sm font-semibold text-base-content/70" %>
              <%= form.text_area :notes, rows: 4, class: "textarea textarea-bordered w-full", placeholder: "Points de vigilance, retour client, remarques de conformité..." %>
            </div>
            <div class="md:col-span-2 flex flex-wrap gap-3">
              <%= form.button "Enregistrer", class: "btn border-[#f1a38b] bg-[#f4a58a] text-white hover:border-[#e39479] hover:bg-[#ee977c]" %>
            </div>
          <% end %>
          <% if current_user&.role_admin? && @placement.workflow_in_progress? %>
            <div class="mt-3 flex flex-wrap gap-3">
              <%= button_to "Valider la conformité", validate_compliance_placement_path(@placement), method: :patch, class: "btn border-[#cfe4d4] bg-[#edf8f0] text-[#2f6b3c] hover:bg-[#e4f4e8]" %>
              <%= button_to "Refuser", refuse_compliance_placement_path(@placement), method: :patch, params: { admin_review_note: "Placement refusé par l'admin Rivyr" }, class: "btn border-[#f1c9d3] bg-[#fff1f4] text-[#b14360] hover:bg-[#ffe6ec]" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="card border border-base-100/70 bg-base-100/86 shadow">
        <div class="card-body p-4">
          <div class="placement-timeline-scroll">
            <div class="flex min-w-[1250px] items-start gap-0">
              <% @stage_states.each_with_index do |step, index| %>
                <div class="flex min-w-[190px] items-start">
                  <div class="space-y-2">
                    <div class="flex items-center gap-2">
                      <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border <%= step[:done] ? 'border-success bg-success text-success-content' : (step[:active] ? 'border-warning bg-warning text-warning-content' : 'border-base-300 bg-base-200 text-base-content/50') %>">
                        <% if step[:done] %>
                          <i class="fa-solid fa-check text-[10px]"></i>
                        <% elsif step[:active] %>
                          <i class="fa-solid fa-hourglass-half text-[10px]"></i>
                        <% else %>
                          <i class="fa-solid fa-circle text-[6px]"></i>
                        <% end %>
                      </span>
                      <span class="text-xs font-medium text-base-content/80"><%= step[:label] %></span>
                    </div>
                    <div class="h-1 w-40 rounded-full <%= step[:done] ? 'bg-success/60' : (step[:active] ? 'bg-warning/60' : 'bg-base-200') %>"></div>
                  </div>
                  <% unless index == @stage_states.size - 1 %>
                    <div class="mt-3 h-px w-4 bg-base-300"></div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-4 xl:grid-cols-12">
        <div class="xl:col-span-4 space-y-4">
          <div class="card border border-base-100/70 bg-base-100/90 shadow">
            <div class="card-body p-4">
              <h2 class="text-xl font-semibold text-base-content">Candidat retenu</h2>
              <div class="mt-2 flex items-center gap-3">
                <div class="avatar placeholder">
                  <div class="h-14 w-14 rounded-full bg-primary/20 text-primary">
                    <span class="text-lg font-semibold"><%= candidate_initials %></span>
                  </div>
                </div>
                <div>
                  <p class="text-lg font-semibold text-base-content"><%= [@candidate.first_name, @candidate.last_name].join(" ") %></p>
                  <p class="text-sm text-base-content/65">Demarrage: <%= @placement.hired_at.present? ? l(@placement.hired_at) : "-" %></p>
                </div>
              </div>
              <div class="mt-3 grid grid-cols-2 gap-2 text-sm">
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Offre acceptée</p>
                  <p class="font-medium text-base-content">
                    <% accepted = (@candidate.status == "placed" || @placement.hired_at.present?) %>
                    <i class="fa-solid <%= accepted ? 'fa-circle-check text-success' : 'fa-circle-xmark text-error' %>"></i>
                    <%= accepted ? "Oui" : "Non" %>
                  </p>
                </div>
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Source</p>
                  <p class="font-medium text-base-content">
                    <i class="<%= source_icon %>"></i>
                    <%= @candidate.source == "jobboard" ? "Hellowork / Jobboard" : @candidate.source %>
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="card border border-base-100/70 bg-base-100/90 shadow">
            <div class="card-body p-4">
              <h2 class="text-xl font-semibold text-base-content">Stats mission</h2>
              <div class="mt-2 grid grid-cols-2 gap-2 text-sm">
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Duree</p>
                  <p class="font-semibold"><%= @mission_stats[:duration_days].present? ? "#{@mission_stats[:duration_days]} jours" : "-" %></p>
                </div>
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Rencontres</p>
                  <p class="font-semibold"><%= @mission_stats[:interviewed_candidates] %></p>
                </div>
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Presents</p>
                  <p class="font-semibold"><%= @mission_stats[:presented_candidates] %></p>
                </div>
                <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Postules</p>
                  <p class="font-semibold"><%= @mission_stats[:applied_candidates] %></p>
                </div>
                <div class="col-span-2 rounded-lg border border-base-200 bg-base-100/80 p-2">
                  <p class="text-base-content/60">Sources</p>
                  <p class="font-semibold"><%= @mission_stats[:sourced_candidates] %></p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="xl:col-span-5 space-y-4">
          <div class="card border border-base-100/70 bg-base-100/90 shadow">
            <div class="card-body p-4">
              <h2 class="text-xl font-semibold text-base-content">Resume contractuel et financier</h2>
              <div class="mt-2 space-y-2 rounded-xl border border-base-200 bg-base-100/80 p-3 text-sm md:text-base">
                <p>
                  <i class="fa-solid fa-file-signature text-primary"></i>
                  Contrat signé le <strong><%= @mission.opened_at.present? ? l(@mission.opened_at) : "-" %></strong>
                </p>
                <p>
                  <i class="fa-solid fa-user-check text-success"></i>
                  Promesse d'embauche <strong><%= @placement.hired_at.present? ? "validée" : "à confirmer" %></strong>
                </p>
                <p>Date de fin <strong><%= closed_at.present? ? l(closed_at) : "-" %></strong></p>
                <p>Montant facture <strong><%= number_to_currency(billed_amount_cents / 100.0, unit: "€") %></strong></p>
                <p>Commission freelance <strong><%= number_to_currency(mission_amount_cents / 100.0, unit: "€") %></strong></p>
              </div>
            </div>
          </div>

          <div class="card border border-base-100/70 bg-base-100/90 shadow">
            <div class="card-body p-4">
              <h2 class="text-xl font-semibold text-base-content">Checklist de validation facturation</h2>
              <div class="mt-2 space-y-2">
                <% @validation_checks.each do |check| %>
                  <div class="flex items-start justify-between gap-3 rounded-lg border border-base-200 bg-base-100/80 p-2">
                    <div>
                      <p class="text-sm font-medium text-base-content"><%= check[:label] %></p>
                      <p class="text-xs text-base-content/60"><%= check[:detail] %></p>
                    </div>
                    <i class="fa-solid <%= check[:ok] ? 'fa-circle-check text-success' : 'fa-circle-xmark text-error' %>"></i>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <aside class="xl:col-span-3 card border border-base-100/70 bg-base-100/90 shadow">
          <div class="card-body p-4">
            <h2 class="text-xl font-semibold text-base-content">Suivi Rivyr</h2>
            <div class="placement-followups-scroll mt-2 space-y-2">
              <% if @rivyr_followups.any? %>
                <% @rivyr_followups.first(10).each do |event| %>
                  <% badge_class = case event[:tone]
                  when "success" then "badge-success"
                  when "action" then "badge-error"
                  else "badge-info"
                  end %>
                  <div class="rounded-lg border border-base-200 bg-base-100/80 p-2">
                    <p class="text-xs text-base-content/55"><%= l(event[:occurred_at], format: "%d/%m/%Y %H:%M") %></p>
                    <div class="mt-1 flex items-start gap-2">
                      <span class="badge badge-xs <%= badge_class %>"></span>
                      <div>
                        <p class="text-sm font-medium text-base-content"><%= event[:title] %></p>
                        <p class="text-xs text-base-content/70"><%= event[:detail] %></p>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% else %>
                <p class="text-sm text-base-content/60">Pas encore d'evenement de suivi.</p>
              <% end %>
            </div>
          </div>
        </aside>
      </div>

      <div class="flex flex-wrap gap-2 pt-1">
        <%= link_to "Retour finances", (current_user&.role_freelance? ? dashboard_freelance_finance_path : placements_path), class: "btn btn-ghost btn-sm" %>
        <%= link_to "Voir mission", mission_path(@mission), class: "btn btn-ghost btn-sm" %>
      </div>
    </div>
  </section>
</div>
