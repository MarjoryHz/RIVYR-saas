                    <button type="button" class="text-[#b14360]" data-action="click->placement-billing-editor#toggleField"><i class="fa-regular fa-building"></i></button>
                  </div>
                  <div class="mt-2 hidden gap-2" data-field-editor>
                    <input type="text" value="<%= client_name %>" class="input input-bordered input-sm w-full">
