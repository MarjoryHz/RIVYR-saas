<% client = @mission.client_contact.client %>
<% started_at = @mission.started_at || @mission.opened_at %>
<% closed_at = @mission.closed_at || (started_at ? started_at + 3.months : nil) %>
<% mission_amount_cents = @commission&.freelancer_share_cents.to_i %>
<% billed_amount_cents = @client_invoice&.amount_cents.to_i %>
<% duration_months = if started_at && closed_at
  ((closed_at.year * 12 + closed_at.month) - (started_at.year * 12 + started_at.month)) + 1
end %>
<% source_icon = case @candidate.source
when "linkedin" then "fa-brands fa-linkedin text-info"
when "jobboard" then "fa-solid fa-briefcase text-warning"
when "network" then "fa-solid fa-user-group text-primary"
when "referral" then "fa-solid fa-handshake text-secondary"
else "fa-solid fa-bullseye text-accent"
end %>
<% client_name = client.brand_name.presence || client.legal_name %>
<% company_initials = client_name.to_s.split.map { |part| part.first }.first(2).join.upcase %>
<% candidate_current_role = @candidate.job_titles.first.presence || "Non renseigné" %>
<% retained_compensation = @placement.annual_salary_cents.to_i.positive? ? number_to_currency(@placement.annual_salary_cents / 100.0, unit: "€", precision: 0) : "Non renseigné" %>
<% placement_start_date = @placement.hired_at || @mission.started_at || @mission.opened_at %>
<% timeline_status = (@stage_states.reverse.find { |step| step[:done] } || @current_stage || @stage_states.first) %>
<% timeline_status_classes = case timeline_status&.dig(:key)
when :paid, :client_payment_received, :wallet_available
  "border-[#d7e9dc] bg-[#edf8f0] text-[#2f6b3c]"
when :in_payment, :client_invoice_validated, :freelancer_invoice_validated
  "border-[#d9e3f7] bg-[#eef4ff] text-[#335c99]"
when :refused
  "border-[#f1c9d3] bg-[#fff1f4] text-[#b14360]"
else
  "border-[#f3dfc8] bg-[#fff3e8] text-[#ba6d2f]"
end %>
<% document_badge_classes = lambda do |received|
  received ? "border-[#d7e9dc] bg-[#edf8f0] text-[#2f6b3c]" : "border-[#f3dfc8] bg-[#fff3e8] text-[#ba6d2f]"
end %>
<% document_badge_label = ->(received) { received ? "Reçu" : "À charger" } %>
<% invoice_ht_cents = mission_amount_cents.positive? ? mission_amount_cents : billed_amount_cents %>
<% invoice_vat_cents = (invoice_ht_cents * 0.2).round %>
<% invoice_ttc_cents = invoice_ht_cents + invoice_vat_cents %>

<div class="mx-auto max-w-7xl p-4 md:p-6">
  <section class="space-y-4">
    <div class="placement-summary-sticky space-y-4">
      <header class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
        <div class="space-y-1">
          <h1 class="text-2xl font-semibold tracking-tight text-base-content md:text-4xl"><%= @mission.title %></h1>
          <p class="flex flex-wrap items-center gap-3 text-xl text-base-content/85 md:text-3xl">
            <% if client.logo.present? %>
              <span class="inline-flex h-11 w-11 items-center justify-center overflow-hidden rounded-2xl border border-base-200 bg-white shadow-sm">
                <%= image_tag client_logo_src(client.logo), alt: "Logo #{client_name}", class: "h-full w-full object-contain" %>
              </span>
            <% else %>
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-base-200 bg-base-100 text-sm font-semibold text-primary shadow-sm"><%= company_initials %></span>
            <% end %>
            <span class="font-semibold"><%= client_name %></span>
            <% if duration_months.present? %>
              <span class="text-base text-base-content/60 md:text-xl">| <%= duration_months %> mois</span>
            <% end %>
          </p>
        </div>

        <div class="card border border-base-100/80 bg-base-100/90 shadow-lg">
          <div class="card-body gap-1 px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.2em] text-base-content/55">Gain mission</p>
            <p class="text-2xl font-semibold text-base-content"><%= number_to_currency(mission_amount_cents / 100.0, unit: "€") %></p>
          </div>
        </div>
      </header>

    </div>

    <div class="placement-content-scroll space-y-4">
      <div class="card border border-base-100/70 bg-base-100/90 shadow" data-controller="placement-billing-editor">
        <div class="card-body p-5">
          <div class="flex flex-col gap-3 xl:flex-row xl:items-start xl:justify-between">
            <div>
              <h2 class="text-xl font-semibold text-base-content">Pilotage du placement</h2>
              <p class="mt-1 text-sm text-base-content/60">Les informations utiles pour déclencher la facturation et vérifier que le dossier est complet.</p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
              <% if timeline_status&.dig(:key) == :client_payment_received %>
                <button type="button" class="btn rounded-full border-[#ed0e64] bg-[#ed0e64] px-4 text-sm font-semibold text-white hover:border-[#cf0c57] hover:bg-[#cf0c57]" onclick="document.getElementById('client-invoice-modal').showModal()">
                  Création facture
                </button>
              <% elsif timeline_status&.dig(:key) == :documents_validated %>
                <button type="button" class="btn rounded-full border-[#ed0e64] bg-[#ed0e64] px-4 text-sm font-semibold text-white hover:border-[#cf0c57] hover:bg-[#cf0c57]" onclick="document.getElementById('submit-client-invoice-modal').showModal()">
                  Créer la facture client
                </button>
              <% end %>
              <span class="inline-flex items-center rounded-full border px-4 py-2 text-sm font-semibold <%= timeline_status_classes %>">
                <%= timeline_status&.dig(:label) || "Placement réalisé" %>
              </span>
            </div>
          </div>

          <div class="mt-4 grid gap-4 xl:grid-cols-3">
            <section class="rounded-[1.35rem] border border-[#f0dce3] bg-[#fffafc] p-4">
              <div class="flex items-center gap-2">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-2xl bg-[#fdeef3] text-[#b14360]">
                  <i class="fa-solid fa-building"></i>
                </span>
                <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-[#8b4452]">Information client</h3>
              </div>
              <div class="mt-4 space-y-3 text-sm text-base-content/80">
                <div class="rounded-2xl border border-base-200 bg-white px-3 py-2" data-editable-field>
